      function translateTextNode(node: Node) {
        if (node.nodeType === Node.TEXT_NODE) {
          const original = node.nodeValue?.trim();
          if (original && translations[original]) {
            node.nodeValue = translations[original];
          } else if (original) {
            let translated = original;
            let matched = false;
            
            if (translated.includes("Thời gian đọc:")) {
              translated = translated.replace("Thời gian đọc:", "Read time:");
              translated = translated.replace("phút", "min");
              matched = true;
            }
            if (translated.includes("người phụ thuộc")) {
              translated = translated.replace("người phụ thuộc", "dependents");
              matched = true;
            }
            if (translated.includes("Sắp ra mắt")) {
              translated = translated.replace("Sắp ra mắt", "Coming Soon");
              matched = true;
            }
            if (translated.includes("Mở công cụ")) {
              translated = translated.replace("Mở công cụ", "Open Tool");
              matched = true;
            }

            if (matched) {
              node.nodeValue = translated;
            }
          }
        } else {
          if (node.nodeName !== 'SCRIPT' && node.nodeName !== 'STYLE') {
            for (let child of Array.from(node.childNodes)) {
              translateTextNode(child);
            }
          }
        }
      }

      function applyLanguage(lang: string) {
        if (lang === 'en') {
          document.title = document.title.replace("Trợ Lý Số", "Trolyso");
          
          translateTextNode(document.body);

          document.querySelectorAll('input, textarea').forEach(el => {
            const input = el as HTMLInputElement | HTMLTextAreaElement;
            const ph = input.placeholder?.trim();
            if (ph && translations[ph]) {
              input.placeholder = translations[ph];
            }
          });

          document.querySelectorAll('option').forEach(el => {
            const opt = el as HTMLOptionElement;
            const text = opt.text?.trim();
            if (text && translations[text]) {
              opt.text = translations[text];
            }
          });

          if (searchInput) searchInput.placeholder = "Search tools, articles...";
        } else {
          if (localStorage.getItem('lang') === 'en') {
            localStorage.setItem('lang', 'vi');
            window.location.reload();
          }
        }
      }

      langSelector?.addEventListener('change', () => {
        const lang = langSelector.value;
        localStorage.setItem('lang', lang);
        if (lang === 'en') {
          applyLanguage('en');
        } else {
          applyLanguage('vi');
        }
      });

      // Load ngôn ngữ đã lưu khi tải trang
      const savedLang = localStorage.getItem('lang') || 'vi';
      if (langSelector) langSelector.value = savedLang;
      if (savedLang === 'en') {
        // Chờ DOM load để áp dụng dịch
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => applyLanguage('en'));
        } else {
          applyLanguage('en');
        }
      }
    </script>
