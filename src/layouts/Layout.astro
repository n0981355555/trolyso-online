    <!-- Theme toggle & Global search client logic -->
    <script>
      const themeToggleBtn = document.getElementById('themeToggle');
      const themeSun = document.getElementById('themeSun');
      const themeMoon = document.getElementById('themeMoon');

      // Update toggle icon visibility on load
      function updateIcons() {
        if (document.documentElement.classList.contains('dark')) {
          themeSun?.classList.remove('hidden');
          themeMoon?.classList.add('hidden');
        } else {
          themeSun?.classList.add('hidden');
          themeMoon?.classList.remove('hidden');
        }
      }
      updateIcons();

      themeToggleBtn?.addEventListener('click', () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('color-theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('color-theme', 'dark');
        }
        updateIcons();
      });

      // Global Search Engine (High Performance & Debounced)
      interface SearchItem {
        title: string;
        desc?: string;
        url: string;
        _norm?: string;
      }

      let searchIndex: SearchItem[] | null = null;
      let isFetchingSearchIndex = false;

      function removeVietnameseTones(str: string) {
        let result = str.toLowerCase();
        result = result.replace(/à|á|ạ|ả|ã|â|ầ|ấ|ậ|ẩ|ẫ|ă|ằ|ắ|ặ|ẳ|ẵ/g, "a");
        result = result.replace(/è|é|ẹ|ẻ|ẽ|ê|ề|ế|ệ|ể|ễ/g, "e");
        result = result.replace(/ì|í|ị|ỉ|ĩ/g, "i");
        result = result.replace(/ò|ó|ọ|ỏ|õ|ô|ồ|ố|ộ|ổ|ỗ|ơ|ờ|ớ|ợ|ở|ỡ/g, "o");
        result = result.replace(/ù|ú|ụ|ủ|ũ|ư|ừ|ứ|ự|ử|ữ/g, "u");
        result = result.replace(/ỳ|ý|ỵ|ỷ|ỹ/g, "y");
        result = result.replace(/đ/g, "d");
        result = result.replace(/[^a-z0-9\s]/g, ""); // Keep only letters, numbers and spaces
        return result.normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
      }

      async function loadSearchIndex() {
        if (searchIndex || isFetchingSearchIndex) return;
        isFetchingSearchIndex = true;
        try {
          const res = await fetch('/search-index.json');
          if (res.ok) {
            const rawData: SearchItem[] = await res.json();
            // Pre-calculate normalized search strings once for 100x faster filtering
            searchIndex = rawData.map(item => ({
              ...item,
              _norm: removeVietnameseTones(item.title + ' ' + (item.desc || ''))
            }));
          } else {
            console.error('Failed to fetch search-index.json');
            searchIndex = [];
          }
        } catch (err) {
          console.error('Error loading search index:', err);
          searchIndex = [];
        } finally {
          isFetchingSearchIndex = false;
        }
      }

      function setupSearch(inputId: string, dropdownId: string) {
        const input = document.getElementById(inputId) as HTMLInputElement;
        const dropdown = document.getElementById(dropdownId);
        if (!input || !dropdown) return;

        input.addEventListener('focus', loadSearchIndex);
        input.addEventListener('mouseenter', loadSearchIndex);

        let debounceTimer: any = null;

        input.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(async () => {
            if (!searchIndex) {
              await loadSearchIndex();
            }
            if (!searchIndex) return;
            const rawQuery = input.value.trim();
            if (!rawQuery) {
              dropdown.classList.add('hidden');
              return;
            }

            const query = removeVietnameseTones(rawQuery);
            const queryWords = query.split(/\s+/).filter(Boolean);
            if (queryWords.length === 0) {
              dropdown.classList.add('hidden');
              return;
            }

            // High performance search: use pre-normalized _norm string & early exit at 8 items
            const matches: SearchItem[] = [];
            for (let i = 0; i < searchIndex.length; i++) {
              const item = searchIndex[i];
              const norm = item._norm || '';
              if (queryWords.every(word => norm.includes(word))) {
                matches.push(item);
                if (matches.length >= 8) break; // Stop loop immediately once 8 matches found!
              }
            }

            if (matches.length === 0) {
              dropdown.innerHTML = `<div class="p-3 text-xs text-slate-400 text-center">Không tìm thấy kết quả phù hợp</div>`;
              dropdown.classList.remove('hidden');
              return;
            }

            dropdown.innerHTML = matches.map(item => `
              <a href="${item.url}" class="block p-2.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-left transition select-none">
                <div class="font-semibold text-xs text-slate-900 dark:text-white">${item.title}</div>
                <div class="text-[10px] text-slate-400 line-clamp-1 mt-0.5">${item.desc || ''}</div>
              </a>
            `).join('');
            dropdown.classList.remove('hidden');
          }, 120);
        });

        // Đóng dropdown khi click bên ngoài
        document.addEventListener('click', (e) => {
          if (e.target !== input && e.target !== dropdown) {
            dropdown.classList.add('hidden');
          }
        });
      }

      // Initialize
      setupSearch('globalSearchInput', 'searchDropdown');
      setupSearch('heroSearchInput', 'heroSearchDropdown');
      setupSearch('mobileSearchInput', 'mobileSearchDropdown');

      // Scroll threshold to show/hide the floating mobile search
      const mobileFloatingSearch = document.getElementById('mobileFloatingSearch');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 250) {
          mobileFloatingSearch?.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
        } else {
          mobileFloatingSearch?.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
        }
      });

