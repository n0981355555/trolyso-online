    <!-- Deferred Google Analytics (GA4) for Performance Optimization -->
    <script is:inline>
      window.addEventListener('load', () => {
        setTimeout(() => {
          const script = document.createElement('script');
          script.src = "https://www.googletagmanager.com/gtag/js?id=G-0V28V469Y4";
          script.async = true;
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-0V28V469Y4');
        }, 1500); // 1.5s delay after page load to free main thread
      });
    </script>
    
    <!-- Inline script to prevent theme flash -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('color-theme')) {
          return localStorage.getItem('color-theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
    
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    
    <style is:global>
      /* Global accessibility color contrast overrides in light mode */
      html:not(.dark) .text-slate-400 {
        color: #64748b !important;
      }
      html:not(.dark) .text-slate-500 {
        color: #475569 !important;
      }
      html:not(.dark) .text-slate-600 {
        color: #334155 !important;
      }

      /* Subtle premium shadows for cards and blocks in light mode */
      html:not(.dark) .rounded-2xl.bg-white,
      html:not(.dark) .rounded-xl.bg-white,
      html:not(.dark) a.group {
        box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.06), 0 8px 16px -6px rgba(15, 23, 42, 0.04) !important;
      }
    </style>
  </head>
