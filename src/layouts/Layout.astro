---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Trợ Lý Số - Nền tảng công cụ trực tuyến miễn phí" } = Astro.props;
---

<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="144x144" href="/favicon-144.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts Preconnect & Async Load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap" /></noscript>
    
    <!-- Deferred Google Analytics (GA4) for Performance Optimization -->
    <script is:inline>
      window.addEventListener('load', () => {
        setTimeout(() => {
          const script = document.createElement('script');
          script.src = "https://www.googletagmanager.com/gtag/js?id=G-0V28V469Y4";
          script.async = true;
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-0V28V469Y4');
        }, 1500); // 1.5s delay after page load to free main thread
      });
    </script>
    
    <!-- Inline script to prevent theme flash -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('color-theme')) {
          return localStorage.getItem('color-theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
    
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    
    <style is:global>
      /* Global accessibility color contrast overrides in light mode */
      html:not(.dark) .text-slate-400 {
        color: #64748b !important;
      }
      html:not(.dark) .text-slate-500 {
        color: #475569 !important;
      }
      html:not(.dark) .text-slate-600 {
        color: #334155 !important;
      }
    </style>
  </head>
  <body class="bg-slate-50 dark:bg-brand-darkBg text-slate-800 dark:text-slate-200 min-h-screen flex flex-col transition-colors duration-300">
    <!-- Header -->
    <header class="bg-white/80 dark:bg-brand-darkCard/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 sticky top-0 z-50 transition-colors">
      <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="text-2xl sm:text-3xl font-heading font-extrabold flex items-center select-none tracking-tight">
          <span class="text-[#0063b6] dark:text-white transition-colors">trolyso</span><span class="text-[#49a2dc] transition-colors">.online</span>
        </a>
        
        <!-- Dark Mode Toggle & Menu -->
        <div class="flex items-center gap-3 sm:gap-4">
          <!-- Search Bar -->
          <div class="relative hidden sm:block">
            <input type="text" id="globalSearchInput" placeholder="Tìm công cụ, bài viết..." aria-label="Tìm kiếm công cụ và bài viết" class="w-48 lg:w-56 pl-9 pr-4 py-2 rounded-full border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint text-xs font-medium transition-all" />
            <svg class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <div id="searchDropdown" class="absolute right-0 top-full mt-2 w-72 bg-white dark:bg-brand-darkCard border border-slate-200 dark:border-slate-800 rounded-xl shadow-xl z-50 p-2 hidden max-h-80 overflow-y-auto">
              <!-- Results -->
            </div>
          </div>

          <a href="/blog/" class="text-sm font-semibold hover:text-brand-blue dark:hover:text-brand-mint">
            Cẩm Nang
          </a>
          
          <!-- Theme Toggle Button -->
          <button id="themeToggle" class="p-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:ring-2 hover:ring-slate-300 dark:hover:ring-slate-700 transition" aria-label="Toggle theme">
            <!-- Sun Icon (shown in dark mode) -->
            <svg id="themeSun" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707-.707m12.728 0l-.707.707M6.343 6.343l-.707-.707m12.728 12.728A9 9 0 115.52 12a9 9 0 0112.728 12.728z"></path>
            </svg>
            <!-- Moon Icon (shown in light mode) -->
            <svg id="themeMoon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Page Content Slot -->
    <slot />

    <!-- Footer -->
    <footer class="bg-white dark:bg-brand-darkCard border-t border-slate-200 dark:border-slate-800 py-10 text-sm text-slate-500 dark:text-slate-400 mt-auto transition-colors">
      <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
        
        <!-- Copyright & Social Links -->
        <div class="flex flex-col items-center md:items-start gap-3">
          <p>© 2026 Trợ Lý Số (trolyso.online). Bảo lưu mọi quyền.</p>
          <!-- Social Icons (Placeholder links) -->
          <div class="flex items-center gap-4">
            <!-- Zalo -->
            <a href="#" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-brand-blue dark:hover:text-brand-mint transition-colors" title="Liên hệ Zalo" aria-label="Liên hệ Zalo">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12c0 1.93.55 3.73 1.5 5.25L2 22l4.75-1.5c1.52.95 3.32 1.5 5.25 1.5 5.52 0 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V7h2v5z"/>
              </svg>
            </a>
            <!-- Facebook -->
            <a href="#" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-brand-blue dark:hover:text-brand-mint transition-colors" title="Facebook" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1V12h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
              </svg>
            </a>
            <!-- Gmail -->
            <a href="mailto:" class="text-slate-500 hover:text-brand-blue dark:hover:text-brand-mint transition-colors" title="Email liên hệ" aria-label="Email liên hệ">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Footer Links & Language Switcher -->
        <div class="flex flex-col items-center md:items-end gap-3">
          <div class="flex gap-4">
            <a href="/dieu-khoan/" class="hover:underline">Điều khoản</a>
            <a href="/chinh-sach-bao-mat/" class="hover:underline">Chính sách bảo mật</a>
          </div>
          
          <!-- Language Selector -->
          <div class="flex items-center gap-2">
            <span class="text-xs text-slate-500 dark:text-slate-400">Ngôn ngữ:</span>
            <select id="langSelector" aria-label="Chọn ngôn ngữ hiển thị" class="px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-brand-blue dark:focus:ring-brand-mint cursor-pointer">
              <option value="vi" selected>Tiếng Việt (VI)</option>
              <option value="en">English (EN)</option>
            </select>
          </div>
        </div>

      </div>
    </footer>

    <!-- Theme toggle & Global search client logic -->
    <script>
      const themeToggleBtn = document.getElementById('themeToggle');
      const themeSun = document.getElementById('themeSun');
      const themeMoon = document.getElementById('themeMoon');

      // Update toggle icon visibility on load
      function updateIcons() {
        if (document.documentElement.classList.contains('dark')) {
          themeSun?.classList.remove('hidden');
          themeMoon?.classList.add('hidden');
        } else {
          themeSun?.classList.add('hidden');
          themeMoon?.classList.remove('hidden');
        }
      }
      updateIcons();

      themeToggleBtn?.addEventListener('click', () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('color-theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('color-theme', 'dark');
        }
        updateIcons();
      });

      // Global Search Engine
      const searchInput = document.getElementById('globalSearchInput') as HTMLInputElement;
      const searchDropdown = document.getElementById('searchDropdown');

        const searchIndex = [
          { title: "Tính lương Gross sang Net (2026)", desc: "Quy đổi lương Gross sang Net chuẩn bảo hiểm thuế", url: "/" },
          { title: "Tính bảo hiểm xã hội 1 lần", desc: "Ước tính số tiền rút BHXH một lần nhanh chóng", url: "/calculators/tinh-bhxh-1-lan/" },
          { title: "Trình tạo mã VietQR thanh toán", desc: "Tạo mã QR chuyển khoản nhanh hơn 40 ngân hàng", url: "/calculators/tao-ma-qr/" },
          { title: "Đọc số thành chữ tiếng Việt", desc: "Chuyển số tiền thành chữ viết hóa đơn kế toán", url: "/calculators/doc-so-thanh-chu/" },
          { title: "Tính thuế thu nhập cá nhân 2026", desc: "Tính thuế TNCN lũy tiến từng phần chi tiết", url: "/calculators/tinh-thue-tncn/" },
          { title: "Nén ảnh WebP trực tuyến", desc: "Nén tối ưu dung lượng ảnh JPG PNG sang WebP", url: "/calculators/nen-anh/" },
          { title: "Tạo chữ ký Email chuyên nghiệp", desc: "Thiết kế chữ ký email HTML chuyên nghiệp Outlook Gmail", url: "/calculators/chu-ky-email/" },
          { title: "Tạo văn bản hành chính chuẩn Nghị định 30", desc: "Soạn thảo 15 loại văn bản quy phạm pháp luật và 29 loại văn bản hành chính", url: "/calculators/tao-van-ban/" },
          { title: "Dự tính tuổi nghỉ hưu & lương hưu", desc: "Tính tuổi nghỉ hưu lộ trình Nghị định 135 và mức hưởng lương hưu dự kiến", url: "/calculators/tinh-luong-huu/" },
          { title: "Trình tạo ảnh AI miễn phí bằng Prompt", desc: "Tạo hình ảnh nghệ thuật, ảnh anime bằng văn bản qua công nghệ AI", url: "/calculators/tao-anh-ai/" },
          { title: "Blog Cẩm Nang", desc: "Danh sách bài viết hướng dẫn thuế, bảo hiểm, kế toán", url: "/blog/" },
          { title: "Bài viết: Hướng dẫn tính thuế TNCN", desc: "Cẩm nang tính thuế TNCN bậc lũy tiến từng phần", url: "/blog/huong-dan-tinh-thue-tncn/" },
          { title: "Bài viết: Cách tính BHXH 1 lần", desc: "Thủ tục và cách tính bảo hiểm xã hội một lần", url: "/blog/cach-tinh-bhxh-1-lan/" },
          { title: "Bài viết: Phân biệt lương Gross và Net", desc: "Nên đàm phán lương Gross hay lương Net khi phỏng vấn", url: "/blog/phan-biet-luong-gross-va-net/" },
          { title: "Bài viết: Hướng dẫn tạo mã VietQR", desc: "Chuẩn thanh toán VietQR Napas tại cửa hàng", url: "/blog/huong-dan-tao-ma-vietqr/" },
          { title: "Bài viết: Quy tắc đọc số thành chữ", desc: "Cách viết số tiền bằng chữ trên hóa đơn đỏ không sai sót", url: "/blog/quy-tac-doc-so-thanh-chu-ke-toan/" },
          { title: "Bài viết: Cách nén ảnh WebP tối ưu", desc: "Hướng dẫn nén hình ảnh PNG JPG sang WebP cải thiện SEO", url: "/blog/huong-dan-nen-anh-webp/" },
          { title: "Bài viết: Tạo chữ ký Email chuyên nghiệp", desc: "Cách thiết kế chữ ký email HTML cho Gmail Outlook", url: "/blog/cach-tao-chu-ky-email-html/" },
          { title: "Bài viết: Trình bày văn bản chuẩn Nghị định 30", desc: "Cách soạn thảo văn bản hành chính và quy phạm pháp luật đúng chuẩn Chính phủ", url: "/blog/huong-dan-trinh-bay-van-ban-hanh-chinh/" },
          { title: "Bài viết: Lương Gross là gì? Phân biệt và cách tính", desc: "Tìm hiểu chi tiết lương Gross và Net, công thức quy đổi tiền lương thực tế", url: "/blog/luong-gross-la-gi/" },
          { title: "Bài viết: Tính tuổi nghỉ hưu 2026", desc: "Hướng dẫn cách tính tuổi nghỉ hưu 2026 chi tiết cho nam và nữ", url: "/blog/tinh-tuoi-nghi-huu-2026/" },
          { title: "Bài viết: Đóng BHXH bao nhiêu năm hưởng lương hưu tối đa", desc: "Số năm đóng bảo hiểm xã hội đạt tỷ lệ 75% lương hưu", url: "/blog/dong-bhxh-bao-nhieu-nam-thi-duoc-luong-huu-toi-da/" },
          { title: "Bài viết: Hướng dẫn cách tính lương hưu BHXH", desc: "Công thức và hướng dẫn tự tính lương hưu bảo hiểm xã hội 2026", url: "/blog/cach-tinh-luong-huu-bhxh/" },
          { title: "Tính tiền chậm nộp thuế & tờ khai", desc: "Tính nhanh tiền phạt chậm nộp thuế 0.03% mỗi ngày và tờ khai theo Nghị định 125", url: "/calculators/tinh-tien-cham-nop-thue/" },
          { title: "Bài viết: Cách tính tiền chậm nộp thuế", desc: "Hướng dẫn cách tính tiền phạt chậm nộp thuế 0.03% và tờ khai mới nhất", url: "/blog/huong-dan-tinh-tien-cham-nop-thue/" },
          { title: "Bài viết: Tôi được giảm bao nhiêu thuế năm 2026", desc: "Hướng dẫn các khoản giảm trừ gia cảnh thuế TNCN mới nhất năm 2026", url: "/blog/toi-duoc-giam-bao-nhieu-thue-nam-2026/" },
           { title: "Bài viết: Máy tính tăng lương sau cải cách thuế 2026", desc: "Hướng dẫn tự tính lương thực lĩnh (Net) sau điều chỉnh lương cơ sở và thuế TNCN", url: "/blog/may-tinh-tang-luong-sau-cai-cach-thue/" },
          { title: "Bài viết: Lương bao nhiêu phải đóng thuế TNCN 2026", desc: "Ngưỡng thu nhập chịu thuế TNCN, các khoản giảm trừ và 15 ví dụ thực tế", url: "/blog/luong-bao-nhieu-phai-dong-thue-thu-nhap-ca-nhan-2026/" },
          { title: "Tính chỉ số BMI cơ thể & Cân nặng lý tưởng", desc: "Tính chỉ số khối cơ thể và kiểm tra cân nặng lý tưởng WHO", url: "/calculators/tinh-bmi/" },
          { title: "Giải phương trình bậc 2, 3", desc: "Giải nhanh phương trình bậc hai, bậc ba hiển thị các bước giải Delta và vẽ đồ thị", url: "/calculators/giai-phuong-trinh/" },
          { title: "Đếm ngày yêu nhau online", desc: "Love Counter đếm chính xác thời gian bên nhau chạy giây thực tế", url: "/calculators/dem-ngay-yeu-nhau/" },
          { title: "Bài viết: Hướng dẫn tính chỉ số BMI", desc: "Cách tính chỉ số khối cơ thể BMI chuẩn WHO và người Châu Á", url: "/blog/tinh-chi-so-bmi-va-can-nang-ly-tuong/" },
          { title: "Bài viết: Hướng dẫn giải phương trình bậc 2, 3", desc: "Công thức tính Delta phương trình bậc 2 và phương pháp giải phương trình bậc 3", url: "/blog/huong-dan-giai-phuong-trinh-bac-2-bac-3/" },
          { title: "Bài viết: Hướng dẫn sử dụng đếm ngày yêu nhau", desc: "Cách thiết lập đồng hồ đếm ngày yêu nhau online bảo mật cục bộ", url: "/blog/cach-su-dung-trinh-dem-ngay-yeu-nhau/" },
          { title: "Lịch vạn niên & Âm lịch hôm nay", desc: "Xem lịch âm dương, đổi ngày âm dương và xem giờ hoàng đạo tốt lành", url: "/calculators/lich-van-nien/" },
          { title: "Đo tốc độ mạng Internet Speedtest", desc: "Kiểm tra tốc độ download, upload và độ trễ ping mạng wifi 4G 5G", url: "/calculators/speedtest/" },
          { title: "Bài viết: Hướng dẫn xem lịch vạn niên", desc: "Cách xem lịch âm dương hôm nay và tính Can Chi, giờ hoàng đạo", url: "/blog/huong-dan-tra-cuu-lich-van-nien-lich-am-hom-nay/" },
          { title: "Bài viết: Hướng dẫn đo tốc độ mạng Speedtest", desc: "Cách kiểm tra tốc độ internet và tối ưu băng thông đường truyền", url: "/blog/huong-dan-kiem-tra-toc-do-mang-speedtest-online/" },
          { title: "Điều khoản dịch vụ", desc: "Quy định sử dụng website và tuyên bố miễn trừ trách nhiệm pháp lý", url: "/dieu-khoan/" },
          { title: "Chính sách bảo mật", desc: "Cam kết bảo mật thông tin và quyền riêng tư của khách truy cập", url: "/chinh-sach-bao-mat/" },
        ];

      function removeVietnameseTones(str: string) {
        return str
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/đ/g, 'd')
          .replace(/Đ/g, 'D')
          .toLowerCase();
      }

      searchInput?.addEventListener('input', () => {
        const query = removeVietnameseTones(searchInput.value.trim());
        if (!query) {
          searchDropdown?.classList.add('hidden');
          return;
        }

        const results = searchIndex.filter(item => 
          removeVietnameseTones(item.title).includes(query) || 
          removeVietnameseTones(item.desc).includes(query)
        );

        if (results.length === 0) {
          if (searchDropdown) {
            searchDropdown.innerHTML = `<div class="p-3 text-xs text-slate-400 text-center">Không tìm thấy kết quả phù hợp</div>`;
            searchDropdown.classList.remove('hidden');
          }
          return;
        }

        if (searchDropdown) {
          searchDropdown.innerHTML = results.map(item => `
            <a href="${item.url}" class="block p-2.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-left transition select-none">
              <div class="font-semibold text-xs text-slate-900 dark:text-white">${item.title}</div>
              <div class="text-[10px] text-slate-400 line-clamp-1 mt-0.5">${item.desc}</div>
            </a>
          `).join('');
          searchDropdown.classList.remove('hidden');
        }
      });

      // Đóng dropdown khi click bên ngoài
      document.addEventListener('click', (e) => {
        if (e.target !== searchInput && e.target !== searchDropdown) {
          searchDropdown?.classList.add('hidden');
        }
      });

      // Language Switcher Logic
      const langSelector = document.getElementById('langSelector') as HTMLSelectElement;

      const translations: Record<string, string> = {
        // Navigation & Search
        "Cẩm Nang": "Handbook",
        "Điều khoản": "Terms",
