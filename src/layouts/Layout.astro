    <!-- Dynamic Live Stats Counter & Real Calculation Tracking Client Script -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const pathname = window.location.pathname;
        let slug = '';
        let type = '';

        if (pathname.startsWith('/blog/') && pathname !== '/blog/' && pathname !== '/blog') {
          slug = pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
          type = 'post';
        } else if (pathname.startsWith('/calculators/') && pathname !== '/calculators/' && pathname !== '/calculators') {
          slug = pathname.replace(/^\/calculators\//, '').replace(/\/$/, '');
          type = 'tool';
        }

        // Helper function to update badge counter UI
        const updateBadgeUI = (targetSlug: string, addedCount: number) => {
          const badges = document.querySelectorAll(`.stats-badge[data-slug="${targetSlug}"]`);
          badges.forEach(badge => {
            const counterEl = badge.querySelector('.stats-counter');
            const baseStr = badge.getAttribute('data-base-count');
            if (counterEl && baseStr) {
              const baseCount = parseInt(baseStr, 10) || 3000;
              const total = baseCount + addedCount;
              counterEl.textContent = total >= 1000 ? `${(total / 1000).toFixed(1)}k+` : `${total}`;
            }
          });
        };

        // Render real counts stored in localStorage across all badges
        document.querySelectorAll('.stats-badge').forEach(badge => {
          const s = badge.getAttribute('data-slug');
          if (s) {
            const realCount = parseInt(localStorage.getItem(`calc_real_count_${s}`) || '0', 10);
            if (realCount > 0) {
              updateBadgeUI(s, realCount);
            }
          }
        });

        if (slug && type === 'tool') {
          const storageKey = `calc_real_count_${slug}`;
          
          // Increment calculation count on page visit
          const sessionKey = `visited_calc_${slug}`;
          if (!sessionStorage.getItem(sessionKey)) {
            sessionStorage.setItem(sessionKey, '1');
            let current = parseInt(localStorage.getItem(storageKey) || '0', 10);
            current += 1;
            localStorage.setItem(storageKey, current.toString());
            updateBadgeUI(slug, current);
          }

          // Track explicit user calculation clicks (form submit, calculate button clicks)
          document.addEventListener('click', (e) => {
            const btn = (e.target as HTMLElement)?.closest('button, input[type="submit"], .calc-btn, #btnCalculate, #btn-calc');
            if (btn) {
              let current = parseInt(localStorage.getItem(storageKey) || '0', 10);
              current += 1;
              localStorage.setItem(storageKey, current.toString());
              updateBadgeUI(slug, current);
            }
          });

          // Also listen to form submit
          document.addEventListener('submit', () => {
            let current = parseInt(localStorage.getItem(storageKey) || '0', 10);
            current += 1;
            localStorage.setItem(storageKey, current.toString());
            updateBadgeUI(slug, current);
          });
        }
      });
    </script>
