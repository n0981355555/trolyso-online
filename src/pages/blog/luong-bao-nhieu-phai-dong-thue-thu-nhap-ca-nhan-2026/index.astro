  description="Hướng dẫn chi tiết mức lương chịu thuế TNCN năm 2026. Tổng hợp các khoản giảm trừ và 15 ví dụ tính thuế thực tế chi tiết từ lương thấp đến lương cao."
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    
    <!-- Breadcrumb -->
