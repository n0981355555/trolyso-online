      &lt;div style="font-size: 13px; color: #666666; margin-bottom: 8px;"&gt;Trưởng phòng Kinh Doanh&lt;/div&gt;
      
      &lt;div style="font-size: 12px; color: #555555;"&gt;
        &lt;span style="font-weight: bold;"&gt;Hotline:&lt;/span&gt; 098.135.5555 &lt;br/&gt;
        &lt;span style="font-weight: bold;"&gt;Website:&lt;/span&gt; &lt;a href="https://trolyso.online" style="color: #0063b6; text-decoration: none;"&gt;trolyso.online&lt;/a&gt;
