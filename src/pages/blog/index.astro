const featuredPost = posts[0];
const subFeaturedPosts = posts.slice(1, 4);
const regularPosts = posts.slice(4);

function getCategorySlug(category: string) {
  if (category.includes("Thuế") || category.includes("Lương")) return "thue-luong";
  if (category.includes("Bảo hiểm")) return "bao-hiem";
  if (category.includes("Pháp lý") || category.includes("Doanh nghiệp")) return "phap-ly";
  if (category.includes("Sư phạm") || category.includes("Tuyển sinh")) return "giao-duc";
  return "cong-nghe";
}
---

<Layout 
  title="Cẩm Nang Trợ Lý Số - Tin Tức, Hướng Dẫn Kế Toán, Thuế & Tiện Ích"
  description="Trang tin tức và cẩm nang hướng dẫn chuyên sâu về thuế, lương, bảo hiểm xã hội, thủ tục pháp lý doanh nghiệp và tiện ích công nghệ mới nhất 2026."
>
  <!-- Background Glow -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_20%,rgba(37,99,235,0.05),transparent_60%)] pointer-events-none z-0"></div>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12 w-full z-10 relative">
    
    <!-- Portal Header & Search Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 pb-8 border-b border-slate-200/80 dark:border-slate-800/80">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-blue/10 dark:bg-brand-mint/10 text-brand-blue dark:text-brand-mint text-xs font-bold mb-3">
          <span>📰</span> CỔNG TIN TỨC & CẨM NANG CHUYÊN SÂU 2026
        </div>
        <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white tracking-tight">
          Cẩm Nang Trợ Lý Số
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 mt-2 max-w-2xl">
          Cập nhật quy định mới nhất về Thuế, BHXH, Pháp lý doanh nghiệp & Hướng dẫn sử dụng các tiện ích số chuẩn xác.
        </p>
      </div>

      <!-- Real-time Live Search Input -->
      <div class="relative w-full md:w-80 shrink-0">
        <input 
          type="text" 
          id="blogSearchInput" 
          placeholder="Tìm bài viết, cẩm nang..." 
          class="w-full pl-10 pr-4 py-2.5 rounded-2xl bg-white dark:bg-brand-darkCard border border-slate-200 dark:border-slate-800 text-sm font-medium text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint shadow-sm transition-all"
        />
        <svg class="w-4 h-4 text-slate-400 absolute left-3.5 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
    </div>

    <!-- Spotlight / Featured News Section (Top Layout) -->
    <section class="mb-14">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-heading font-extrabold text-slate-900 dark:text-white flex items-center gap-2">
          <span class="w-2.5 h-6 bg-brand-blue dark:bg-brand-mint rounded-full inline-block"></span>
          Bài Viết Nổi Bật & Mới Nhất
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <!-- Main Big Hero Card (8 cols) -->
        <article class="blog-article lg:col-span-7 group bg-white dark:bg-brand-darkCard rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:border-brand-blue dark:hover:border-brand-mint hover:shadow-xl transition-all duration-300 flex flex-col justify-between" data-group={getCategorySlug(featuredPost.category)} data-search={`${featuredPost.title} ${featuredPost.description}`.toLowerCase()}>
          <div>
            <div class="relative aspect-[16/9] w-full overflow-hidden bg-slate-100 dark:bg-slate-900">
              <img 
                src={featuredPost.image} 
                alt={featuredPost.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 rounded-t-3xl"
                loading="eager"
              />
              <span class="absolute top-4 left-4 px-3 py-1 bg-red-600 text-white text-xs font-black uppercase tracking-wider rounded-xl shadow-lg flex items-center gap-1">
                🔥 {featuredPost.badge || "MỚI NHẤT"}
              </span>
              <span class="absolute bottom-4 left-4 px-3 py-1 bg-slate-900/80 backdrop-blur-md text-white text-xs font-bold rounded-lg">
                {featuredPost.category}
              </span>
            </div>

            <div class="p-6 sm:p-8 space-y-3">
              <div class="flex items-center gap-3 text-xs text-slate-400 font-medium">
                <span>📅 {featuredPost.date}</span>
                <span>•</span>
                <span>⏱️ {featuredPost.readTime}</span>
                <span>•</span>
                <span class="text-brand-blue dark:text-brand-mint font-bold">Ban Biên Tập Trợ Lý Số</span>
              </div>

              <h3 class="text-xl sm:text-2xl font-heading font-extrabold text-slate-900 dark:text-white group-hover:text-brand-blue dark:group-hover:text-brand-mint transition-colors leading-snug">
                <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.title}</a>
              </h3>

              <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 line-clamp-3 leading-relaxed">
                {featuredPost.description}
              </p>
            </div>
          </div>

          <div class="px-6 pb-6 pt-0">
            <a href={`/blog/${featuredPost.slug}/`} class="inline-flex items-center gap-2 text-sm font-extrabold text-brand-blue dark:text-brand-mint group-hover:gap-3 transition-all">
              Đọc toàn bộ cẩm nang <span>→</span>
            </a>
          </div>
        </article>

        <!-- Sub-Featured Stack Cards (5 cols) -->
        <div class="lg:col-span-5 flex flex-col gap-6">
          {subFeaturedPosts.map(post => (
            <article class="blog-article group bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200 dark:border-slate-800 p-4 sm:p-5 hover:border-brand-blue dark:hover:border-brand-mint hover:shadow-md transition-all duration-300 flex items-start gap-4" data-group={getCategorySlug(post.category)} data-search={`${post.title} ${post.description}`.toLowerCase()}>
              <div class="w-28 sm:w-36 aspect-[4/3] rounded-xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-900 relative">
                <img 
                  src={post.image} 
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 rounded-xl"
                  loading="lazy"
                />
              </div>

              <div class="flex-grow min-w-0 space-y-1.5">
                <div class="flex items-center gap-2 text-[11px] font-bold text-brand-blue dark:text-brand-mint">
                  <span>{post.category}</span>
                  <span class="text-slate-300 dark:text-slate-700">•</span>
                  <span class="text-slate-400 font-normal">{post.date}</span>
                </div>

                <h4 class="text-sm sm:text-base font-heading font-bold text-slate-900 dark:text-white group-hover:text-brand-blue dark:group-hover:text-brand-mint transition-colors line-clamp-2 leading-snug">
                  <a href={`/blog/${post.slug}/`}>{post.title}</a>
                </h4>

                <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-1">
                  {post.description}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- News Category Filter Tabs -->
    <div class="flex flex-wrap items-center gap-2 mb-8 pb-4 border-b border-slate-200/80 dark:border-slate-800/80 overflow-x-auto scrollbar-none">
      <button class="tab-btn px-4 py-2 text-xs sm:text-sm font-bold rounded-2xl border transition-all duration-200 shadow-sm bg-brand-blue border-brand-blue text-white" data-target="all">
        ✨ Tất cả bài viết ({posts.length})
      </button>
      <button class="tab-btn px-4 py-2 text-xs sm:text-sm font-bold rounded-2xl border transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard shadow-sm" data-target="thue-luong">
        💼 Thuế & Lương
      </button>
      <button class="tab-btn px-4 py-2 text-xs sm:text-sm font-bold rounded-2xl border transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard shadow-sm" data-target="bao-hiem">
        🛡️ Bảo hiểm xã hội
      </button>
      <button class="tab-btn px-4 py-2 text-xs sm:text-sm font-bold rounded-2xl border transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard shadow-sm" data-target="phap-ly">
        ⚖️ Pháp lý & Doanh nghiệp
      </button>
      <button class="tab-btn px-4 py-2 text-xs sm:text-sm font-bold rounded-2xl border transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard shadow-sm" data-target="giao-duc">
        🎓 Giáo dục & Hướng nghiệp
      </button>
      <button class="tab-btn px-4 py-2 text-xs sm:text-sm font-bold rounded-2xl border transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard shadow-sm" data-target="cong-nghe">
        🌐 Tiện ích & Công nghệ
      </button>
    </div>

    <!-- Magazine News Cards Grid -->
    <div id="blogGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {regularPosts.map(post => (
        <article 
          class="blog-article group bg-white dark:bg-brand-darkCard rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:border-brand-blue dark:hover:border-brand-mint hover:shadow-md transition-all duration-300 flex flex-col justify-between" 
          data-group={getCategorySlug(post.category)}
          data-search={`${post.title} ${post.description}`.toLowerCase()}
        >
          <div>
            <!-- Thumbnail Image Container -->
            <div class="relative aspect-[16/10] w-full overflow-hidden bg-slate-100 dark:bg-slate-900">
              <img 
                src={post.image} 
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 rounded-t-3xl"
                loading="lazy"
              />
              <span class="absolute top-3 left-3 px-2.5 py-1 bg-slate-900/80 backdrop-blur-md text-white text-[11px] font-bold rounded-lg">
                {post.category}
              </span>
            </div>

            <!-- Card Content Body -->
            <div class="p-5 sm:p-6 space-y-2.5">
              <div class="flex items-center gap-2 text-xs text-slate-400 font-medium">
                <span>📅 {post.date}</span>
                <span>•</span>
                <span>⏱️ {post.readTime}</span>
              </div>

              <h3 class="text-base sm:text-lg font-heading font-bold text-slate-900 dark:text-white group-hover:text-brand-blue dark:group-hover:text-brand-mint transition-colors line-clamp-2 leading-snug">
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </h3>

              <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 line-clamp-2 leading-relaxed">
                {post.description}
              </p>
            </div>
          </div>

          <!-- Card Footer Action -->
          <div class="px-5 sm:px-6 pb-5 pt-0 flex items-center justify-between border-t border-slate-100 dark:border-slate-800/50 pt-4 mt-2">
            <span class="text-xs font-semibold text-slate-400">
              {post.badge || "Cẩm nang"}
            </span>
            <a href={`/blog/${post.slug}/`} class="text-xs font-bold text-brand-blue dark:text-brand-mint group-hover:translate-x-1 transition-transform flex items-center gap-1">
              Đọc tiếp <span>→</span>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty State when no results found -->
    <div id="noResults" class="hidden text-center py-16 bg-white dark:bg-brand-darkCard rounded-3xl border border-slate-200 dark:border-slate-800 mt-6">
      <div class="text-4xl mb-3">🔍</div>
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">Không tìm thấy bài viết phù hợp</h3>
      <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400">Vui lòng thử tìm kiếm bằng từ khóa khác hoặc chuyển danh mục.</p>
    </div>

  </main>
</Layout>

<script>
  const tabBtns = document.querySelectorAll('.tab-btn');
  const articles = document.querySelectorAll('.blog-article');
  const searchInput = document.getElementById('blogSearchInput') as HTMLInputElement;
  const noResults = document.getElementById('noResults');

  let currentCategory = 'all';
  let searchQuery = '';

  function filterPosts() {
    let visibleCount = 0;

    articles.forEach(article => {
      const group = article.getAttribute('data-group');
      const searchData = article.getAttribute('data-search') || '';

      const matchCategory = (currentCategory === 'all' || group === currentCategory);
      const matchSearch = (searchQuery === '' || searchData.includes(searchQuery));

      if (matchCategory && matchSearch) {
        article.classList.remove('hidden');
        visibleCount++;
      } else {
        article.classList.add('hidden');
      }
    });

    if (noResults) {
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    }
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => {
        b.classList.remove('bg-brand-blue', 'border-brand-blue', 'text-white');
        b.classList.add('border-slate-200', 'dark:border-slate-800', 'text-slate-600', 'dark:text-slate-300', 'bg-white', 'dark:bg-brand-darkCard');
      });

      btn.classList.remove('border-slate-200', 'dark:border-slate-800', 'text-slate-600', 'dark:text-slate-300', 'bg-white', 'dark:bg-brand-darkCard');
      btn.classList.add('bg-brand-blue', 'border-brand-blue', 'text-white');

      currentCategory = btn.getAttribute('data-target') || 'all';
      filterPosts();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    searchQuery = target.value.trim().toLowerCase();
    filterPosts();
  });
</script>
