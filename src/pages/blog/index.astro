---

<Layout 
  title="Cẩm Nang Trợ Lý Số - Kiến Thức Tài Chính & Tiện Ích Số Dành Cho Người Việt"
  description="Chuyên mục chia sẻ kiến thức, hướng dẫn chi tiết các thủ tục thuế, bảo hiểm xã hội, kế toán văn phòng chính xác chuẩn E-E-A-T."
>
  <!-- Background Decor -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(37,99,235,0.03),transparent_50%)] pointer-events-none z-0"></div>

  <main class="max-w-6xl mx-auto px-4 py-12 w-full z-10 relative">
    
    <!-- Hero Section -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h1 class="text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-4">
        Cẩm Nang Trợ Lý Số
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Các bài viết hướng dẫn chuyên sâu về thuế, lương, thủ tục hành chính được cố vấn bởi các chuyên gia tài chính và kế toán uy tín.
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map(post => (
        <article class="bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden flex flex-col justify-between hover:shadow-lg transition">
          <div class="p-6">
            <!-- Category and Badge -->
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xs font-bold text-brand-blue dark:text-brand-mint bg-blue-50 dark:bg-blue-950 px-2.5 py-1 rounded-md">
                {post.category}
              </span>
              <span class="text-[11px] font-medium text-slate-400">
                • {post.date}
              </span>
            </div>
            
            <!-- Title -->
            <h2 class="text-xl font-heading font-bold text-slate-900 dark:text-white mb-3 hover:text-brand-blue dark:hover:text-brand-mint transition">
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
            </h2>
            
            <!-- Description -->
            <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-3">
              {post.description}
            </p>
          </div>
          
          <div class="p-6 pt-0 border-t border-slate-100 dark:border-slate-800/50 flex justify-between items-center text-xs">
            <span class="text-slate-400">Thời gian đọc: {post.readTime}</span>
            <a href={`/blog/${post.slug}/`} class="font-bold text-brand-blue dark:text-brand-mint flex items-center gap-1 hover:underline">
              Đọc tiếp <span>→</span>
            </a>
          </div>
        </article>
      ))}
    </div>

  </main>
</Layout>
