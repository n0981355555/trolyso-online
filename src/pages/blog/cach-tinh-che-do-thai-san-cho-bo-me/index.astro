      <div class="mt-12 border-t border-slate-200 dark:border-slate-800 pt-8 space-y-6">
        <div class="hover:border-brand-blue dark:hover:border-brand-mint hover:shadow-md transition duration-300 border border-slate-100 dark:border-slate-800 p-5 rounded-2xl">
