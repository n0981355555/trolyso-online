<Layout title={tag.title} description={tag.description}>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/blog/" class="hover:text-brand-blue dark:hover:text-brand-mint">Blog</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500 text-xs truncate max-w-[200px]">Thẻ: {tag.name}</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Header Section -->
    <div class="border-b border-slate-200 dark:border-slate-800 pb-6 mb-8">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs font-bold text-[#0063b6] dark:text-[#49a2dc] bg-blue-50 dark:bg-blue-950/40 px-2.5 py-1 rounded-md">
          Chủ đề bài viết
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white leading-tight">
        Từ khóa: {tag.name}
      </h1>
    </div>

    <!-- Introduction Text (200-500 words) -->
    <div class="prose prose-slate dark:prose-invert max-w-none text-slate-600 dark:text-slate-300 leading-relaxed mb-12 p-6 rounded-2xl bg-white dark:bg-brand-darkCard border border-slate-200 dark:border-slate-800 shadow-sm">
      <p class="mb-0 text-sm md:text-base">{tag.intro}</p>
    </div>

    <!-- Related Articles List -->
    <div>
      <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Danh sách bài viết liên quan</h2>
      
      {relatedPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {relatedPosts.map(post => (
            <article class="flex flex-col bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200 dark:border-slate-800 p-6 hover:shadow-lg transition duration-200">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-bold text-brand-blue dark:text-brand-mint bg-blue-50 dark:bg-blue-950 px-2.5 py-1 rounded-md">
                  {post.category}
                </span>
                <span class="text-xs text-slate-400">{post.date}</span>
              </div>
              <h3 class="text-md font-bold text-slate-900 dark:text-white mb-2 line-clamp-2 hover:text-brand-blue dark:hover:text-brand-mint">
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </h3>
              <p class="text-xs text-slate-500 dark:text-slate-400 mb-4 line-clamp-3">
                {post.description}
              </p>
              <div class="mt-auto flex items-center justify-between">
                <span class="text-xs text-slate-400">⏱️ {post.readTime} đọc</span>
                <a href={`/blog/${post.slug}/`} class="text-xs font-bold text-brand-blue dark:text-brand-mint hover:underline">
                  Đọc tiếp →
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="text-sm text-slate-500 italic">Chưa có bài viết nào thuộc chủ đề này.</p>
      )}
    </div>
  </main>
</Layout>
