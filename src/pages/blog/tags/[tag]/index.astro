---
import Layout from '../../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const tagData = [
    {
      slug: 'thue-thu-nhap-ca-nhan',
      name: 'Thuế thu nhập cá nhân',
      title: 'Cẩm Nang Thuế Thu Nhập Cá Nhân Mới Nhất - Trợ Lý Số',
      description: 'Tổng hợp các bài viết hướng dẫn, quy định pháp luật và công cụ tính thuế thu nhập cá nhân mới nhất dành cho người lao động.',
      intro: 'Thuế thu nhập cá nhân (TNCN) là một sắc thuế trực thu đánh trực tiếp vào thu nhập của mỗi cá nhân sau khi đã trừ đi các khoản chi phí hợp lý và giảm trừ gia cảnh. Đối với người lao động làm công ăn lương, thuế TNCN quyết định trực tiếp đến số tiền thực nhận (Net) mỗi tháng. Do đó, việc hiểu rõ các quy định pháp luật thuế là vô cùng quan trọng để tự bảo vệ quyền lợi tài chính chính đáng của mình. Chuyên mục Thuế Thu Nhập Cá Nhân tại Trợ Lý Số được xây dựng nhằm cung cấp một hệ thống tài liệu cẩm nang toàn diện, cập nhật liên tục các quy định mới nhất từ Bộ Tài chính và Tổng cục Thuế. Tại đây, bạn sẽ tìm thấy các bài viết phân tích chi tiết về biểu thuế lũy tiến từng phần gồm 7 bậc thuế suất, cách phân loại thu nhập chịu thuế và thu nhập được miễn thuế, cũng như các điều kiện để được áp dụng giảm thuế trong các trường hợp đặc biệt. Bên cạnh lý thuyết pháp lý, chúng tôi cung cấp các hướng dẫn từng bước trực quan giúp cá nhân tự thực hiện quyết toán thuế cuối năm hoặc nộp hồ sơ xin hoàn thuế TNCN online thông qua cổng thông tin thuế điện tử mà không cần qua trung gian. Hãy cùng khám phá các bài viết dưới đây để trang bị kiến thức và sử dụng công cụ tính toán tự động tối ưu nhất cho bản thân.'
    },
    {
      slug: 'luong-gross-net',
      name: 'Lương Gross Net',
      title: 'Cẩm Nang Lương Gross Net & Cách Quy Đổi - Trợ Lý Số',
      description: 'Tổng hợp các hướng dẫn phân biệt lương Gross và lương Net, công thức quy đổi tiền lương thực tế và cẩm nang đàm phán lương khi xin việc.',
      intro: 'Khi ký kết hợp đồng lao động, khái niệm lương Gross và lương Net luôn là điểm cốt lõi cần làm rõ giữa người lao động và người sử dụng lao động. Hiểu một cách đơn giản, lương Gross là tổng thu nhập bạn nhận được bao gồm cả tiền bảo hiểm và thuế TNCN, trong khi lương Net là số tiền thực tế đổ về tài khoản của bạn sau khi đã khấu trừ hết các khoản trên. Việc không phân biệt rõ hai loại lương này dễ dẫn đến những hiểu lầm về quyền lợi khi doanh nghiệp đóng bảo hiểm ở mức thấp hoặc trốn tránh nghĩa vụ đóng thuế. Chuyên mục Lương Gross Net tại Trợ Lý Số cung cấp các bài viết chuyên sâu hướng dẫn bạn cách chuyển đổi chính xác hai chiều từ Gross sang Net và ngược lại theo đúng quy định trích đóng bảo hiểm 10.5% mới nhất. Bạn sẽ nắm được cách thức doanh nghiệp xây dựng thang bảng lương, cách tính tiền lương làm thêm giờ dựa trên mức lương Gross, và những lưu ý đặc biệt khi đàm phán lương trong các buổi phỏng vấn tuyển dụng để đạt được mức thu nhập tối ưu và an toàn nhất.'
    },
    {
      slug: 'quyet-toan-thue',
      name: 'Quyết toán thuế',
      title: 'Hướng Dẫn Hồ Sơ Quyết Toán Thuế TNCN Online - Trợ Lý Số',
      description: 'Hướng dẫn chi tiết quy trình, thủ tục làm hồ sơ tự quyết toán thuế thu nhập cá nhân online và cách nhận tiền hoàn thuế nhanh chóng.',
      intro: 'Quyết toán thuế thu nhập cá nhân là công việc bắt buộc hàng năm đối với cá nhân cư trú có thu nhập từ nhiều nguồn hoặc có số thuế nộp thừa muốn xin hoàn trả. Tuy nhiên, quy trình chuẩn bị chứng từ khấu trừ thuế, điền tờ khai quyết toán 02/QTT-TNCN và lựa chọn cơ quan thuế quyết toán thường gây ra nhiều lúng túng cho người lao động tự do hoặc nhân viên đã nhảy việc trong năm. Chuyên mục Quyết toán thuế tại Trợ Lý Số sẽ đồng hành cùng bạn giải quyết mọi khó khăn pháp lý đó. Chúng tôi tổng hợp các bài viết hướng dẫn chi tiết cách thức đăng ký tài khoản thuế điện tử cá nhân, cách nhập dữ liệu tờ khai online trên hệ thống của Tổng cục Thuế, cách quét mã XML tờ khai và tải tài liệu minh chứng đi kèm. Ngoài ra, bạn cũng sẽ tìm hiểu được thời hạn nộp hồ sơ quyết toán để tránh bị xử phạt hành chính theo Nghị định 125, cũng như các mẹo kiểm tra trạng thái xử lý hồ sơ để sớm nhận được tiền hoàn thuế vào tài khoản ngân hàng.'
    },
