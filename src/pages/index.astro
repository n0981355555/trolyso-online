<script>
  function formatMoney(amount: number) {
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
  }

  const grossInput = document.getElementById('grossInput') as HTMLInputElement;
  const dependentsInput = document.getElementById('dependentsInput') as HTMLInputElement;
  const btnMinus = document.getElementById('btnMinus');
  const btnPlus = document.getElementById('btnPlus');
  const btnCalculate = document.getElementById('btnCalculate');

  const resGross = document.getElementById('resGross');
  const resInsurance = document.getElementById('resInsurance');
  const resDependentDeduction = document.getElementById('resDependentDeduction');
  const dependentDeductionRow = document.getElementById('dependentDeductionRow');
  const resTax = document.getElementById('resTax');
  const resNet = document.getElementById('resNet');

  function calculateSalary() {
    const gross = parseFloat(grossInput.value) || 0;
    const dependents = parseInt(dependentsInput.value) || 0;

    // Bảo hiểm bắt buộc (10.5%)
    const insurance = gross * 0.105;

    // Giảm trừ gia cảnh
    const selfDeduction = 11000000;
    const dependentDeduction = dependents * 4400000;
    const totalDeduction = selfDeduction + dependentDeduction;

    if (dependents > 0) {
      dependentDeductionRow?.classList.remove('hidden');
      if (resDependentDeduction) resDependentDeduction.innerText = "-" + formatMoney(dependentDeduction);
    } else {
      dependentDeductionRow?.classList.add('hidden');
    }

    // Thu nhập chịu thuế
    const taxableIncome = gross - insurance - totalDeduction;
    let tax = 0;

    // Thuế TNCN lũy tiến
    if (taxableIncome > 0) {
      if (taxableIncome <= 5000000) {
        tax = taxableIncome * 0.05;
      } else if (taxableIncome <= 10000000) {
        tax = taxableIncome * 0.1 - 250000;
      } else if (taxableIncome <= 18000000) {
        tax = taxableIncome * 0.15 - 750000;
      } else if (taxableIncome <= 32000000) {
        tax = taxableIncome * 0.2 - 1650000;
      } else if (taxableIncome <= 52000000) {
        tax = taxableIncome * 0.25 - 3250000;
      } else if (taxableIncome <= 80000000) {
        tax = taxableIncome * 0.3 - 5850000;
      } else {
        tax = taxableIncome * 0.35 - 9850000;
      }
    }

    const net = gross - insurance - tax;

    if (resGross) resGross.innerText = formatMoney(gross);
    if (resInsurance) resInsurance.innerText = "-" + formatMoney(insurance);
    if (resTax) resTax.innerText = "-" + formatMoney(tax);
    if (resNet) resNet.innerText = formatMoney(net);
  }

  // Bind Events
  btnMinus?.addEventListener('click', () => {
    let val = parseInt(dependentsInput.value) || 0;
    val = Math.max(0, val - 1);
    dependentsInput.value = val.toString();
    calculateSalary();
  });

  btnPlus?.addEventListener('click', () => {
    let val = parseInt(dependentsInput.value) || 0;
    dependentsInput.value = (val + 1).toString();
    calculateSalary();
  });

  btnCalculate?.addEventListener('click', calculateSalary);
  grossInput?.addEventListener('input', calculateSalary);

  // Initial Calculation
  calculateSalary();

  // Directory expander & Category filtering logic (TinyWow style)
  const btnToggleTools = document.getElementById('btnToggleTools');
  const btnToggleText = document.getElementById('btnToggleText');
  const btnToggleIcon = document.getElementById('btnToggleIcon');
  const allCards = document.querySelectorAll('#calculators-grid [data-category]');

  let isExpanded = false;
  let currentCategory = 'all';

  function updateVisibleTools() {
    if (currentCategory === 'all') {
      btnToggleTools?.classList.remove('hidden');
      
      allCards.forEach((card, idx) => {
        if (isExpanded) {
          card.classList.remove('hidden');
        } else {
          // Show only first 9 cards (indices 0 to 8)
          if (idx < 9) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        }
      });

      if (btnToggleText) btnToggleText.innerText = isExpanded ? "Thu gọn bớt" : "Xem thêm công cụ";
      if (btnToggleIcon) btnToggleIcon.innerText = isExpanded ? "↑" : "↓";
    } else {
      // Specific category: show all matching cards from the single grid, hide the toggle button
      btnToggleTools?.classList.add('hidden');
      
      allCards.forEach(card => {
        const cat = card.getAttribute('data-category');
        if (cat === currentCategory) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    }
  }

  btnToggleTools?.addEventListener('click', () => {
    isExpanded = !isExpanded;
    updateVisibleTools();
  });

  const tabBtns = document.querySelectorAll('.calc-tab-btn');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category') || 'all';
      currentCategory = cat;
      isExpanded = false; // Reset expand state when switching category
      updateVisibleTools();

      // Update tab active styling
      tabBtns.forEach(b => {
        if (b.getAttribute('data-category') === cat) {
          b.className = "calc-tab-btn px-3.5 py-1.5 text-xs font-bold rounded-xl transition-all duration-200 bg-white dark:bg-brand-darkCard text-slate-900 dark:text-white shadow-sm flex items-center gap-1.5 shrink-0";
        } else {
          b.className = "calc-tab-btn px-3.5 py-1.5 text-xs font-bold rounded-xl transition-all duration-200 text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 flex items-center gap-1.5 shrink-0";
        }
      });
    });
  });

  // Handle hash routing to expand tools list and scroll
  function checkHash() {
    if (window.location.hash === '#calculators') {
      isExpanded = true;
      currentCategory = 'all';
      updateVisibleTools();
      setTimeout(() => {
        const target = document.getElementById('calculators');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      }, 100);
    }
  }

  // Check on load and hash change
  window.addEventListener('load', () => {
    updateVisibleTools();
    checkHash();
  });
  window.addEventListener('hashchange', checkHash);

  // Smooth word rotator (Smart <-> Utility)
  const rotateWord = document.getElementById('rotateWord');
  if (rotateWord) {
    let isSmart = true;
    setInterval(() => {
      // 1. Fade out and scale down slightly
      rotateWord.classList.remove('scale-100', 'opacity-100');
      rotateWord.classList.add('scale-95', 'opacity-0');

      setTimeout(() => {
        if (isSmart) {
          // Switch to "Tiện Ích"
          rotateWord.textContent = 'Tiện Ích';
          rotateWord.className = 'block sm:inline-block transition-all duration-500 ease-out transform scale-95 opacity-0 text-red-500 dark:text-rose-500 pb-2 mt-1 sm:mt-0 select-none';
        } else {
          // Switch to "Thông Minh"
          rotateWord.textContent = 'Thông Minh';
          rotateWord.className = 'block sm:inline-block transition-all duration-500 ease-out transform scale-95 opacity-0 bg-gradient-to-r from-brand-blue to-blue-500 dark:from-brand-mint dark:to-emerald-400 bg-clip-text text-transparent pb-2 mt-1 sm:mt-0 select-none';
        }
        isSmart = !isSmart;

        // Force reflow
        rotateWord.offsetHeight;
        
        // 2. Fade in and scale back to normal
        rotateWord.classList.remove('scale-95', 'opacity-0');
        rotateWord.classList.add('scale-100', 'opacity-100');
      }, 400); // Swaps text halfway through transition
    }, 4000); // Transitions every 4 seconds
  }
</script>

<style>
  @keyframes floatSlow {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
  }
  @keyframes floatMedium {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(12px) rotate(-8deg); }
  }
  @keyframes floatFast {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(12deg); }
  }
  
  /* Apply animation only on desktop viewports to save mobile CPU/battery */
  @media (min-width: 640px) {
    .animate-float-slow {
      animation: floatSlow 8s infinite ease-in-out;
    }
    .animate-float-medium {
      animation: floatMedium 10s infinite ease-in-out;
    }
    .animate-float-fast {
      animation: floatFast 12s infinite ease-in-out;
    }
  }
</style>
