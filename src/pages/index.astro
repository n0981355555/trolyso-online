---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Trợ Lý Số - Công Cụ Số Online Miễn Phí Cho Người Việt"
  description="Trợ Lý Số cung cấp công cụ tính lương Gross sang Net, bảo hiểm xã hội, thuế thu nhập cá nhân chuẩn xác chuẩn Việt Nam."
>
  <!-- Schema cấu trúc định danh thương hiệu cho Google AI Overviews -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Trợ Lý Số",
      "alternateName": "trolyso.online",
      "url": "https://trolyso.online",
      "logo": "https://trolyso.online/logo.png",
      "description": "Trợ Lý Số là trang web cung cấp các công cụ tính toán tiện ích số online miễn phí hàng đầu tại Việt Nam như tính lương Gross sang Net, bảo hiểm xã hội, thuế thu nhập cá nhân.",
      "sameAs": [
        "https://github.com/trolyso-online",
        "https://facebook.com/trolyso.online"
      ]
    }
  </script>

  <!-- Background Decor -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(37,99,235,0.04),transparent_50%)] pointer-events-none z-0"></div>

  <!-- Floating 3D Shapes Background Decor (Premium SaaS Style) -->
  <div class="absolute inset-x-0 top-0 bottom-0 overflow-hidden pointer-events-none select-none z-0 hidden sm:block">
    <!-- LEFT SIDE SHAPES -->
    <!-- Shape 1: Pink Cube (Top Left) -->
    <div class="absolute left-[5%] top-[8%] opacity-75 animate-float-slow">
      <svg class="w-12 h-12" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="pinkTop1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#ff758f" /><stop offset="100%" stop-color="#ff8fa3" /></linearGradient>
          <linearGradient id="pinkLeft1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#c9184a" /><stop offset="100%" stop-color="#ff4d6d" /></linearGradient>
          <linearGradient id="pinkRight1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#a4133c" /><stop offset="100%" stop-color="#c9184a" /></linearGradient>
        </defs>
        <polygon points="50,15 85,35 50,55 15,35" fill="url(#pinkTop1)" />
        <polygon points="15,35 50,55 50,90 15,70" fill="url(#pinkLeft1)" />
        <polygon points="50,55 85,35 85,70 50,90" fill="url(#pinkRight1)" />
      </svg>
    </div>

    <!-- Shape 2: Orange Pyramid (Upper Left - Blurred) -->
    <div class="absolute left-[16%] top-[22%] opacity-55 blur-[1.5px] animate-float-medium">
      <svg class="w-10 h-10" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="orangeLeft1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#ffb703" /><stop offset="100%" stop-color="#fb8500" /></linearGradient>
          <linearGradient id="orangeRight1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fb8500" /><stop offset="100%" stop-color="#d66200" /></linearGradient>
        </defs>
        <polygon points="50,10 15,80 50,90" fill="url(#orangeLeft1)" />
        <polygon points="50,10 50,90 85,80" fill="url(#orangeRight1)" />
      </svg>
    </div>

    <!-- Shape 3: Purple Sphere (Mid-Upper Left) -->
    <div class="absolute left-[7%] top-[36%] opacity-85 animate-float-fast">
      <svg class="w-8 h-8" viewBox="0 0 100 100">
        <defs>
          <radialGradient id="purpleSphere1" cx="30%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#e0aaff" />
            <stop offset="50%" stop-color="#9d4edd" />
            <stop offset="100%" stop-color="#5a189a" />
          </radialGradient>
        </defs>
        <circle cx="50" cy="50" r="45" fill="url(#purpleSphere1)" />
      </svg>
    </div>

    <!-- Shape 4: Mint Cube (Middle Left) -->
    <div class="absolute left-[14%] top-[50%] opacity-80 animate-float-slow">
      <svg class="w-12 h-12" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="mintTop1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#adf7d1" /><stop offset="100%" stop-color="#96e6b2" /></linearGradient>
          <linearGradient id="mintLeft1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#2ec4b6" /><stop offset="100%" stop-color="#0f9f90" /></linearGradient>
          <linearGradient id="mintRight1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#0f9f90" /><stop offset="100%" stop-color="#086e64" /></linearGradient>
        </defs>
        <polygon points="50,15 85,35 50,55 15,35" fill="url(#mintTop1)" />
        <polygon points="15,35 50,55 50,90 15,70" fill="url(#mintLeft1)" />
        <polygon points="50,55 85,35 85,70 50,90" fill="url(#mintRight1)" />
      </svg>
    </div>

    <!-- Shape 5: Yellow Sphere (Mid-Lower Left - Blurred) -->
    <div class="absolute left-[5%] top-[65%] opacity-70 blur-[1px] animate-float-medium">
      <svg class="w-8 h-8" viewBox="0 0 100 100">
        <defs>
          <radialGradient id="yellowSphere1" cx="30%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#fff275" />
            <stop offset="50%" stop-color="#ffb703" />
            <stop offset="100%" stop-color="#d66200" />
          </radialGradient>
        </defs>
        <circle cx="50" cy="50" r="45" fill="url(#yellowSphere1)" />
      </svg>
    </div>

    <!-- Shape 6: Blue Pyramid (Lower Left) -->
    <div class="absolute left-[15%] top-[78%] opacity-65 animate-float-fast">
      <svg class="w-10 h-10" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="blueLeft1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#4ea8de" /><stop offset="100%" stop-color="#0077b6" /></linearGradient>
          <linearGradient id="blueRight1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0077b6" /><stop offset="100%" stop-color="#03045e" /></linearGradient>
        </defs>
        <polygon points="50,10 15,80 50,90" fill="url(#blueLeft1)" />
        <polygon points="50,10 50,90 85,80" fill="url(#blueRight1)" />
      </svg>
    </div>

    <!-- Shape 7: Pink Cube (Bottom Left) -->
    <div class="absolute left-[6%] top-[92%] opacity-75 animate-float-slow">
      <svg class="w-12 h-12" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="pinkTop2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#ff758f" /><stop offset="100%" stop-color="#ff8fa3" /></linearGradient>
          <linearGradient id="pinkLeft2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#c9184a" /><stop offset="100%" stop-color="#ff4d6d" /></linearGradient>
          <linearGradient id="pinkRight2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#a4133c" /><stop offset="100%" stop-color="#c9184a" /></linearGradient>
        </defs>
        <polygon points="50,15 85,35 50,55 15,35" fill="url(#pinkTop2)" />
        <polygon points="15,35 50,55 50,90 15,70" fill="url(#pinkLeft2)" />
        <polygon points="50,55 85,35 85,70 50,90" fill="url(#pinkRight2)" />
      </svg>
    </div>

    <!-- RIGHT SIDE SHAPES -->
    <!-- Shape 8: Mint Cube (Top Right) -->
    <div class="absolute right-[6%] top-[10%] opacity-80 animate-float-medium">
      <svg class="w-12 h-12" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="mintTop2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#adf7d1" /><stop offset="100%" stop-color="#96e6b2" /></linearGradient>
          <linearGradient id="mintLeft2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#2ec4b6" /><stop offset="100%" stop-color="#0f9f90" /></linearGradient>
          <linearGradient id="mintRight2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#0f9f90" /><stop offset="100%" stop-color="#086e64" /></linearGradient>
        </defs>
        <polygon points="50,15 85,35 50,55 15,35" fill="url(#mintTop2)" />
        <polygon points="15,35 50,55 50,90 15,70" fill="url(#mintLeft2)" />
        <polygon points="50,55 85,35 85,70 50,90" fill="url(#mintRight2)" />
      </svg>
    </div>

    <!-- Shape 9: Yellow Sphere (Upper Right) -->
    <div class="absolute right-[17%] top-[24%] opacity-75 animate-float-slow">
      <svg class="w-8 h-8" viewBox="0 0 100 100">
        <defs>
          <radialGradient id="yellowSphere2" cx="30%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#fff275" />
            <stop offset="50%" stop-color="#ffb703" />
            <stop offset="100%" stop-color="#d66200" />
          </radialGradient>
        </defs>
        <circle cx="50" cy="50" r="45" fill="url(#yellowSphere2)" />
      </svg>
    </div>

    <!-- Shape 10: Blue Pyramid (Mid-Upper Right - Blurred) -->
    <div class="absolute right-[8%] top-[38%] opacity-50 blur-[1.5px] animate-float-fast">
      <svg class="w-10 h-10" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="blueLeft2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#4ea8de" /><stop offset="100%" stop-color="#0077b6" /></linearGradient>
          <linearGradient id="blueRight2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0077b6" /><stop offset="100%" stop-color="#03045e" /></linearGradient>
        </defs>
        <polygon points="50,10 15,80 50,90" fill="url(#blueLeft2)" />
        <polygon points="50,10 50,90 85,80" fill="url(#blueRight2)" />
      </svg>
    </div>

    <!-- Shape 11: Pink Cube (Middle Right) -->
    <div class="absolute right-[15%] top-[52%] opacity-85 animate-float-medium">
      <svg class="w-12 h-12" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="pinkTop3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#ff758f" /><stop offset="100%" stop-color="#ff8fa3" /></linearGradient>
          <linearGradient id="pinkLeft3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#c9184a" /><stop offset="100%" stop-color="#ff4d6d" /></linearGradient>
          <linearGradient id="pinkRight3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#a4133c" /><stop offset="100%" stop-color="#c9184a" /></linearGradient>
        </defs>
        <polygon points="50,15 85,35 50,55 15,35" fill="url(#pinkTop3)" />
        <polygon points="15,35 50,55 50,90 15,70" fill="url(#pinkLeft3)" />
        <polygon points="50,55 85,35 85,70 50,90" fill="url(#pinkRight3)" />
      </svg>
    </div>

    <!-- Shape 12: Orange Pyramid (Mid-Lower Right) -->
    <div class="absolute right-[6%] top-[66%] opacity-65 animate-float-slow">
      <svg class="w-10 h-10" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="orangeLeft2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#ffb703" /><stop offset="100%" stop-color="#fb8500" /></linearGradient>
          <linearGradient id="orangeRight2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fb8500" /><stop offset="100%" stop-color="#d66200" /></linearGradient>
        </defs>
        <polygon points="50,10 15,80 50,90" fill="url(#orangeLeft2)" />
        <polygon points="50,10 50,90 85,80" fill="url(#orangeRight2)" />
      </svg>
    </div>

    <!-- Shape 13: Purple Sphere (Lower Right - Blurred) -->
    <div class="absolute right-[16%] top-[80%] opacity-75 blur-[1px] animate-float-fast">
      <svg class="w-8 h-8" viewBox="0 0 100 100">
        <defs>
          <radialGradient id="purpleSphere2" cx="30%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#e0aaff" />
            <stop offset="50%" stop-color="#9d4edd" />
            <stop offset="100%" stop-color="#5a189a" />
          </radialGradient>
        </defs>
        <circle cx="50" cy="50" r="45" fill="url(#purpleSphere2)" />
      </svg>
    </div>

    <!-- Shape 14: Mint Cube (Bottom Right) -->
    <div class="absolute right-[7%] top-[94%] opacity-80 animate-float-medium">
      <svg class="w-12 h-12" viewBox="0 0 100 100" fill="none">
        <defs>
          <linearGradient id="mintTop3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#adf7d1" /><stop offset="100%" stop-color="#96e6b2" /></linearGradient>
          <linearGradient id="mintLeft3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#2ec4b6" /><stop offset="100%" stop-color="#0f9f90" /></linearGradient>
          <linearGradient id="mintRight3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#0f9f90" /><stop offset="100%" stop-color="#086e64" /></linearGradient>
        </defs>
        <polygon points="50,15 85,35 50,55 15,35" fill="url(#mintTop3)" />
        <polygon points="15,35 50,55 50,90 15,70" fill="url(#mintLeft3)" />
        <polygon points="50,55 85,35 85,70 50,90" fill="url(#mintRight3)" />
      </svg>
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 py-12 w-full z-10 relative">
    
    <!-- Hero Section -->
    <div class="text-center max-w-4xl mx-auto mb-16 relative">
      <!-- Hero Search Bar (Premium SaaS Style) -->
      <div class="max-w-md mx-auto mb-8 relative">
        <input type="text" id="heroSearchInput" placeholder="Tìm kiếm công cụ, cẩm nang..." aria-label="Tìm kiếm nhanh công cụ và cẩm nang" class="w-full pl-12 pr-4 py-3.5 rounded-2xl border border-slate-200/60 dark:border-slate-800/50 bg-white/70 dark:bg-slate-900/60 backdrop-blur-md focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint font-bold text-sm transition-all shadow-sm hover:shadow-md" />
        <svg class="w-5 h-5 text-brand-blue dark:text-brand-mint absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <div id="heroSearchDropdown" class="absolute left-0 right-0 top-full mt-2 w-full bg-white dark:bg-brand-darkCard border border-slate-200 dark:border-slate-800 rounded-2xl shadow-xl z-50 p-2 hidden max-h-80 overflow-y-auto">
          <!-- Results -->
        </div>
      </div>
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-heading font-extrabold text-slate-900 dark:text-white tracking-tight mb-6 leading-tight select-none text-center">
        <span class="block sm:inline sm:whitespace-nowrap">
          <span class="block sm:inline">Hộp Công Cụ Số </span>
          <span id="rotateWord" class="block sm:inline-block transition-all duration-500 ease-out transform scale-100 opacity-100 bg-gradient-to-r from-brand-blue to-blue-500 dark:from-brand-mint dark:to-emerald-400 bg-clip-text text-transparent pb-2 mt-1 sm:mt-0 select-none">Thông Minh</span>
        </span>
        <span class="block mt-1 sm:mt-2">Cho Người Việt</span>
      </h1>
      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Các tiện ích tính toán tài chính, thuế, BHXH trực quan, bảo mật tuyệt đối 100% dữ liệu ngay trên trình duyệt của bạn.
      </p>
    </div>

    <!-- 2 Column Tool Section (Gross to Net) -->
    <div class="bg-white dark:bg-brand-darkCard rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 overflow-hidden grid grid-cols-1 md:grid-cols-12 mb-16 transition-colors">
        
      <!-- Left Side: Inputs (7 cols) -->
      <div class="p-6 sm:p-10 md:col-span-7">
        <h2 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-8 flex items-center gap-3">
          <span class="p-2 rounded-xl bg-blue-50 dark:bg-blue-950 text-brand-blue font-bold text-base">VND</span>
          Tính Lương Gross Sang Net (Chuẩn 2026)
        </h2>
        
        <div class="space-y-6">
          <!-- Input Lương Gross -->
          <div>
            <label for="grossInput" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Mức lương Gross (VND/Tháng)</label>
            <div class="relative">
              <input type="number" id="grossInput" value="20000000" step="500000" class="w-full px-4 py-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint font-bold text-xl transition-all" />
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">đ</span>
            </div>
          </div>

          <!-- Input Người phụ thuộc -->
          <div>
            <label for="dependentsInput" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Số người phụ thuộc (Giảm trừ gia cảnh)</label>
            <div class="flex items-center gap-3">
              <button id="btnMinus" aria-label="Giảm số người phụ thuộc" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">-</button>
              <input type="number" id="dependentsInput" value="0" min="0" class="w-20 text-center py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint font-bold text-lg" />
              <button id="btnPlus" aria-label="Tăng số người phụ thuộc" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">+</button>
            </div>
          </div>

          <button id="btnCalculate" class="w-full bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold py-4 px-6 rounded-xl transition duration-200 shadow-lg shadow-blue-500/10 dark:shadow-emerald-500/10 flex items-center justify-center gap-2">
            ⚡ Tính Toán Ngay
          </button>
        </div>
      </div>

      <!-- Right Side: Outputs (5 cols) -->
      <div class="p-6 sm:p-10 bg-slate-50/50 dark:bg-slate-900/50 md:col-span-5 flex flex-col justify-between border-t md:border-t-0 md:border-l border-slate-200 dark:border-slate-800">
        <div>
          <h3 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-6">Bảng Phân Tích Lương Net</h3>
          
          <div class="space-y-4 text-sm">
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500 dark:text-slate-400">Lương Gross:</span>
              <span class="font-bold text-slate-900 dark:text-white" id="resGross">0đ</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500 dark:text-slate-400">Bảo hiểm bắt buộc (10.5%):</span>
              <span class="font-semibold text-red-500" id="resInsurance">0đ</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500 dark:text-slate-400">Giảm trừ bản thân:</span>
              <span class="font-semibold text-slate-700 dark:text-slate-300">-11,000,000đ</span>
            </div>
            <div id="dependentDeductionRow" class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800 hidden">
              <span class="text-slate-500 dark:text-slate-400">Giảm trừ phụ thuộc:</span>
              <span class="font-semibold text-slate-700 dark:text-slate-300" id="resDependentDeduction">0đ</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500 dark:text-slate-400">Thuế thu nhập cá nhân:</span>
              <span class="font-semibold text-red-500" id="resTax">0đ</span>
            </div>
            <div class="flex justify-between items-center pt-6 pb-2">
              <span class="text-base font-bold text-slate-800 dark:text-slate-200">LƯƠNG THỰC NHẬN:</span>
              <span class="text-3xl font-extrabold text-emerald-600 dark:text-brand-mint" id="resNet">0đ</span>
            </div>
          </div>
        </div>

        <div class="text-xs text-slate-400 mt-8 pt-4 border-t border-slate-200 dark:border-slate-800">
          * Công thức áp dụng mức bảo hiểm 10.5% (BHXH 8%, BHYT 1.5%, BHTN 1%) và biểu thuế lũy tiến từng phần của Tổng cục Thuế Việt Nam.
        </div>
      </div>
    </div>

    <!-- Quick Access Directory -->
    <div id="calculators">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-8">
        <h3 class="text-xl font-heading font-bold text-slate-900 dark:text-white m-0">Các công cụ tiện ích khác:</h3>
        <!-- Category Filter Tabs (Responsive: Scrollable on mobile, flex on desktop) -->
        <div class="flex overflow-x-auto lg:flex-wrap gap-1.5 bg-slate-100/80 dark:bg-slate-800/80 backdrop-blur-sm p-1.5 rounded-2xl border border-slate-200/40 dark:border-slate-800/40 max-w-full scrollbar-none shadow-sm select-none">
          <button class="calc-tab-btn px-3.5 py-1.5 text-xs font-bold rounded-xl transition-all duration-200 bg-white dark:bg-brand-darkCard text-slate-900 dark:text-white shadow-sm flex items-center gap-1.5 shrink-0" data-category="all" aria-label="Tất cả công cụ">
