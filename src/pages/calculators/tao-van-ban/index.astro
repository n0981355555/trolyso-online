---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Trình Tạo Văn Bản Hành Chính Theo Chuẩn Nghị Định 30 - Trợ Lý Số"
  description="Công cụ soạn thảo và tạo văn bản hành chính, văn bản quy phạm pháp luật trực tuyến chuẩn Nghị định 30/2020/NĐ-CP của Chính phủ."
>
  <!-- Background Decor -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(37,99,235,0.04),transparent_50%)] pointer-events-none z-0"></div>

  <main class="max-w-7xl mx-auto px-4 py-12 w-full z-10 relative">
    
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="hover:text-brand-blue dark:hover:text-brand-mint">Calculators</span>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Tạo văn bản hành chính</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-4">
        Trình Tạo Văn Bản Chuẩn Nghị Định 30/2020/NĐ-CP
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Soạn thảo 15 loại văn bản quy phạm pháp luật và 29 loại văn bản hành chính đúng chuẩn kích thước, căn lề, quốc hiệu và tiêu ngữ của Chính phủ.
      </p>
    </div>

    <!-- Tool Container -->
    <div class="bg-white dark:bg-brand-darkCard rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 overflow-hidden grid grid-cols-1 lg:grid-cols-12 mb-12 transition-colors">
        
      <!-- Left Inputs Form (5 cols) -->
      <div class="p-6 sm:p-8 lg:col-span-5 border-b lg:border-b-0 lg:border-r border-slate-200 dark:border-slate-800 space-y-5 max-h-[85vh] overflow-y-auto">
        <h2 class="text-lg font-heading font-bold text-slate-900 dark:text-white flex items-center gap-3">
          📝 Nhập thông tin văn bản
        </h2>

        <!-- Nhóm văn bản -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="docGroup" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Nhóm văn bản</label>
            <select id="docGroup" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-xs font-semibold">
              <option value="hanhchinh" selected>Văn bản hành chính</option>
              <option value="quypfam">Quy phạm pháp luật</option>
            </select>
          </div>
          <div>
            <label for="docType" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Loại văn bản</label>
            <select id="docType" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-xs font-semibold">
              <!-- Sẽ được fill bằng JS -->
            </select>
          </div>
        </div>

        <!-- Cơ quan ban hành & Địa danh -->
        <div class="space-y-4">
          <div>
            <label for="issuingAuthority" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Cơ quan ban hành (Dòng trên)</label>
            <input type="text" id="issuingAuthority" value="ỦY BAN NHÂN DÂN TỈNH LÂM ĐỒNG" class="w-full px-4 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-xs font-semibold" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="issuingSubAuthority" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Số hiệu văn bản (Dòng dưới)</label>
              <input type="text" id="issuingSubAuthority" value="Số: 124/QĐ-UBND" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-xs" />
            </div>
            <div>
              <label for="locationDate" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Địa danh & Ngày tháng</label>
              <input type="text" id="locationDate" value="Lâm Đồng, ngày 03 tháng 07 năm 2026" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-xs" />
            </div>
          </div>
        </div>

        <!-- Tiêu đề & Trích yếu -->
        <div class="space-y-4">
          <div>
            <label for="docTitle" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Tiêu đề chính văn bản</label>
            <input type="text" id="docTitle" value="QUYẾT ĐỊNH" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-sm font-bold" />
          </div>
          <div>
            <label for="docSummary" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Trích yếu nội dung (Dưới tiêu đề)</label>
            <input type="text" id="docSummary" value="Về việc ban hành quy chế làm việc của cơ quan" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-xs" />
          </div>
        </div>

        <!-- Nội dung chính -->
        <div>
          <label for="docBody" class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Nội dung chính văn bản</label>
          <textarea id="docBody" rows="5" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-xs font-mono">Điều 1. Ban hành kèm theo Quyết định này Quy chế hoạt động văn phòng mới nhất.
Điều 2. Quyết định này có hiệu lực kể từ ngày ký ban hành.
Điều 3. Chánh văn phòng Ủy ban nhân dân và các tổ chức liên quan chịu trách nhiệm thi hành quyết định này.</textarea>
        </div>

        <!-- Nơi nhận -->
        <div class="p-3 bg-slate-50 dark:bg-slate-900/40 rounded-xl border border-slate-200 dark:border-slate-800 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-bold text-slate-700 dark:text-slate-300">Nơi nhận văn bản</span>
            <label class="flex items-center gap-1.5 text-xs text-slate-500 dark:text-slate-400 cursor-pointer select-none">
              <input type="checkbox" id="showRecipient" checked class="rounded border-slate-300 text-brand-blue focus:ring-brand-blue w-4 h-4" />
              Hiển thị
            </label>
          </div>
          <div id="recipientInputWrapper">
            <textarea id="recipientText" rows="2" class="w-full px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs font-medium" placeholder="Nhập nơi nhận (mỗi dòng một nơi nhận)">- Như Điều 3;
- Lưu: VT, HC.</textarea>
          </div>
        </div>

        <!-- Cấu hình Người ký (Tối đa 5 người) -->
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <label for="signerCount" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Người ký văn bản</label>
            <select id="signerCount" class="px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-xs font-bold">
              <option value="1" selected>1 người ký</option>
              <option value="2">2 người ký</option>
              <option value="3">3 người ký</option>
              <option value="4">4 người ký</option>
              <option value="5">5 người ký</option>
            </select>
          </div>

          <div id="signersInputsContainer" class="space-y-3">
            <!-- Người ký 1 -->
            <div class="grid grid-cols-2 gap-3 p-3 bg-blue-50/30 dark:bg-blue-950/10 rounded-xl border border-blue-100/50 dark:border-blue-950/20">
              <div class="col-span-2 text-[10px] font-bold text-brand-blue dark:text-brand-mint">NGƯỜI KÝ 1 (BÊN PHẢI)</div>
              <div>
                <input type="text" id="signerRole1" value="CHỦ TỊCH" placeholder="Chức vụ (Ví dụ: GIÁM ĐỐC)" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs font-semibold" />
              </div>
              <div>
                <input type="text" id="signerName1" value="Nguyễn Quốc Dũng" placeholder="Họ và tên người ký" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs font-semibold" />
              </div>
            </div>

            <!-- Người ký 2 -->
            <div id="signerWrapper2" class="grid grid-cols-2 gap-3 p-3 bg-slate-50 dark:bg-slate-900/50 rounded-xl border border-slate-200/50 dark:border-slate-800/50 hidden">
              <div class="col-span-2 text-[10px] font-bold text-slate-400">NGƯỜI KÝ 2 (BÊN TRÁI)</div>
              <div>
                <input type="text" id="signerRole2" value="GIÁM ĐỐC" placeholder="Chức vụ" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
              <div>
                <input type="text" id="signerName2" value="Trần Văn B" placeholder="Họ và tên" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
            </div>

            <!-- Người ký 3 -->
            <div id="signerWrapper3" class="grid grid-cols-2 gap-3 p-3 bg-slate-50 dark:bg-slate-900/50 rounded-xl border border-slate-200/50 dark:border-slate-800/50 hidden">
              <div class="col-span-2 text-[10px] font-bold text-slate-400">NGƯỜI KÝ 3</div>
              <div>
                <input type="text" id="signerRole3" value="KẾ TOÁN TRƯỞNG" placeholder="Chức vụ" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
              <div>
                <input type="text" id="signerName3" value="Phạm Thị C" placeholder="Họ và tên" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
            </div>

            <!-- Người ký 4 -->
            <div id="signerWrapper4" class="grid grid-cols-2 gap-3 p-3 bg-slate-50 dark:bg-slate-900/50 rounded-xl border border-slate-200/50 dark:border-slate-800/50 hidden">
              <div class="col-span-2 text-[10px] font-bold text-slate-400">NGƯỜI KÝ 4</div>
              <div>
                <input type="text" id="signerRole4" value="TRƯỞNG PHÒNG HC" placeholder="Chức vụ" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
              <div>
                <input type="text" id="signerName4" value="Lê Văn D" placeholder="Họ và tên" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
            </div>

            <!-- Người ký 5 -->
            <div id="signerWrapper5" class="grid grid-cols-2 gap-3 p-3 bg-slate-50 dark:bg-slate-900/50 rounded-xl border border-slate-200/50 dark:border-slate-800/50 hidden">
              <div class="col-span-2 text-[10px] font-bold text-slate-400">NGƯỜI KÝ 5</div>
              <div>
                <input type="text" id="signerRole5" value="ỦY VIÊN" placeholder="Chức vụ" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
              <div>
                <input type="text" id="signerName5" value="Hoàng Văn E" placeholder="Họ và tên" class="w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-xs" />
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Right Live Preview (7 cols) -->
      <div class="p-6 sm:p-8 lg:col-span-7 bg-slate-100 dark:bg-slate-900/50 flex flex-col justify-between">
        <div>
          <h3 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-4">👁️ Bản xem trước văn bản chuẩn Nghị định 30</h3>
          
          <!-- Outer Paper Box -->
          <div class="border border-slate-300 dark:border-slate-800 rounded-xl bg-white p-8 min-h-[500px] shadow-lg overflow-x-auto">
            
            <!-- Real HTML Document Target for Copy -->
            <div id="paperDocument" class="bg-white text-black font-serif text-[13px] leading-relaxed w-full max-w-[650px] mx-auto select-text" style="font-family: 'Times New Roman', Times, serif;">
              <!-- Sẽ được vẽ bằng script -->
            </div>

          </div>
        </div>

        <div class="mt-8 space-y-3">
          <!-- Button sao chép -->
          <button id="btnCopyDoc" class="w-full bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold py-3.5 px-6 rounded-xl transition duration-200 shadow-md flex items-center justify-center gap-2">
            📋 Sao Chép Văn Bản (Rich HTML để dán vào Word)
          </button>
          
          <!-- Button tải file -->
          <button id="btnDownloadDoc" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3.5 px-6 rounded-xl transition duration-200 shadow-md flex items-center justify-center gap-2">
            📥 Tải Văn Bản (.doc mở bằng Word)
          </button>
          
          <div class="text-[11px] text-slate-400 leading-normal text-center mt-2">
            * Sau khi bấm **Sao chép** hoặc **Tải file**, bạn mở file Microsoft Word ra để chỉnh sửa nâng cao. Định dạng bảng Quốc hiệu và chữ ký sẽ được bảo toàn.
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>

<script>
  const docGroup = document.getElementById('docGroup') as HTMLSelectElement;
  const docType = document.getElementById('docType') as HTMLSelectElement;
  const issuingAuthority = document.getElementById('issuingAuthority') as HTMLInputElement;
  const issuingSubAuthority = document.getElementById('issuingSubAuthority') as HTMLInputElement;
  const locationDate = document.getElementById('locationDate') as HTMLInputElement;
  const docTitle = document.getElementById('docTitle') as HTMLInputElement;
  const docSummary = document.getElementById('docSummary') as HTMLInputElement;
  const docBody = document.getElementById('docBody') as HTMLTextAreaElement;
  const paperDocument = document.getElementById('paperDocument');
  const btnCopyDoc = document.getElementById('btnCopyDoc');
  const btnDownloadDoc = document.getElementById('btnDownloadDoc');

  // Nơi nhận
  const showRecipient = document.getElementById('showRecipient') as HTMLInputElement;
  const recipientText = document.getElementById('recipientText') as HTMLTextAreaElement;
  const recipientInputWrapper = document.getElementById('recipientInputWrapper');

  // Người ký
  const signerCountSelect = document.getElementById('signerCount') as HTMLSelectElement;
  const signerInputs = [
    { role: document.getElementById('signerRole1') as HTMLInputElement, name: document.getElementById('signerName1') as HTMLInputElement, wrapper: null },
    { role: document.getElementById('signerRole2') as HTMLInputElement, name: document.getElementById('signerName2') as HTMLInputElement, wrapper: document.getElementById('signerWrapper2') },
    { role: document.getElementById('signerRole3') as HTMLInputElement, name: document.getElementById('signerName3') as HTMLInputElement, wrapper: document.getElementById('signerWrapper3') },
    { role: document.getElementById('signerRole4') as HTMLInputElement, name: document.getElementById('signerName4') as HTMLInputElement, wrapper: document.getElementById('signerWrapper4') },
    { role: document.getElementById('signerRole5') as HTMLInputElement, name: document.getElementById('signerName5') as HTMLInputElement, wrapper: document.getElementById('signerWrapper5') }
  ];

  // 15 loại VB quy phạm pháp luật và 29 loại VB hành chính
  const docTypes = {
    hanhchinh: [
      { value: "QuyetDinh", name: "Quyết định (cá biệt)" },
      { value: "NghiQuyet", name: "Nghị quyết (cá biệt)" },
      { value: "ChiThi", name: "Chỉ thị" },
      { value: "QuyChe", name: "Quy chế" },
      { value: "QuyDinh", name: "Quy định" },
      { value: "ThongBao", name: "Thông báo" },
      { value: "HuongDan", name: "Hướng dẫn" },
      { value: "ChuongTrinh", name: "Chương trình" },
      { value: "KeHoach", name: "Kế hoạch" },
      { value: "PhuongAn", name: "Phương án" },
      { value: "DeAn", name: "Đề án" },
      { value: "DuAn", name: "Dự án" },
      { value: "BaoCao", name: "Báo cáo" },
      { value: "BienBan", name: "Biên bản" },
      { value: "ToTrinh", name: "Tờ trình" },
      { value: "HopDong", name: "Hợp đồng" },
      { value: "CongVan", name: "Công văn" },
      { value: "CongDien", name: "Công điện" },
      { value: "BanGhiNho", name: "Bản ghi nhớ" },
      { value: "BanThoaThuan", name: "Bản thỏa thuận" },
      { value: "GiayUyQuyen", name: "Giấy ủy quyền" },
      { value: "GiayMoi", name: "Giấy mời" },
      { value: "GiayGioiThieu", name: "Giấy giới thiệu" },
      { value: "GiayNghiPhep", name: "Giấy nghỉ phép" },
      { value: "GiayDiDuong", name: "Giấy đi đường" },
      { value: "BienNhan", name: "Biên nhận" },
      { value: "PhieuGui", name: "Phiếu gửi" },
      { value: "PhieuChuyen", name: "Phiếu chuyển" },
      { value: "ThuCong", name: "Thư công" }
    ],
    quypfam: [
      { value: "Luat", name: "Luật" },
      { value: "NghiQuyetQP", name: "Nghị quyết" },
      { value: "PhapLenh", name: "Pháp lệnh" },
      { value: "Lenh", name: "Lệnh" },
      { value: "QuyetDinhQP", name: "Quyết định" },
      { value: "ChiThiQP", name: "Chỉ thị" },
      { value: "ThongTu", name: "Thông tư" },
      { value: "NghiDinh", name: "Nghị định" },
      { value: "NghiQuyetLienTich", name: "Nghị quyết liên tịch" },
      { value: "ThongTuLienTich", name: "Thông tư liên tịch" },
      { value: "QuyCheQP", name: "Quy chế" },
      { value: "QuyDinhQP", name: "Quy định" },
      { value: "HienPhap", name: "Hiến pháp" },
      { value: "BoLuat", name: "Bộ luật" },
      { value: "LuatSuaDoi", name: "Luật sửa đổi, bổ sung" }
    ]
  };

  // Cập nhật danh sách loại văn bản khi đổi nhóm
  function updateDocTypes() {
    const group = docGroup.value as 'hanhchinh' | 'quypfam';
    const list = docTypes[group];
    
    if (docType) {
      docType.innerHTML = list.map(item => `<option value="${item.value}">${item.name}</option>`).join('');
    }
  }

  // Ẩn hiện các ô nhập người ký tùy thuộc vào số lượng được chọn
  function toggleSignerFields() {
    const count = parseInt(signerCountSelect.value);
    for (let i = 1; i < signerInputs.length; i++) {
      const item = signerInputs[i];
      if (item.wrapper) {
        if (i < count) {
          item.wrapper.classList.remove('hidden');
        } else {
          item.wrapper.classList.add('hidden');
        }
      }
    }
    renderDocument();
  }

  // Ẩn hiện ô nhập nơi nhận
  showRecipient?.addEventListener('change', () => {
    if (showRecipient.checked) {
      recipientInputWrapper?.classList.remove('hidden');
    } else {
      recipientInputWrapper?.classList.add('hidden');
    }
    renderDocument();
  });

  recipientText?.addEventListener('input', renderDocument);
  signerCountSelect?.addEventListener('change', toggleSignerFields);

  // Khi thay đổi loại văn bản, tự cập nhật một số thông tin mẫu
  docType?.addEventListener('change', () => {
    const selectedText = docType.options[docType.selectedIndex].text;
    if (docTitle) {
      docTitle.value = selectedText.toUpperCase();
    }
    renderDocument();
  });

  docGroup?.addEventListener('change', () => {
    updateDocTypes();
    const selectedText = docType.options[docType.selectedIndex].text;
    if (docTitle) {
      docTitle.value = selectedText.toUpperCase();
    }
    renderDocument();
  });

  // Tạo cấu trúc bảng cho người ký (hỗ trợ tối đa 5 người ký)
  function generateSignaturesMarkup() {
    const count = parseInt(signerCountSelect.value);
    const signers = [];
    for (let i = 0; i < count; i++) {
      signers.push({
        role: signerInputs[i].role.value || `CHỨC DANH ${i + 1}`,
        name: signerInputs[i].name.value || `Họ tên người ký ${i + 1}`
      });
    }

    // Phục vụ Nơi nhận
    let recipientHtml = '';
    if (showRecipient.checked) {
      const listLines = (recipientText.value || '').split('\n');
      recipientHtml = `
        <div style="font-weight: bold; font-style: italic; font-size: 12px; margin-bottom: 5px; text-align: left;">Nơi nhận:</div>
        <div style="text-align: left;">
          ${listLines.map(line => `<div style="font-size: 11px; line-height: 1.4; text-align: left;">${line}</div>`).join('')}
        </div>
      `;
    }

    let markup = '';

    if (count === 1) {
      // 1 người ký: Nơi nhận bên trái, Người ký 1 bên phải
      markup = `
        <table cellpadding="0" cellspacing="0" border="0" style="width: 100%; border-collapse: collapse; font-family: 'Times New Roman', Times, serif; font-size: 13px;">
          <tr>
            <td style="width: 45%; vertical-align: top; text-align: left;">
              ${recipientHtml}
            </td>
            <td style="width: 55%; text-align: center; vertical-align: top;">
              <div style="font-weight: bold; text-transform: uppercase;">${signers[0].role}</div>
              <div style="font-style: italic; font-size: 12px; margin-top: 3px; color: #888888; height: 65px; display: flex; align-items: center; justify-content: center;">(Chữ ký, dấu)</div>
              <div style="font-weight: bold; margin-top: 10px; font-size: 14px;">${signers[0].name}</div>
            </td>
          </tr>
        </table>
      `;
    } else {
      // Từ 2 đến 5 người ký
      // Chúng ta sẽ vẽ Nơi nhận ở trên cùng bên trái, sau đó là bảng các chữ ký chia 2 cột song song
      let sigsRows = '';
      
      // Ghép cặp các người ký thành các hàng
      // Hàng 1: Người ký 2 (Trái) - Người ký 1 (Phải)
      // Hàng 2: Người ký 4 (Trái) - Người ký 3 (Phải)
      // Hàng 3: Empty (Trái) - Người ký 5 (Phải)
      const rowsData = [];
      rowsData.push({ left: signers[1], right: signers[0] });
      
      if (count >= 3) {
        rowsData.push({ left: signers[3] || null, right: signers[2] });
      }
      if (count === 5) {
        rowsData.push({ left: null, right: signers[4] });
      }

      sigsRows = rowsData.map(row => `
        <tr>
          <td style="width: 50%; text-align: center; vertical-align: top; padding-bottom: 25px;">
            ${row.left ? `
              <div style="font-weight: bold; text-transform: uppercase;">${row.left.role}</div>
              <div style="font-style: italic; font-size: 12px; margin-top: 3px; color: #888888; height: 60px; display: flex; align-items: center; justify-content: center;">(Chữ ký)</div>
              <div style="font-weight: bold; margin-top: 10px; font-size: 14px;">${row.left.name}</div>
            ` : ''}
          </td>
          <td style="width: 50%; text-align: center; vertical-align: top; padding-bottom: 25px;">
            ${row.right ? `
              <div style="font-weight: bold; text-transform: uppercase;">${row.right.role}</div>
              <div style="font-style: italic; font-size: 12px; margin-top: 3px; color: #888888; height: 60px; display: flex; align-items: center; justify-content: center;">(Chữ ký, dấu)</div>
              <div style="font-weight: bold; margin-top: 10px; font-size: 14px;">${row.right.name}</div>
            ` : ''}
          </td>
        </tr>
      `).join('');

      markup = `
        <!-- Nếu có nơi nhận, vẽ nơi nhận riêng ở phía trên bên trái signature block -->
        ${showRecipient.checked ? `
          <table cellpadding="0" cellspacing="0" border="0" style="width: 100%; border-collapse: collapse; font-family: 'Times New Roman', Times, serif; font-size: 13px; margin-bottom: 15px;">
            <tr>
              <td style="width: 50%; vertical-align: top; text-align: left; padding-bottom: 10px;">
                ${recipientHtml}
              </td>
              <td style="width: 50%;"></td>
            </tr>
          </table>
        ` : ''}

        <!-- Bảng chữ ký nhiều người -->
        <table cellpadding="0" cellspacing="0" border="0" style="width: 100%; border-collapse: collapse; font-family: 'Times New Roman', Times, serif; font-size: 13px;">
          ${sigsRows}
        </table>
      `;
    }

    return markup;
  }

  function renderDocument() {
    if (!paperDocument) return;

    const authority = issuingAuthority.value || 'TÊN CƠ QUAN CHỦ QUẢN';
    const subAuthority = issuingSubAuthority.value || 'Số: ...';
    const locDate = locationDate.value || '..., ngày ... tháng ... năm ...';
    const title = docTitle.value || 'TÊN VĂN BẢN';
    const summary = docSummary.value || 'Về việc ...';
    const body = (docBody.value || '').replace(/\n/g, '<br />');

    // Cấu trúc bảng và định dạng đúng Nghị định 30
    const html = `
      <!-- Header double-column table layout -->
      <table cellpadding="0" cellspacing="0" border="0" style="width: 100%; border-collapse: collapse; font-family: 'Times New Roman', Times, serif; font-size: 13px; margin-bottom: 30px;">
        <tr>
          <td style="width: 45%; text-align: center; vertical-align: top;">
            <div style="font-weight: bold; text-transform: uppercase;">${authority}</div>
            <div style="font-weight: bold; margin-top: 3px;">${subAuthority}</div>
            <div style="width: 60px; border-bottom: 1px solid black; margin: 8px auto 0 auto;"></div>
          </td>
          <td style="width: 55%; text-align: center; vertical-align: top; padding-left: 10px;">
            <div style="font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px;">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</div>
            <div style="font-weight: bold; text-decoration: underline; margin-top: 3px;">Độc lập - Tự do - Hạnh phúc</div>
            <div style="font-style: italic; margin-top: 8px;">${locDate}</div>
          </td>
        </tr>
      </table>

      <!-- Title area -->
      <div style="text-align: center; font-family: 'Times New Roman', Times, serif; margin-bottom: 25px;">
        <h2 style="font-size: 15px; font-weight: bold; margin: 0; text-transform: uppercase; line-height: 1.3;">${title}</h2>
        <div style="font-size: 13px; font-style: italic; margin-top: 5px; font-weight: bold;">${summary}</div>
        <div style="width: 100px; border-bottom: 1px solid black; margin: 10px auto 0 auto;"></div>
      </div>

      <!-- Main Body content -->
      <div style="font-family: 'Times New Roman', Times, serif; font-size: 13px; line-height: 1.5; text-align: justify; margin-bottom: 40px; text-indent: 20px;">
        ${body}
      </div>

      <!-- Signature & Recipient Area -->
      ${generateSignaturesMarkup()}
    `;

    paperDocument.innerHTML = html;
  }

  // Bind input events
  const inputs = [issuingAuthority, issuingSubAuthority, locationDate, docTitle, docSummary, docBody];
  inputs.forEach(input => {
    input.addEventListener('input', renderDocument);
  });

  signerInputs.forEach(item => {
    item.role.addEventListener('input', renderDocument);
    item.name.addEventListener('input', renderDocument);
  });

  // Sao chép dạng Rich HTML để paste trực tiếp vào Word
  btnCopyDoc?.addEventListener('click', async () => {
    if (!paperDocument) return;

    try {
      const type = "text/html";
      const blob = new Blob([paperDocument.innerHTML], { type });
      const data = [new ClipboardItem({ [type]: blob })];
      
      await navigator.clipboard.write(data);
      alert("Đã sao chép văn bản! Hãy mở Microsoft Word ra nhấn Ctrl+V để dán chuẩn Nghị định 30.");
    } catch (err) {
      try {
        await navigator.clipboard.writeText(paperDocument.innerText);
        alert("Đã sao chép văn bản dạng chữ thường!");
      } catch (e) {
        alert("Không thể tự động sao chép. Vui lòng tự bôi đen văn bản và nhấn Ctrl+C!");
      }
    }
  });

  // Tải file văn bản mở bằng Word (.doc)
  btnDownloadDoc?.addEventListener('click', () => {
    if (!paperDocument) return;

    const htmlContent = paperDocument.innerHTML;
    // Chuẩn hóa HTML sang Mime Type MSWord để Word đọc giữ nguyên cấu trúc CSS và Table lề
    const docHtml = `
      <html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
      <head><title>Van Ban Hanh Chinh</title>
      <meta charset="utf-8">
      <style>
        body { font-family: 'Times New Roman', serif; font-size: 13pt; line-height: 1.5; }
        table { border-collapse: collapse; width: 100%; }
        td { font-family: 'Times New Roman', serif; font-size: 13pt; vertical-align: top; }
      </style>
      </head>
      <body>
        ${htmlContent}
      </body>
      </html>
    `;

    const blob = new Blob(['\ufeff' + docHtml], { type: 'application/msword' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'van-ban-hanh-chinh-trolyso.doc';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  });

  // Initialize
  updateDocTypes();
  toggleSignerFields();
  renderDocument();
</script>
