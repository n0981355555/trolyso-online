---
import Layout from '../../../layouts/Layout.astro';
import rawRegions from '../../../data/regions.json';
import { getSlug } from '../../../utils/slugify.js';

// Nhóm 6 tỉnh hành chính cũ thành 4 tỉnh/thành sáp nhập mới
const mappedRegions = [
  {
    name: "Thành phố Hà Nội",
    slug: "ha-noi"
  },
  {
    name: "Tỉnh Bắc Ninh",
    slug: "bac-ninh"
  },
  {
    name: "Tỉnh Quảng Ninh",
    slug: "quang-ninh"
  },
  {
    name: "Thành phố Hải Phòng",
    slug: "hai-phong"
  }
];

// Định dạng dữ liệu Phường/Xã cho từng Tỉnh và xử lý trùng lặp slug
const processedRegions = mappedRegions.map(target => {
  const wards = [];
  
  const matchingRaw = rawRegions.filter(r => {
    if (target.slug === 'ha-noi') return r.code === 1;
    if (target.slug === 'bac-ninh') return r.code === 24 || r.code === 27;
    if (target.slug === 'quang-ninh') return r.code === 22;
    if (target.slug === 'hai-phong') return r.code === 2 || r.code === 30;
    return false;
  });
  
  matchingRaw.forEach(prov => {
    prov.districts.forEach(dist => {
      dist.wards.forEach(w => {
        wards.push({
          name: w.name,
          rawSlug: getSlug(w.name),
          districtName: dist.name,
          code: w.code
        });
      });
    });
  });
  
  // Tìm kiếm và đánh dấu các Phường/Xã bị trùng tên trong cùng một Tỉnh
  const slugCounts = {};
  wards.forEach(w => {
    slugCounts[w.rawSlug] = (slugCounts[w.rawSlug] || 0) + 1;
  });
  
  wards.forEach(w => {
    if (slugCounts[w.rawSlug] > 1) {
      w.slug = `${w.rawSlug}-${getSlug(w.districtName)}`;
    } else {
      w.slug = w.rawSlug;
    }
  });
  
  // Sắp xếp Phường/Xã theo Alphabet tiếng Việt
  return {
    ...target,
    wards: wards.sort((a, b) => a.name.localeCompare(b.name, 'vi'))
  };
});
