<!-- CLIENT LOGIC FOR FILTER AND AJAX SEARCH -->
<script define:vars={{ processedRegions }}>
  // Nhúng danh sách địa phương vào client script
  const regions = processedRegions;
  let currentWards = [];

  // Lấy các element DOM
  const tabRegion = document.getElementById('tabRegion');
  const tabMkh = document.getElementById('tabMkh');
  const regionForm = document.getElementById('regionForm');
  const mkhForm = document.getElementById('mkhForm');
  const selectProvince = document.getElementById('selectProvince');
  
  const selectWardInput = document.getElementById('selectWardInput');
  const selectWardValue = document.getElementById('selectWardValue');
  const wardDropdownList = document.getElementById('wardDropdownList');
  
  const btnSearchRegion = document.getElementById('btnSearchRegion');
  const mkhInput = document.getElementById('mkhInput');
  const btnSearchMkh = document.getElementById('btnSearchMkh');
  const resultBox = document.getElementById('resultBox');
  const resultContent = document.getElementById('resultContent');
  const btnClearResult = document.getElementById('btnClearResult');

  // Hàm chuyển ký tự có dấu thành không dấu phục vụ tìm kiếm fuzzy
  function removeAccents(str) {
    if (!str) return '';
    return str
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/đ/g, 'd')
      .replace(/Đ/g, 'D')
      .toLowerCase();
  }

  // Chuyển đổi TAB
  tabRegion.addEventListener('click', () => {
    tabRegion.className = "flex-1 py-2.5 text-xs font-bold rounded-lg text-center transition bg-white dark:bg-brand-darkCard shadow-sm text-slate-800 dark:text-white";
    tabMkh.className = "flex-1 py-2.5 text-xs font-bold rounded-lg text-center transition text-slate-500 dark:text-slate-400";
    regionForm.classList.remove('hidden');
    mkhForm.classList.add('hidden');
  });

  tabMkh.addEventListener('click', () => {
    tabMkh.className = "flex-1 py-2.5 text-xs font-bold rounded-lg text-center transition bg-white dark:bg-brand-darkCard shadow-sm text-slate-800 dark:text-white";
    tabRegion.className = "flex-1 py-2.5 text-xs font-bold rounded-lg text-center transition text-slate-500 dark:text-slate-400";
    mkhForm.classList.remove('hidden');
    regionForm.classList.add('hidden');
  });

  // Vẽ danh sách kết quả lên Dropdown gợi ý
  function renderDropdown(wardsList) {
    wardDropdownList.innerHTML = '';
    if (!wardsList.length) {
      const emptyItem = document.createElement('div');
      emptyItem.className = 'px-4 py-3 text-sm text-slate-400 dark:text-slate-600 font-medium italic';
      emptyItem.textContent = 'Không tìm thấy Phường/Xã tương ứng';
      wardDropdownList.appendChild(emptyItem);
      return;
    }

    wardsList.forEach(w => {
      const item = document.createElement('button');
      item.type = 'button';
      item.className = 'w-full text-left px-4 py-3 text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors';
      item.textContent = w.name;
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        selectWardInput.value = w.name;
        selectWardValue.value = w.slug;
        wardDropdownList.classList.add('hidden');
      });
      wardDropdownList.appendChild(item);
    });
  }

  // Xử lý Thay đổi Tỉnh/Thành -> Load danh sách Xã/Phường
  selectProvince.addEventListener('change', (e) => {
    const provinceSlug = e.target.value;
    selectWardInput.value = '';
    selectWardValue.value = '';
    wardDropdownList.innerHTML = '';
    
    if (!provinceSlug) {
      selectWardInput.disabled = true;
      selectWardInput.placeholder = '-- Vui lòng chọn Tỉnh/Thành trước --';
      selectWardInput.className = "w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-950 font-bold text-slate-400 dark:text-slate-600 focus:outline-none";
      currentWards = [];
      return;
    }

    const province = regions.find(r => r.slug === provinceSlug);
    if (!province || !province.wards.length) {
      selectWardInput.disabled = true;
      selectWardInput.placeholder = '-- Không có dữ liệu Phường/Xã --';
      currentWards = [];
      return;
    }

    selectWardInput.disabled = false;
    selectWardInput.placeholder = 'Gõ để tìm kiếm Phường / Xã...';
    selectWardInput.className = "w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 font-bold text-slate-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-brand-blue";
    currentWards = province.wards;
    renderDropdown(currentWards);
  });

  // Hiển thị dropdown khi focus vào Input tìm kiếm
  selectWardInput.addEventListener('focus', () => {
    if (currentWards.length) {
      wardDropdownList.classList.remove('hidden');
    }
  });

  // Lọc các mục dropdown khi người dùng gõ phím (fuzzy search không dấu)
  selectWardInput.addEventListener('input', () => {
    const query = removeAccents(selectWardInput.value.trim());
    if (!query) {
      renderDropdown(currentWards);
      return;
    }
    const filtered = currentWards.filter(w => removeAccents(w.name).includes(query));
    renderDropdown(filtered);
    wardDropdownList.classList.remove('hidden');
  });

  // Đóng dropdown khi click ra ngoài vùng bộ chọn
  document.addEventListener('click', (e) => {
    const combobox = document.getElementById('wardCombobox');
    if (combobox && !combobox.contains(e.target)) {
      wardDropdownList.classList.add('hidden');
    }
  });

  // Nhấn nút Tra cứu theo khu vực -> Chuyển hướng tới trang SEO Phường/Xã
  btnSearchRegion.addEventListener('click', () => {
    const provinceSlug = selectProvince.value;
    const wardSlug = selectWardValue.value;

    if (!provinceSlug || !wardSlug) {
      alert('Vui lòng nhập tìm kiếm và chọn Phường/Xã/Đặc khu từ danh sách gợi ý nhé!');
      return;
    }

    // Redirect tới URL của trang xã: /calculators/lich-cat-dien/[tinh]/[xa]/
    window.location.href = `/calculators/lich-cat-dien/${provinceSlug}/${wardSlug}/`;
  });

  // Nhấn nút Tra cứu theo Mã Khách Hàng (EVN) -> Gọi AJAX qua proxy
  btnSearchMkh.addEventListener('click', async () => {
    const mkh = mkhInput.value.trim().toUpperCase();
    if (!mkh) {
      alert('Vui lòng nhập Mã khách hàng của bạn (Ví dụ: PE01...)!');
      return;
    }

    resultBox.classList.remove('hidden');
    resultContent.innerHTML = `
      <div class="flex items-center justify-center py-6 gap-2">
        <span class="w-5 h-5 border-2 border-brand-blue border-t-transparent rounded-full animate-spin"></span>
        <span class="text-sm text-slate-500 font-bold">Đang kết nối API Điện lực EVN...</span>
      </div>
    `;

    try {
      // Giả lập cuộc gọi AJAX tới proxy EVN (Sau này sẽ tích hợp API cào trực tiếp)
      // Trong Giai đoạn 1, chúng ta viết mock dữ liệu trả về theo mã vùng
      await new Promise(resolve => setTimeout(resolve, 1500));

      const isMockSuccess = true;
      if (isMockSuccess) {
        resultContent.innerHTML = `
          <div class="flex items-center gap-2 text-green-600 dark:text-green-400 font-bold mb-2">
            <span class="text-lg">✓</span> Kết nối thành công với EVN
          </div>
          <div class="space-y-2.5 text-sm text-slate-600 dark:text-slate-300">
            <p><strong>Mã Khách Hàng:</strong> ${mkh}</p>
            <p><strong>Trạng thái cấp điện hôm nay (${new Date().toLocaleDateString('vi-VN')}):</strong></p>
            <div class="p-4 bg-green-50 dark:bg-green-950/30 border border-green-200 dark:border-green-900/50 rounded-xl">
              <p class="font-bold text-green-700 dark:text-green-400 text-sm">💡 KHÔNG CÓ LỊCH CẮT ĐIỆN KHẨN CẤP HOẶC ĐỊNH KỲ</p>
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Khu vực của mã khách hàng này hiện đang hoạt động bình thường, không ghi nhận kế hoạch cắt điện trong 7 ngày tới.</p>
            </div>
            <p class="text-xs text-slate-400 dark:text-slate-500 italic mt-2 text-center">
              Mẹo: Nếu có lịch cắt khẩn cấp đột xuất, EVN sẽ nhắn trực tiếp qua SMS hoặc Zalo cho số điện thoại đăng ký hợp đồng.
            </p>
          </div>
        `;
      }
    } catch (e) {
      resultContent.innerHTML = `
        <div class="flex items-center gap-2 text-red-500 font-bold">
          <span>⚠️</span> Lỗi kết nối API EVN
        </div>
        <p class="text-sm text-slate-500 mt-2">
          Hiện tại cổng dịch vụ EVN đang quá tải hoặc cấu hình bảo mật thay đổi. Vui lòng liên hệ trực tiếp tổng đài chăm sóc khách hàng điện lực của bạn để kiểm tra.
        </p>
      `;
    }
  });

  // Nút Xóa Kết Quả
  btnClearResult.addEventListener('click', () => {
    resultBox.classList.add('hidden');
    resultContent.innerHTML = '';
  });
</script>

