---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Công Cụ Tính Tuổi Nghỉ Hưu & Lương Hưu Dự Kiến - Trợ Lý Số"
  description="Dự tính chính xác tuổi nghỉ hưu theo lộ trình Nghị định 135/2020/NĐ-CP, tỷ lệ hưởng lương hưu (%) và mức lương hưu nhận hàng tháng của bạn."
>
  <!-- Background Decor -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(16,185,129,0.04),transparent_50%)] pointer-events-none z-0"></div>

  <main class="max-w-6xl mx-auto px-4 py-12 w-full z-10 relative">
    
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/#calculators" class="hover:text-brand-blue dark:hover:text-brand-mint">Calculators</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Tính lương hưu</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-4">
        Tính Tuổi Nghỉ Hưu & Lương Hưu Dự Kiến
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Tính toán tự động thời điểm nghỉ hưu theo lộ trình tăng tuổi Nghị định 135, tỷ lệ hưởng lương hưu và số tiền trợ cấp đóng dư năm.
      </p>
    </div>

    <!-- Tool Grid -->
    <div class="bg-white dark:bg-brand-darkCard rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 overflow-hidden grid grid-cols-1 md:grid-cols-12 mb-12 transition-colors">
        
      <!-- Left inputs (7 cols) -->
      <div class="p-6 sm:p-10 md:col-span-7">
        <h2 class="text-xl font-heading font-bold text-slate-900 dark:text-white mb-8 flex items-center gap-3">
          💼 Thông tin người lao động & BHXH
        </h2>

        <div class="space-y-5">
          <!-- Giới tính -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Giới tính</label>
            <div class="grid grid-cols-2 gap-3">
              <label class="flex items-center justify-center p-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 cursor-pointer font-bold text-sm select-none">
                <input type="radio" name="gender" value="male" checked class="mr-2 accent-brand-blue" /> Nam
              </label>
              <label class="flex items-center justify-center p-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 cursor-pointer font-bold text-sm select-none">
                <input type="radio" name="gender" value="female" class="mr-2 accent-brand-blue" /> Nữ
              </label>
            </div>
          </div>

          <!-- Tháng và Năm sinh -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="birthMonth" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Tháng sinh</label>
              <select id="birthMonth" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint font-semibold">
                {Array.from({ length: 12 }, (_, i) => (
                  <option value={i + 1} selected={i === 9}>Tháng {i + 1}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="birthYear" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Năm sinh</label>
              <input type="number" id="birthYear" value="1975" min="1950" max="2020" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint font-bold text-center" />
            </div>
          </div>

          <!-- Số năm đóng BHXH -->
          <div>
            <label for="yearsBHXH" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Tổng số năm đóng BHXH</label>
            <div class="flex items-center gap-3">
              <button id="btnMinusYears" aria-label="Giảm số năm đóng bảo hiểm" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">-</button>
              <input type="number" id="yearsBHXH" value="25" min="1" max="50" class="w-24 text-center py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-bold text-lg" />
              <span class="text-sm text-slate-400">năm đóng</span>
              <button id="btnPlusYears" aria-label="Tăng số năm đóng bảo hiểm" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">+</button>
            </div>
          </div>

          <!-- Lương đóng BHXH trung bình -->
          <div>
            <label for="avgSalary" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Bình quân tiền lương tháng đóng BHXH (VND)</label>
            <input type="number" id="avgSalary" value="10000000" step="500000" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint font-bold text-lg" />
          </div>

          <button id="btnCalculate" class="w-full bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold py-4 px-6 rounded-xl transition duration-200 shadow-lg">
            ⚡ Dự Tính Lương Hưu
          </button>
        </div>
      </div>

      <!-- Right outputs (5 cols) -->
      <div class="p-6 sm:p-10 bg-slate-50/50 dark:bg-slate-900/50 md:col-span-5 flex flex-col justify-between border-t md:border-t-0 md:border-l border-slate-200 dark:border-slate-800">
        <div>
          <h3 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-6">Kết quả dự kiến</h3>

          <div class="space-y-4 text-sm">
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Thời điểm nghỉ hưu:</span>
              <span class="font-bold text-slate-900 dark:text-white" id="retireDate">Tháng 10/2037</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Tuổi nghỉ hưu chính thức:</span>
              <span class="font-semibold text-slate-900 dark:text-white" id="retireAge">62 tuổi</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Tỷ lệ hưởng lương hưu:</span>
              <span class="font-bold text-brand-blue dark:text-brand-mint" id="pensionRate">55%</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500 flex flex-col">
                <span>Lương hưu hàng tháng:</span>
                <span class="text-[10px] text-slate-400">(Nhận trọn đời)</span>
              </span>
              <span class="text-xl font-extrabold text-emerald-600 dark:text-brand-mint" id="monthlyPension">5,500,000 đ</span>
            </div>
            <!-- Trợ cấp thừa năm (Chỉ hiện khi đóng trên 30 năm nữ hoặc 35 năm nam) -->
            <div id="excessWrapper" class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800 hidden">
              <span class="text-slate-500 flex flex-col">
                <span>Trợ cấp một lần (đóng dư):</span>
                <span class="text-[10px] text-slate-400">(0.5 tháng lương/năm dư)</span>
              </span>
              <span class="font-bold text-slate-900 dark:text-white" id="excessAllowance">0 đ</span>
            </div>
          </div>
        </div>

        <div class="text-[11px] text-slate-400 mt-8 pt-4 border-t border-slate-200 dark:border-slate-800 leading-normal" id="warningNote">
          * Lưu ý: Kết quả trên tính theo điều kiện làm việc bình thường. Số năm đóng tối thiểu để hưởng lương hưu là 20 năm đối với nam và 15 năm đối với nữ (Luật mới có lộ trình giảm dần năm đóng tối thiểu xuống 15 năm).
        </div>
      </div>

    </div>
  </main>
</Layout>

<script>
  function formatMoney(amount: number) {
    const isEn = localStorage.getItem('lang') === 'en';
    if (isEn) {
      return new Intl.NumberFormat('en-US', { style: 'decimal' }).format(amount) + ' VND';
    }
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
  }

  const birthMonthSelect = document.getElementById('birthMonth') as HTMLSelectElement;
  const birthYearInput = document.getElementById('birthYear') as HTMLInputElement;
  const yearsBHXHInput = document.getElementById('yearsBHXH') as HTMLInputElement;
  const avgSalaryInput = document.getElementById('avgSalary') as HTMLInputElement;

  const btnMinusYears = document.getElementById('btnMinusYears');
  const btnPlusYears = document.getElementById('btnPlusYears');
  const btnCalculate = document.getElementById('btnCalculate');

  const retireDateEl = document.getElementById('retireDate');
  const retireAgeEl = document.getElementById('retireAge');
  const pensionRateEl = document.getElementById('pensionRate');
  const monthlyPensionEl = document.getElementById('monthlyPension');
  const excessWrapper = document.getElementById('excessWrapper');
  const excessAllowanceEl = document.getElementById('excessAllowance');
  const warningNoteEl = document.getElementById('warningNote');

  function calculatePension() {
    const isEn = localStorage.getItem('lang') === 'en';
    const birthY = parseInt(birthYearInput.value) || 1975;
    const birthM = parseInt(birthMonthSelect.value) || 10;
    const yearsBHXH = parseFloat(yearsBHXHInput.value) || 0;
    const avgSalary = parseFloat(avgSalaryInput.value) || 0;

    // Lấy giới tính đang chọn
    const genderNode = document.querySelector('input[name="gender"]:checked') as HTMLInputElement;
    const isMale = genderNode ? genderNode.value === 'male' : true;

    // Giải lộ trình Nghị định 135 tìm tháng năm nghỉ hưu
    let retireYear = birthY + 55;
    let retireMonth = birthM;
    let found = false;

    for (let y = birthY + 55; y <= birthY + 70; y++) {
      for (let m = 1; m <= 12; m++) {
        const ageMonths = (y * 12 + m) - (birthY * 12 + birthM);
        let reqMonths = 0;
        if (isMale) {
          if (y <= 2020) reqMonths = 60 * 12;
          else if (y === 2021) reqMonths = 60 * 12 + 3;
          else if (y === 2022) reqMonths = 60 * 12 + 6;
          else if (y === 2023) reqMonths = 60 * 12 + 9;
          else if (y === 2024) reqMonths = 61 * 12;
          else if (y === 2025) reqMonths = 61 * 12 + 3;
          else if (y === 2026) reqMonths = 61 * 12 + 6;
          else if (y === 2027) reqMonths = 61 * 12 + 9;
          else reqMonths = 62 * 12;
        } else {
          if (y <= 2020) reqMonths = 55 * 12;
          else if (y === 2021) reqMonths = 55 * 12 + 4;
          else if (y === 2022) reqMonths = 55 * 12 + 8;
          else if (y === 2023) reqMonths = 56 * 12;
          else if (y === 2024) reqMonths = 56 * 12 + 4;
          else if (y === 2025) reqMonths = 56 * 12 + 8;
          else if (y === 2026) reqMonths = 57 * 12;
          else if (y === 2027) reqMonths = 57 * 12 + 4;
          else if (y === 2028) reqMonths = 57 * 12 + 8;
          else if (y === 2029) reqMonths = 58 * 12;
          else if (y === 2030) reqMonths = 58 * 12 + 4;
          else if (y === 2031) reqMonths = 58 * 12 + 8;
          else if (y === 2032) reqMonths = 59 * 12;
          else if (y === 2033) reqMonths = 59 * 12 + 4;
          else if (y === 2034) reqMonths = 59 * 12 + 8;
          else reqMonths = 60 * 12;
        }

        if (ageMonths >= reqMonths) {
          retireYear = y;
          retireMonth = m;
          found = true;
          break;
        }
      }
      if (found) break;
    }

    const diffMonths = (retireYear * 12 + retireMonth) - (birthY * 12 + birthM);
    const retireAgeYears = Math.floor(diffMonths / 12);
    const retireAgeMonths = diffMonths % 12;

    // Hiển thị ngày nghỉ hưu và tuổi nghỉ hưu
    if (retireDateEl) {
      retireDateEl.innerText = isEn 
        ? `Month ${retireMonth}/${retireYear}`
        : `Tháng ${retireMonth}/${retireYear}`;
    }
    if (retireAgeEl) {
      if (retireAgeMonths > 0) {
        retireAgeEl.innerText = isEn
          ? `${retireAgeYears} years and ${retireAgeMonths} months`
          : `${retireAgeYears} tuổi ${retireAgeMonths} tháng`;
      } else {
        retireAgeEl.innerText = isEn
          ? `${retireAgeYears} years`
          : `${retireAgeYears} tuổi`;
      }
    }

    // Tính tỷ lệ hưởng lương hưu và trợ cấp dư năm
    const baseYears = isMale ? 20 : 15;
    let rate = 0;
    let excessYears = 0;

    if (yearsBHXH >= baseYears) {
      rate = 45 + (yearsBHXH - baseYears) * 2;
      if (rate > 75) {
        rate = 75;
        // Số năm cần thiết để hưởng tối đa 75%
        const maxRequiredYears = isMale ? 35 : 30;
        excessYears = Math.max(0, yearsBHXH - maxRequiredYears);
      }
    } else {
      // Chưa đủ năm đóng tối thiểu
      rate = 0;
    }

    if (pensionRateEl) {
      if (rate > 0) {
        pensionRateEl.innerText = `${rate}%`;
      } else {
        pensionRateEl.innerText = isEn 
          ? "Not eligible for pension" 
          : "Chưa đủ điều kiện nhận lương hưu";
      }
    }

    // Lương hưu hàng tháng
    const monthlyPension = (rate / 100) * avgSalary;
    if (monthlyPensionEl) {
      monthlyPensionEl.innerText = formatMoney(monthlyPension);
    }

    // Trợ cấp dư năm
    if (excessYears > 0) {
      excessWrapper?.classList.remove('hidden');
      const excessMoney = excessYears * 0.5 * avgSalary;
      if (excessAllowanceEl) {
        excessAllowanceEl.innerText = formatMoney(excessMoney);
      }
    } else {
      excessWrapper?.classList.add('hidden');
    }

    // Cảnh báo nếu chưa đủ năm
    if (warningNoteEl) {
      if (rate === 0) {
        warningNoteEl.innerText = isEn
          ? `* Warning: You need at least ${baseYears} years of social insurance contributions to qualify for a pension. Standard voluntary insurance option is available.`
          : `* Cảnh báo: Bạn cần đóng tối thiểu từ ${baseYears} năm BHXH trở lên mới đủ điều kiện hưởng lương hưu hàng tháng. Có thể đóng bảo hiểm xã hội tự nguyện tự bù.`;
        warningNoteEl.classList.remove('text-slate-400');
        warningNoteEl.classList.add('text-red-500', 'font-bold');
      } else {
        warningNoteEl.innerText = isEn
          ? `* Note: Estimated calculations assume normal labor conditions. Minimum contribution year threshold is ${baseYears} years.`
          : `* Lưu ý: Kết quả trên tính theo điều kiện làm việc bình thường. Số năm đóng tối thiểu để hưởng lương hưu là ${baseYears} năm.`;
        warningNoteEl.classList.remove('text-red-500', 'font-bold');
        warningNoteEl.classList.add('text-slate-400');
      }
    }
  }

  // Bind events
  btnMinusYears?.addEventListener('click', () => {
    let val = parseFloat(yearsBHXHInput.value) || 0;
    val = Math.max(1, val - 1);
    yearsBHXHInput.value = val.toString();
    calculatePension();
  });

  btnPlusYears?.addEventListener('click', () => {
    let val = parseFloat(yearsBHXHInput.value) || 0;
    yearsBHXHInput.value = (val + 1).toString();
    calculatePension();
  });

  document.getElementsByName('gender').forEach(radio => {
    radio.addEventListener('change', calculatePension);
  });

  btnCalculate?.addEventListener('click', calculatePension);
  birthMonthSelect?.addEventListener('change', calculatePension);
  birthYearInput?.addEventListener('input', calculatePension);
  yearsBHXHInput?.addEventListener('input', calculatePension);
  avgSalaryInput?.addEventListener('input', calculatePension);

  // Tính toán lần đầu
  calculatePension();

  // Lắng nghe sự kiện đổi ngôn ngữ để tính lại lập tức
  document.getElementById('langSelector')?.addEventListener('change', () => {
    setTimeout(calculatePension, 50);
  });
</script>
