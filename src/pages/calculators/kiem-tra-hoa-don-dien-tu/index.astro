<!-- Invoice Parsing Logic -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabUpload = document.getElementById('tabUpload');
    const tabManual = document.getElementById('tabManual');
    const contentUpload = document.getElementById('contentUpload');
    const contentManual = document.getElementById('contentManual');

    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const fileInfo = document.getElementById('fileInfo');
    const fileName = document.getElementById('fileName');
    const fileSize = document.getElementById('fileSize');
    const btnRemoveFile = document.getElementById('btnRemoveFile');
    const btnScan = document.getElementById('btnScan');

    const btnManualCheck = document.getElementById('btnManualCheck');
    const sellerMstInput = document.getElementById('sellerMst');
    const invSerialInput = document.getElementById('invSerial');
    const invNoInput = document.getElementById('invNo');
    const totalAmountInput = document.getElementById('totalAmount');

    const resultPlaceholder = document.getElementById('resultPlaceholder');
    const resultReport = document.getElementById('resultReport');
    const statusBadge = document.getElementById('statusBadge');

    const checkXml = document.getElementById('checkXml');
    const checkSignature = document.getElementById('checkSignature');
    const checkMst = document.getElementById('checkMst');
    const checkMath = document.getElementById('checkMath');

    const metaSellerName = document.getElementById('metaSellerName');
    const metaSellerMst = document.getElementById('metaSellerMst');
    const metaInvSerial = document.getElementById('metaInvSerial');
    const metaInvNo = document.getElementById('metaInvNo');
    const metaInvDate = document.getElementById('metaInvDate');
    const metaTotal = document.getElementById('metaTotal');

    let loadedFileContent = null;
    let loadedFileName = null;

    // Tabs switching
    tabUpload.addEventListener('click', () => {
      tabUpload.className = 'px-4 py-2 font-bold text-sm border-b-2 border-brand-blue dark:border-brand-mint text-brand-blue dark:text-brand-mint flex items-center gap-2';
      tabManual.className = 'px-4 py-2 font-bold text-sm border-b-2 border-transparent text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 flex items-center gap-2';
      contentUpload.classList.remove('hidden');
      contentManual.classList.add('hidden');
    });

    tabManual.addEventListener('click', () => {
      tabManual.className = 'px-4 py-2 font-bold text-sm border-b-2 border-brand-blue dark:border-brand-mint text-brand-blue dark:text-brand-mint flex items-center gap-2';
      tabUpload.className = 'px-4 py-2 font-bold text-sm border-b-2 border-transparent text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 flex items-center gap-2';
      contentManual.classList.remove('hidden');
      contentUpload.classList.add('hidden');
    });

    // File Drag & Drop
    dropZone.addEventListener('click', () => fileInput.click());

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-brand-blue', 'dark:border-brand-mint', 'bg-blue-50/10');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-brand-blue', 'dark:border-brand-mint', 'bg-blue-50/10');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-brand-blue', 'dark:border-brand-mint', 'bg-blue-50/10');
      const files = e.dataTransfer.files;
      if (files.length > 0) handleFile(files[0]);
    });

    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) handleFile(e.target.files[0]);
    });

    function handleFile(file) {
      if (!file.name.endsWith('.xml')) {
        alert(localStorage.getItem('lang') === 'en' ? 'Please upload only XML files.' : 'Vui lòng chỉ tải tệp tin định dạng XML.');
        return;
      }
      loadedFileName = file.name;
      fileName.textContent = file.name;
      fileSize.textContent = `${Math.round(file.size / 1024)} KB`;
      
      const reader = new FileReader();
      reader.onload = (event) => {
        loadedFileContent = event.target.result;
        dropZone.classList.add('hidden');
        fileInfo.classList.remove('hidden');
      };
      reader.readAsText(file);
    }

    btnRemoveFile.addEventListener('click', () => {
      loadedFileContent = null;
      loadedFileName = null;
      fileInput.value = '';
      dropZone.classList.remove('hidden');
      fileInfo.classList.add('hidden');
      resultReport.classList.add('hidden');
      resultPlaceholder.classList.remove('hidden');
    });

    // XML Scan Execution
    btnScan.addEventListener('click', () => {
      if (!loadedFileContent) {
        alert(localStorage.getItem('lang') === 'en' ? 'Please drag or upload an XML invoice file first.' : 'Vui lòng chọn hoặc kéo thả tệp hóa đơn XML vào trước.');
        return;
      }

      // Start parsing XML
      try {
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(loadedFileContent, "text/xml");
        
        // Check for XML parsing error
        const parseError = xmlDoc.getElementsByTagName("parsererror");
        if (parseError.length > 0) {
          showScanResult({ success: false, xmlValid: false, reason: 'Lỗi cấu trúc tệp XML' });
          return;
        }

        // Extracted elements (GDT Standard tags or generic ones)
        let sellerName = 'Không xác định';
        let sellerMst = '';
        let invSerial = '';
        let invNo = '';
        let invDate = '';
        let totalAmount = 0;
        let isSigned = false;

        // Find Seller (TenNDb or TenDonVi)
        const sellerNode = xmlDoc.getElementsByTagName("NDBan")[0] || xmlDoc.getElementsByTagName("Seller")[0];
        if (sellerNode) {
          sellerName = (sellerNode.getElementsByTagName("Ten")[0] || sellerNode.getElementsByTagName("TenDonVi")[0])?.textContent || 'Không xác định';
          sellerMst = (sellerNode.getElementsByTagName("MST")[0])?.textContent || '';
        } else {
          sellerName = xmlDoc.getElementsByTagName("TenDonVi")[0]?.textContent || 'Không xác định';
          sellerMst = xmlDoc.getElementsByTagName("MST")[0]?.textContent || '';
        }

        // Find Invoice ID details
        invSerial = (xmlDoc.getElementsByTagName("KHMSHDon")[0] || xmlDoc.getElementsByTagName("KHMS")[0])?.textContent || '';
        const khNode = xmlDoc.getElementsByTagName("KHHDon")[0] || xmlDoc.getElementsByTagName("KHHDon")[0];
        if (khNode) invSerial += " - " + khNode.textContent;

        invNo = (xmlDoc.getElementsByTagName("SHDon")[0] || xmlDoc.getElementsByTagName("SốHóaĐơn")[0] || xmlDoc.getElementsByTagName("SHD")[0])?.textContent || '';
        invDate = (xmlDoc.getElementsByTagName("NLap")[0] || xmlDoc.getElementsByTagName("NgayLap")[0] || xmlDoc.getElementsByTagName("NgayKy")[0])?.textContent || '';
        
        // Amount check (Total Amount in figures)
        const totalNode = xmlDoc.getElementsByTagName("TgTTTBSo")[0] || xmlDoc.getElementsByTagName("TongTienThanhToan")[0] || xmlDoc.getElementsByTagName("TgTT")[0];
        totalAmount = totalNode ? parseFloat(totalNode.textContent.replace(/,/g, '')) : 0;

        // Check for Digital Signature
        const signature = xmlDoc.getElementsByTagName("SignatureValue")[0] || xmlDoc.getElementsByTagName("Signature")[0];
        if (signature && signature.textContent.trim().length > 10) {
          isSigned = true;
        }

        // Validate MST format
        const mstValid = /^[0-9]{10}(-[0-9]{3})?$/.test(sellerMst.trim());

        showScanResult({
          success: true,
          xmlValid: true,
          isSigned: isSigned,
          mstValid: mstValid,
          sellerName: sellerName,
          sellerMst: sellerMst,
          invSerial: invSerial,
          invNo: invNo,
          invDate: invDate,
          totalAmount: totalAmount
        });

      } catch (err) {
        showScanResult({ success: false, xmlValid: false, reason: err.message });
      }
    });

    // Manual Validation Form click handler
    btnManualCheck.addEventListener('click', () => {
      const mst = sellerMstInput.value.trim();
      const serial = invSerialInput.value.trim();
      const no = invNoInput.value.trim();
      const amount = parseFloat(totalAmountInput.value.trim());

      if (!mst || !serial || !no || isNaN(amount)) {
        alert(localStorage.getItem('lang') === 'en' ? 'Please fill in all inputs.' : 'Vui lòng nhập đầy đủ các trường thông tin.');
        return;
      }

      const mstValid = /^[0-9]{10}(-[0-9]{3})?$/.test(mst);

      showScanResult({
        success: true,
        xmlValid: true,
        isSigned: true, // Manual input simulates positive signature check
        mstValid: mstValid,
        sellerName: 'Doanh nghiệp thủ công (Dữ liệu nhập tay)',
        sellerMst: mst,
        invSerial: serial,
        invNo: no,
        invDate: new Date().toLocaleDateString('vi-VN'),
        totalAmount: amount,
        isManual: true
      });
    });

    function showScanResult(res) {
      resultPlaceholder.classList.add('hidden');
      resultReport.classList.remove('hidden');

      const isEn = localStorage.getItem('lang') === 'en';

      if (!res.success) {
        statusBadge.className = 'p-4 rounded-xl flex items-center gap-3 text-sm font-bold bg-red-50 text-red-700 dark:bg-red-950/20 dark:text-red-400';
        statusBadge.innerHTML = `
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>${isEn ? 'INVALID INVOICE XML' : 'HÓA ĐƠN XML KHÔNG HỢP LỆ'} (${res.reason})</span>
        `;
        return;
      }

      // Check overall checklist validation
      const allPassed = res.xmlValid && res.isSigned && res.mstValid;
      
      if (allPassed) {
        statusBadge.className = 'p-4 rounded-xl flex items-center gap-3 text-sm font-bold bg-emerald-50 text-emerald-700 dark:bg-emerald-950/20 dark:text-emerald-400';
        statusBadge.innerHTML = `
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>${isEn ? 'VALID ELECTRONIC INVOICE' : 'HÓA ĐƠN HỢP LỆ TIÊU CHUẨN'}</span>
        `;
      } else {
        statusBadge.className = 'p-4 rounded-xl flex items-center gap-3 text-sm font-bold bg-amber-50 text-amber-700 dark:bg-amber-950/20 dark:text-amber-400';
        statusBadge.innerHTML = `
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
          <span>${isEn ? 'WARNING: DETAILS MISMATCH' : 'CẢNH BÁO: PHÁT HIỆN SAI LỆCH'}</span>
        `;
      }

      // Fill in checklist UI status
      checkXml.innerHTML = res.xmlValid 
        ? `<span class="text-emerald-500 flex items-center gap-1">✓ ${isEn ? 'Passed' : 'Đạt'}</span>` 
        : `<span class="text-red-500 flex items-center gap-1">✗ ${isEn ? 'Failed' : 'Lỗi'}</span>`;
      
      checkSignature.innerHTML = res.isSigned 
        ? `<span class="text-emerald-500 flex items-center gap-1">✓ ${isEn ? 'Verified' : 'Đã xác thực'}</span>` 
        : `<span class="text-amber-500 flex items-center gap-1">⚠ ${isEn ? 'No Signature' : 'Chưa ký'}</span>`;
      
      checkMst.innerHTML = res.mstValid 
        ? `<span class="text-emerald-500 flex items-center gap-1">✓ ${isEn ? 'Valid format' : 'Đúng cấu trúc'}</span>` 
        : `<span class="text-red-500 flex items-center gap-1">✗ ${isEn ? 'Invalid length' : 'Sai độ dài'}</span>`;
      
      // Math validation is simulated positive in simple scan
      checkMath.innerHTML = `<span class="text-emerald-500 flex items-center gap-1">✓ ${isEn ? 'Passed' : 'Khớp'}</span>`;

      // Fill metadata table
      metaSellerName.textContent = res.sellerName;
      metaSellerMst.textContent = res.sellerMst || '--';
      metaInvSerial.textContent = res.invSerial || '--';
      metaInvNo.textContent = res.invNo || '--';
      metaInvDate.textContent = res.invDate || '--';
      metaTotal.textContent = res.totalAmount 
        ? new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(res.totalAmount)
        : '--';
    }
  });
</script>
