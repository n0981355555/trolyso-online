---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Xem Bói Bài Tarot Online Hằng Ngày - Rút Bài Tarot Miễn Phí" 
  description="Công cụ xem bói bài Tarot online hằng ngày miễn phí. Trải bài Tarot 1 lá hoặc 3 lá để dự báo về tình yêu, công việc, sự nghiệp và sức khỏe chính xác."
>
  <main class="max-w-5xl mx-auto px-4 py-8 sm:py-12">
    <!-- Breadcrumbs -->
    <nav class="flex mb-6 text-sm text-slate-500 dark:text-slate-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">
            Trang chủ
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/#calculators" class="hover:text-brand-blue dark:hover:text-brand-mint">Calculators</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Xem Bài Tarot Online</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Header Section -->
    <div class="text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white tracking-tight mb-3">
        Xem Bói Bài Tarot Online Hằng Ngày
      </h1>
      <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Kết nối trực giác của bạn và chọn chế độ trải bài Tarot dưới đây. Xào bài và lật mở các lá bài ẩn chứa thông điệp dành cho bạn.
      </p>
    </div>

    <!-- Tarot Workspace Container -->
    <div class="max-w-3xl mx-auto bg-white dark:bg-brand-darkCard rounded-3xl border border-slate-200 dark:border-slate-800 p-6 sm:p-10 shadow-xl mb-12 relative overflow-hidden">
      <!-- Background elements -->
      <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-32 h-32 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Mode Selector -->
      <div class="flex flex-col sm:flex-row justify-center gap-3 mb-8">
        <button id="btnModeDaily" class="px-5 py-3 rounded-2xl border text-xs sm:text-sm font-bold shadow-sm transition-all duration-200 bg-brand-blue border-brand-blue text-white">
          🔮 Rút 1 Lá (Thông điệp hằng ngày)
        </button>
        <button id="btnModeSpread3" class="px-5 py-3 rounded-2xl border text-xs sm:text-sm font-bold shadow-sm transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard">
          ✨ Trải 3 Lá (Quá khứ - Hiện tại - Tương lai)
        </button>
      </div>

      <!-- Shuffle & Deal Action -->
      <div class="text-center mb-10">
        <button id="btnShuffle" class="px-8 py-3.5 bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-emerald-500 dark:to-teal-600 text-white font-extrabold rounded-2xl shadow-md hover:scale-105 transition duration-200">
          ⚡ XÀO BÀI & TRẢI BÀI
        </button>
      </div>

      <!-- Tarot Cards Spread Area -->
      <div class="min-h-[280px] flex justify-center items-center py-6">
        <div id="cardsSpread" class="flex flex-wrap justify-center gap-6 sm:gap-8 w-full max-w-xl">
          <!-- Populated via Javascript -->
          <div class="text-center text-slate-400 dark:text-slate-500 text-sm italic py-10">
            Nhấn nút xào bài ở trên để trải các lá bài Tarot...
          </div>
        </div>
      </div>

      <!-- Results Display Panel -->
      <div id="resultsPanel" class="mt-8 pt-8 border-t border-slate-100 dark:border-slate-800/60 hidden space-y-6 animate-fade-in">
        <h3 class="text-xl font-heading font-bold text-slate-900 dark:text-white text-center">
          Thông Điệp Tarot Dành Cho Bạn
        </h3>
        
        <div id="resultsList" class="space-y-6">
          <!-- Rendered dynamically -->
        </div>

        <!-- Disclaimer Box (Terms of Use) -->
        <div class="p-5 rounded-2xl bg-amber-50/50 dark:bg-amber-950/20 border border-amber-200/60 dark:border-amber-900/40 text-center">
