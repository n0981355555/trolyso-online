        name: "The World (Thế Giới)",
        icon: "🌍",
        desc: "Đại diện cho sự hoàn thành viên mãn, sự trọn vẹn toàn diện, đạt được mục tiêu lớn và sự tự do kết nối thế giới.",
        love: "Mối quan hệ đi đến cái kết có hậu viên mãn (như lễ cưới hoặc sự gắn kết bền chặt trọn đời). Sự thấu hiểu tuyệt đối.",
        career: "Hoàn thành xuất sắc mục tiêu sự nghiệp lớn dài hạn. Cơ hội làm việc hoặc mở rộng kinh doanh ra nước ngoài.",
        health: "Cơ thể đạt được trạng thái cân bằng tuyệt đối giữa thể chất và tinh thần. Sức khỏe hoàn hảo."
      }
    ];

    // DOM References
    const btnModeDaily = document.getElementById('btnModeDaily');
    const btnModeSpread3 = document.getElementById('btnModeSpread3');
    const btnShuffle = document.getElementById('btnShuffle');
    const cardsSpread = document.getElementById('cardsSpread');
    const resultsPanel = document.getElementById('resultsPanel');
    const resultsList = document.getElementById('resultsList');

    let currentMode = 'daily'; // 'daily' or 'spread3'
    let isShuffling = false;

    // Switch to Daily Mode
    btnModeDaily.addEventListener('click', () => {
      if (isShuffling) return;
      currentMode = 'daily';
      btnModeDaily.className = "px-5 py-3 rounded-2xl border text-xs sm:text-sm font-bold shadow-sm transition-all duration-200 bg-brand-blue border-brand-blue text-white";
      btnModeSpread3.className = "px-5 py-3 rounded-2xl border text-xs sm:text-sm font-bold shadow-sm transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard";
      resetSpread();
    });

    // Switch to 3-Card Spread Mode
    btnModeSpread3.addEventListener('click', () => {
      if (isShuffling) return;
      currentMode = 'spread3';
      btnModeSpread3.className = "px-5 py-3 rounded-2xl border text-xs sm:text-sm font-bold shadow-sm transition-all duration-200 bg-brand-blue border-brand-blue text-white";
      btnModeDaily.className = "px-5 py-3 rounded-2xl border text-xs sm:text-sm font-bold shadow-sm transition-all duration-200 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:border-brand-blue dark:hover:border-brand-mint hover:text-brand-blue dark:hover:text-brand-mint bg-white dark:bg-brand-darkCard";
      resetSpread();
    });

    function resetSpread() {
      resultsPanel.classList.add('hidden');
      cardsSpread.innerHTML = `
        <div class="text-center text-slate-400 dark:text-slate-500 text-sm italic py-10">
          Nhấn nút xào bài ở trên để trải các lá bài Tarot...
        </div>
      `;
    }

    // Trigger Shuffling Animation and Layout Cards
    btnShuffle.addEventListener('click', () => {
      if (isShuffling) return;
      isShuffling = true;
      resultsPanel.classList.add('hidden');
      btnShuffle.disabled = true;
      btnShuffle.textContent = "🔮 ĐANG XÀO BÀI...";
      
      // Clear container and show shuffling mock cards
      cardsSpread.innerHTML = `
        <div class="flex justify-center items-center gap-2 relative w-64 h-48">
          <div class="absolute w-28 h-44 bg-gradient-to-br from-indigo-900 to-slate-900 dark:from-brand-darkCard dark:to-slate-900 rounded-xl border-2 border-slate-200/50 dark:border-slate-700/50 shadow-md flex items-center justify-center animate-pulse transform -rotate-6">✨</div>
          <div class="absolute w-28 h-44 bg-gradient-to-br from-indigo-900 to-slate-900 dark:from-brand-darkCard dark:to-slate-900 rounded-xl border-2 border-slate-200/50 dark:border-slate-700/50 shadow-md flex items-center justify-center animate-pulse transform translate-x-4 rotate-3">✨</div>
          <div class="absolute w-28 h-44 bg-gradient-to-br from-indigo-900 to-slate-900 dark:from-brand-darkCard dark:to-slate-900 rounded-xl border-2 border-slate-200/50 dark:border-slate-700/50 shadow-md flex items-center justify-center animate-pulse transform -translate-x-4 rotate-12">✨</div>
        </div>
      `;

      // Set timeout to draw cards after shuffle finishes
      setTimeout(() => {
        isShuffling = false;
        btnShuffle.disabled = false;
        btnShuffle.textContent = "⚡ XÀO BÀI & TRẢI BÀI";
        dealCards();
      }, 1500);
    });

    let drawnCards = [];

    // Layout the cards face down
    function dealCards() {
      cardsSpread.innerHTML = '';
      drawnCards = [];

      // Pick random cards from deck without repetition
      const shuffledDeck = [...tarotDeck].sort(() => Math.random() - 0.5);
      const cardsNeeded = currentMode === 'daily' ? 1 : 3;

      for (let i = 0; i < cardsNeeded; i++) {
        drawnCards.push({
          cardData: shuffledDeck[i],
          isFlipped: false,
          positionLabel: currentMode === 'daily' ? 'Thông điệp' : (i === 0 ? 'Quá khứ' : (i === 1 ? 'Hiện tại' : 'Tương lai'))
        });
      }

      // Render cards face down
      drawnCards.forEach((card, index) => {
        const cardWrapper = document.createElement('div');
        cardWrapper.className = "flex flex-col items-center gap-3";
        cardWrapper.innerHTML = `
          <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">${card.positionLabel}</span>
          
          <!-- Flip Card Container -->
          <div class="w-32 h-48 [perspective:1000px] cursor-pointer" onclick="this.dispatchEvent(new CustomEvent('flip-card', {bubbles: true, detail: ${index}}))">
            <div class="card-inner w-full h-full relative [transform-style:preserve-3d] transition-transform duration-500 rounded-2xl shadow-lg border border-slate-250 dark:border-slate-800">
              
              <!-- Card Back -->
              <div class="absolute inset-0 w-full h-full rounded-2xl [backface-visibility:hidden] bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 dark:from-brand-darkCard dark:via-indigo-950 dark:to-slate-950 flex flex-col items-center justify-center p-2 text-center text-amber-400/50">
                <div class="w-24 h-40 border border-amber-400/20 rounded-xl flex flex-col items-center justify-center gap-1.5 relative overflow-hidden">
                  <div class="absolute -top-6 -left-6 w-12 h-12 border border-amber-400/10 rounded-full"></div>
                  <div class="absolute -bottom-6 -right-6 w-12 h-12 border border-amber-400/10 rounded-full"></div>
                  <span class="text-3xl">✨</span>
                  <span class="text-[9px] uppercase tracking-widest font-serif font-semibold text-amber-500/40">Tarot Online</span>
                </div>
              </div>

              <!-- Card Front -->
              <div class="absolute inset-0 w-full h-full rounded-2xl [backface-visibility:hidden] [transform:rotateY(180deg)] bg-white dark:bg-brand-darkCard border-2 border-amber-400 dark:border-brand-mint/70 flex flex-col items-center justify-center p-4 text-center">
                <span class="text-4xl sm:text-5xl mb-3 block">${card.cardData.icon}</span>
                <span class="text-xs font-black text-slate-900 dark:text-white uppercase tracking-tight leading-tight mb-1">${card.cardData.name}</span>
                <span class="text-[9px] font-bold text-slate-400">Major Arcana</span>
              </div>

            </div>
          </div>
        `;
        cardsSpread.appendChild(cardWrapper);
      });
    }

    // Flip card event delegate
    document.addEventListener('flip-card', (e) => {
      const idx = e.detail;
      if (drawnCards[idx].isFlipped) return;

      drawnCards[idx].isFlipped = true;
      const cardWrapper = cardsSpread.children[idx];
      const cardInner = cardWrapper.querySelector('.card-inner');
      
      // Apply CSS 3D rotation
      cardInner.style.transform = 'rotateY(180deg)';

      // Check if all cards have been flipped to display results panel
      const allFlipped = drawnCards.every(c => c.isFlipped);
      if (allFlipped) {
        setTimeout(showInterpretations, 800);
      }
    });

    // Populate and show the interpretations results panel
    function showInterpretations() {
      resultsList.innerHTML = '';
      
      drawnCards.forEach(card => {
        const item = document.createElement('div');
        item.className = "p-5 sm:p-6 bg-slate-50 dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800/80 space-y-4 animate-fade-in";
        item.innerHTML = `
          <div class="flex items-center gap-3 border-b border-slate-200 dark:border-slate-800 pb-3">
            <span class="text-3xl">${card.cardData.icon}</span>
            <div>
              <span class="text-[10px] font-extrabold text-brand-blue dark:text-brand-mint uppercase tracking-wider block">${card.positionLabel}</span>
              <h4 class="text-lg font-bold text-slate-900 dark:text-white">${card.cardData.name}</h4>
            </div>
          </div>
          
          <p class="text-sm text-slate-600 dark:text-slate-350 leading-relaxed font-semibold italic">
            "${card.cardData.desc}"
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-2">
            <div class="p-3 bg-white dark:bg-brand-darkCard rounded-xl border border-slate-200 dark:border-slate-800/60">
              <span class="block text-xs font-bold text-slate-400 mb-1">❤️ Tình duyên / Mối quan hệ</span>
              <p class="text-xs text-slate-600 dark:text-slate-300 leading-relaxed">${card.cardData.love}</p>
            </div>
            <div class="p-3 bg-white dark:bg-brand-darkCard rounded-xl border border-slate-200 dark:border-slate-800/60">
              <span class="block text-xs font-bold text-slate-400 mb-1">💼 Sự nghiệp / Tài chính</span>
              <p class="text-xs text-slate-600 dark:text-slate-300 leading-relaxed">${card.cardData.career}</p>
            </div>
            <div class="p-3 bg-white dark:bg-brand-darkCard rounded-xl border border-slate-200 dark:border-slate-800/60">
              <span class="block text-xs font-bold text-slate-400 mb-1">💪 Sức khỏe / Tinh thần</span>
              <p class="text-xs text-slate-600 dark:text-slate-300 leading-relaxed">${card.cardData.health}</p>
            </div>
          </div>
        `;
        resultsList.appendChild(item);
      });

      resultsPanel.classList.remove('hidden');
      resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  </script>
</Layout>
