---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Trình Tạo Chữ Ký Email Chuyên Nghiệp Miễn Phí - Trợ Lý Số"
  description="Công cụ tạo chữ ký email HTML chuyên nghiệp trực tuyến. Nhập thông tin, chọn mẫu thiết kế hiện đại và sao chép trực tiếp vào Gmail, Outlook."
>
  <!-- Background Decor -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(37,99,235,0.04),transparent_50%)] pointer-events-none z-0"></div>

  <main class="max-w-6xl mx-auto px-4 py-12 w-full z-10 relative">
    
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="hover:text-brand-blue dark:hover:text-brand-mint">Calculators</span>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Tạo chữ ký Email</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-4">
        Trình Tạo Chữ Ký Email Chuyên Nghiệp
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Tạo chữ ký email HTML chuẩn chỉ, đẹp mắt để chèn vào Outlook, Gmail, Apple Mail giúp tăng uy tín cá nhân và thương hiệu của bạn.
      </p>
    </div>

    <!-- Tool Container -->
    <div class="bg-white dark:bg-brand-darkCard rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 overflow-hidden grid grid-cols-1 lg:grid-cols-12 mb-12 transition-colors">
        
      <!-- Left Inputs (5 cols) -->
      <div class="p-6 sm:p-8 lg:col-span-5 border-b lg:border-b-0 lg:border-r border-slate-200 dark:border-slate-800">
        <h2 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-3">
          📝 Thông tin chữ ký
        </h2>

        <div class="space-y-4">
          <!-- Họ và tên -->
          <div>
            <label for="sigName" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Họ và tên</label>
            <input type="text" id="sigName" value="Nguyễn Văn A" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-semibold text-sm" />
          </div>

          <!-- Chức vụ -->
          <div>
            <label for="sigTitle" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Chức vụ / Vị trí</label>
            <input type="text" id="sigTitle" value="Trưởng phòng Nhân sự" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-sm" />
          </div>

          <!-- Tên công ty -->
          <div>
            <label for="sigCompany" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Tên công ty</label>
            <input type="text" id="sigCompany" value="Trợ Lý Số JSC" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-sm font-semibold" />
          </div>

          <!-- Số điện thoại -->
          <div>
            <label for="sigPhone" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Số điện thoại</label>
            <input type="text" id="sigPhone" value="0981 355 555" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-sm" />
          </div>

          <!-- Email -->
          <div>
            <label for="sigEmail" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Địa chỉ Email</label>
            <input type="email" id="sigEmail" value="contact@trolyso.online" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-sm" />
          </div>

          <!-- Website -->
          <div>
            <label for="sigWebsite" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Website URL</label>
            <input type="text" id="sigWebsite" value="www.trolyso.online" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-sm" />
          </div>

          <!-- Mẫu chữ ký -->
          <div>
            <label for="sigTemplate" class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Mẫu thiết kế</label>
            <select id="sigTemplate" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue text-sm">
              <option value="modern" selected>Modern (Hiện đại, có vạch ngăn)</option>
              <option value="classic">Classic (Cổ điển, dạng khối ngang)</option>
              <option value="minimalist">Minimalist (Tối giản)</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Right Preview (7 cols) -->
      <div class="p-6 sm:p-8 lg:col-span-7 bg-slate-50/50 dark:bg-slate-900/50 flex flex-col justify-between">
        <div>
          <h3 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-6">👁️ Xem trước chữ ký</h3>
          
          <!-- Outer Preview Box -->
          <div class="border border-slate-200 dark:border-slate-800 rounded-xl bg-white p-6 min-h-[180px] flex items-center justify-center overflow-x-auto shadow-inner">
            
            <!-- Real HTML Signature Element (Target for copy) -->
            <div id="signatureContainer" class="bg-white text-slate-800 font-sans text-sm w-full max-w-[500px]">
              <!-- Sẽ được vẽ bằng script -->
            </div>

          </div>
        </div>

        <div class="mt-8 space-y-4">
          <button id="btnCopySignature" class="w-full bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold py-3.5 px-6 rounded-xl transition duration-200 shadow-md flex items-center justify-center gap-2">
            📋 Sao Chép Chữ Ký (Rich HTML)
          </button>
          
          <div class="text-[11px] text-slate-400 leading-normal text-center">
            * Sau khi bấm **Sao chép**, bạn chỉ cần mở phần cài đặt chữ ký của Gmail / Outlook ra và nhấn **Ctrl + V** để dán chữ ký vào.
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>

<script>
  const sigName = document.getElementById('sigName') as HTMLInputElement;
  const sigTitle = document.getElementById('sigTitle') as HTMLInputElement;
  const sigCompany = document.getElementById('sigCompany') as HTMLInputElement;
  const sigPhone = document.getElementById('sigPhone') as HTMLInputElement;
  const sigEmail = document.getElementById('sigEmail') as HTMLInputElement;
  const sigWebsite = document.getElementById('sigWebsite') as HTMLInputElement;
  const sigTemplate = document.getElementById('sigTemplate') as HTMLSelectElement;
  const signatureContainer = document.getElementById('signatureContainer');
  const btnCopySignature = document.getElementById('btnCopySignature');

  function renderSignature() {
    if (!signatureContainer) return;

    const isEn = localStorage.getItem('lang') === 'en';
    const name = sigName.value || (isEn ? 'Full Name' : 'Họ và tên');
    const title = sigTitle.value || (isEn ? 'Job Title' : 'Chức vụ');
    const company = sigCompany.value || (isEn ? 'Company Name' : 'Tên công ty');
    const phone = sigPhone.value || (isEn ? 'Phone Number' : 'Số điện thoại');
    const email = sigEmail.value || 'contact@domain.com';
    const website = sigWebsite.value || 'www.domain.com';
    const template = sigTemplate.value;

    let html = '';

    if (template === 'modern') {
      html = `
        <table cellpadding="0" cellspacing="0" style="font-family: Arial, sans-serif; font-size: 14px; line-height: 1.5; color: #333333; min-width: 320px;">
          <tr>
            <td style="vertical-align: top; padding-right: 15px; border-right: 3px solid #0063b6; padding-bottom: 5px;">
              <strong style="font-size: 18px; color: #0063b6;">${name}</strong>
              <div style="font-size: 13px; color: #666666; font-style: italic; margin-top: 2px;">${title}</div>
              <div style="font-size: 13px; font-weight: bold; color: #333333; margin-top: 4px;">${company}</div>
            </td>
            <td style="vertical-align: top; padding-left: 15px; padding-bottom: 5px; font-size: 13px; color: #555555;">
              <div style="margin-bottom: 3px;">📞 ${isEn ? 'Phone' : 'Phone'}: <a href="tel:${phone}" style="color: #49a2dc; text-decoration: none;">${phone}</a></div>
              <div style="margin-bottom: 3px;">✉️ ${isEn ? 'Email' : 'Email'}: <a href="mailto:${email}" style="color: #49a2dc; text-decoration: none;">${email}</a></div>
              <div>🌐 ${isEn ? 'Web' : 'Web'}: <a href="https://${website}" target="_blank" style="color: #49a2dc; text-decoration: none;">${website}</a></div>
            </td>
          </tr>
        </table>
      `;
    } else if (template === 'classic') {
      html = `
        <table cellpadding="0" cellspacing="0" style="font-family: Georgia, serif; font-size: 14px; line-height: 1.6; color: #222222;">
          <tr>
            <td style="padding-bottom: 8px;">
              <strong style="font-size: 17px; color: #111111;">${name}</strong> | <span style="font-size: 13px; color: #555555;">${title}</span>
              <div style="font-size: 13px; font-weight: bold; color: #777777; margin-top: 2px;">${company}</div>
            </td>
          </tr>
          <tr style="border-top: 1px solid #dddddd;">
            <td style="padding-top: 8px; font-size: 12px; color: #666666; border-top: 1px solid #eeeeee;">
              <span style="margin-right: 15px;"><strong>${isEn ? 'Phone:' : 'Điện thoại:'}</strong> ${phone}</span>
              <span style="margin-right: 15px;"><strong>${isEn ? 'Email:' : 'Email:'}</strong> <a href="mailto:${email}" style="color: #0063b6; text-decoration: none;">${email}</a></span>
              <span><strong>${isEn ? 'Web:' : 'Web:'}</strong> <a href="https://${website}" target="_blank" style="color: #0063b6; text-decoration: none;">${website}</a></span>
            </td>
          </tr>
        </table>
      `;
    } else if (template === 'minimalist') {
      html = `
        <div style="font-family: Arial, sans-serif; font-size: 13px; color: #444444; line-height: 1.4;">
          <div style="font-size: 15px; font-weight: bold; color: #333333; margin-bottom: 2px;">${name}</div>
          <div style="color: #777777; margin-bottom: 6px;">${title} @ ${company}</div>
          <div style="color: #999999;">
            t: ${phone} &nbsp;|&nbsp; e: <a href="mailto:${email}" style="color: #444444; text-decoration: none; font-weight: bold;">${email}</a> &nbsp;|&nbsp; w: <a href="https://${website}" target="_blank" style="color: #444444; text-decoration: none; font-weight: bold;">${website}</a>
          </div>
        </div>
      `;
    }

    signatureContainer.innerHTML = html;
  }

  // Lắng nghe sự kiện để cập nhật preview thời gian thực
  [sigName, sigTitle, sigCompany, sigPhone, sigEmail, sigWebsite, sigTemplate].forEach(input => {
    input.addEventListener('input', renderSignature);
    input.addEventListener('change', renderSignature);
  });

  // Sao chép chữ ký dạng Rich HTML vào Clipboard
  btnCopySignature?.addEventListener('click', async () => {
    if (!signatureContainer) return;

    try {
      const type = "text/html";
      const blob = new Blob([signatureContainer.innerHTML], { type });
      const data = [new ClipboardItem({ [type]: blob })];
      
      await navigator.clipboard.write(data);
      alert("Đã sao chép chữ ký! Hãy mở Outlook/Gmail dán (Ctrl+V) vào ô chữ ký.");
    } catch (err) {
      // Fallback sao chép dạng text thuần
      try {
        await navigator.clipboard.writeText(signatureContainer.innerText);
        alert("Đã sao chép chữ ký dạng chữ thường!");
      } catch (e) {
        alert("Không thể sao chép tự động. Vui lòng tự bôi đen chữ ký và nhấn Ctrl+C!");
      }
    }
  });

  // Vẽ lần đầu tiên
  renderSignature();
</script>
