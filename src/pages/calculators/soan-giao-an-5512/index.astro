---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Công cụ soạn giáo án chuẩn công văn 5512"
  description="Trình soạn giáo án trực tuyến theo khung kế hoạch bài dạy của Công văn 5512 Bộ Giáo dục. Tự động dàn trang, nạp bài mẫu Toán, Văn, Anh và xuất file Word chuẩn xác."
>
  <!-- JSON-LD WebApplication Schema -->
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Công cụ soạn giáo án chuẩn công văn 5512",
      "description": "Ứng dụng giúp giáo viên soạn thảo kế hoạch bài dạy chuẩn khung Phụ lục IV theo Công văn 5512 của Bộ Giáo dục, xuất file Word (.doc) nhanh chóng.",
      "operatingSystem": "All",
      "applicationCategory": "EducationalApplication",
      "browserRequirements": "Requires HTML5, CSS3, JavaScript support",
      "url": "https://trolyso.online/calculators/soan-giao-an-5512/"
    }
  </script>

  <!-- JSON-LD FAQPage Schema -->
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Khung giáo án Công văn 5512 gồm những phần chính nào?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Khung kế hoạch bài dạy ban hành kèm Công văn 5512 gồm 3 phần chính: I. Mục tiêu (Kiến thức, Năng lực, Phẩm chất); II. Thiết bị dạy học và học liệu; III. Tiến trình dạy học (gồm 4 hoạt động học tập chính)."
          }
        },
        {
          "@type": "Question",
          "name": "Bốn bước bắt buộc trong tổ chức thực hiện mỗi hoạt động là gì?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Mỗi hoạt động dạy học phải được tổ chức theo 4 bước: Bước 1: Chuyển giao nhiệm vụ; Bước 2: Thực hiện nhiệm vụ; Bước 3: Báo cáo, thảo luận; Bước 4: Kết luận, nhận định."
          }
        },
        {
          "@type": "Question",
          "name": "Có xuất được giáo án 5512 ra file Word chỉnh sửa được không?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Có. Công cụ của Trợ Lý Số hỗ trợ xuất toàn bộ giáo án đã soạn thảo ra file Word (.doc) giữ nguyên định dạng bảng biểu, font Times New Roman tiêu chuẩn để in ấn nộp tổ chuyên môn."
          }
        }
      ]
    }
  </script>

  <main class="max-w-7xl mx-auto px-4 py-8 text-slate-800 dark:text-slate-200">
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-6" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint font-medium transition">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/calculators/" class="hover:text-brand-blue dark:hover:text-brand-mint font-medium transition">Công cụ</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Soạn giáo án chuẩn công văn 5512</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Title Header -->
    <div class="text-center mb-8">
      <h1 class="text-2xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-3">
        Công cụ soạn giáo án chuẩn công văn 5512
      </h1>
      <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400 max-w-3xl mx-auto">
        Công cụ tạo kế hoạch bài dạy chuẩn cấu trúc Phụ lục IV Công văn 5512/BGDĐT. Hỗ trợ nạp bài học mẫu cực nhanh cho môn Toán, Văn, Anh và xuất file Word miễn phí.
      </p>
    </div>

    <!-- Quick Load Sample Bar -->
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-slate-900/60 dark:to-slate-850/60 p-4 rounded-2xl border border-slate-200/60 dark:border-slate-800/80 mb-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="text-2xl animate-bounce">💡</span>
        <div>
          <h4 class="font-bold text-slate-800 dark:text-slate-200 text-sm">Điền nhanh bài học mẫu để thử nghiệm:</h4>
          <p class="text-xs text-slate-500 dark:text-slate-400">Hệ thống đã viết sẵn 3 giáo án mẫu hoàn chỉnh đúng chuẩn 5512.</p>
        </div>
      </div>
      <div class="w-full sm:w-auto">
        <select id="select-sample" class="w-full sm:w-64 bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2 text-sm outline-none focus:border-brand-blue font-semibold transition">
          <option value="">-- Chọn bài học mẫu --</option>
          <option value="math">📐 Môn Toán: Hàm số lượng giác (Lớp 11)</option>
          <option value="literature">✍️ Môn Ngữ văn: Vợ chồng A Phủ (Lớp 12)</option>
          <option value="english">💬 Môn Tiếng Anh: Unit 1 - Generation Gap (Lớp 11)</option>
        </select>
      </div>
    </div>

    <!-- Main Workspace Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- LEFT COLUMN: Input Form Panels (7 cols) -->
      <div class="lg:col-span-6 space-y-6">
        
        <!-- Section: General Info Card -->
        <details open class="group bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200/60 dark:border-slate-800/60 p-5 shadow-sm">
          <summary class="flex justify-between items-center font-bold text-slate-900 dark:text-white cursor-pointer select-none outline-none list-none text-base">
            <span class="flex items-center gap-2">🏫 I. Thông tin chung</span>
            <span class="text-slate-400 transition-transform duration-300 group-open:rotate-180">↓</span>
          </summary>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Tên trường học</label>
              <input type="text" id="in-school" placeholder="THPT Chuyên Hà Nội - Amsterdam" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Tổ chuyên môn</label>
              <input type="text" id="in-dept" placeholder="Tổ Toán - Tin học" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Họ tên giáo viên</label>
              <input type="text" id="in-teacher" placeholder="Nguyễn Văn A" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Môn học / Lớp</label>
              <input type="text" id="in-subject" placeholder="Toán học - Lớp 11A1" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
            <div class="sm:col-span-2">
              <label class="block text-xs font-semibold text-slate-500 mb-1">Tên bài dạy (Lesson Title)</label>
              <input type="text" id="in-lesson" placeholder="HÀM SỐ LƯỢNG GIÁC VÀ ĐỒ THỊ" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2.5 text-sm font-bold text-slate-800 dark:text-slate-200 outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Thời lượng (Số tiết)</label>
              <input type="text" id="in-duration" placeholder="2 tiết" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
          </div>
        </details>

        <!-- Section: Objectives Card -->
        <details class="group bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200/60 dark:border-slate-800/60 p-5 shadow-sm">
          <summary class="flex justify-between items-center font-bold text-slate-900 dark:text-white cursor-pointer select-none outline-none list-none text-base">
            <span class="flex items-center gap-2">🎯 II. Mục tiêu bài học</span>
            <span class="text-slate-400 transition-transform duration-300 group-open:rotate-180">↓</span>
          </summary>
          <div class="mt-4 space-y-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">1. Kiến thức</label>
              <textarea id="in-obj-knowledge" rows="3" placeholder="- Học sinh phát biểu được định nghĩa hàm số lượng giác..." class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">2. Năng lực</label>
              <textarea id="in-obj-competence" rows="3" placeholder="- Năng lực tự chủ và tự học: Tự nghiên cứu bài giảng qua phiếu học tập...\n- Năng lực toán học: Tư duy và lập luận toán học thông qua vẽ đồ thị..." class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">3. Phẩm chất</label>
              <textarea id="in-obj-quality" rows="3" placeholder="- Chăm chỉ: Tích cực hoàn thành các nhiệm vụ cá nhân và nhóm...\n- Trung thực: Khách quan trong báo cáo kết quả thực hành..." class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
            </div>
          </div>
        </details>

        <!-- Section: Equipment Card -->
        <details class="group bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200/60 dark:border-slate-800/60 p-5 shadow-sm">
          <summary class="flex justify-between items-center font-bold text-slate-900 dark:text-white cursor-pointer select-none outline-none list-none text-base">
            <span class="flex items-center gap-2">🛠️ III. Thiết bị dạy học & học liệu</span>
            <span class="text-slate-400 transition-transform duration-300 group-open:rotate-180">↓</span>
          </summary>
          <div class="mt-4 space-y-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Thiết bị của giáo viên</label>
              <textarea id="in-equip-teacher" rows="2" placeholder="- Máy chiếu, máy tính kết nối internet.\n- Bộ phiếu học tập in sẵn, bảng phụ cho các nhóm." class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Thiết bị/Học liệu của học sinh</label>
              <textarea id="in-equip-student" rows="2" placeholder="- Sách giáo khoa Toán 11, vở ghi chép.\n- Thước kẻ, compa, bút màu vẽ đồ thị." class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
            </div>
          </div>
        </details>

        <!-- Section: Activities Card (Progress) -->
        <details class="group bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200/60 dark:border-slate-800/60 p-5 shadow-sm">
          <summary class="flex justify-between items-center font-bold text-slate-900 dark:text-white cursor-pointer select-none outline-none list-none text-base">
            <span class="flex items-center gap-2">⚡ IV. Tiến trình dạy học (4 Hoạt động)</span>
            <span class="text-slate-400 transition-transform duration-300 group-open:rotate-180">↓</span>
          </summary>
          <div class="mt-4 space-y-6">
            
            <!-- Activity Selector Tabs inside Form -->
            <div class="flex bg-slate-100 dark:bg-slate-900 p-1 rounded-xl">
              <button type="button" id="form-act-tab-1" class="w-1/4 py-1.5 text-xs font-bold rounded-lg bg-white dark:bg-brand-darkCard text-brand-blue dark:text-brand-mint shadow-sm transition">HĐ 1</button>
              <button type="button" id="form-act-tab-2" class="w-1/4 py-1.5 text-xs font-bold rounded-lg text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 transition">HĐ 2</button>
              <button type="button" id="form-act-tab-3" class="w-1/4 py-1.5 text-xs font-bold rounded-lg text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 transition">HĐ 3</button>
              <button type="button" id="form-act-tab-4" class="w-1/4 py-1.5 text-xs font-bold rounded-lg text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 transition">HĐ 4</button>
            </div>

            <!-- Dynamic Activity Input Fields wrapper -->
            <div class="space-y-4">
              <h4 id="act-form-title" class="font-bold text-sm text-slate-400 uppercase tracking-wider">Hoạt động 1: Mở đầu/Khởi động</h4>
              
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">a) Mục tiêu hoạt động</label>
                <textarea id="in-act-goal" rows="2" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">b) Nội dung nhiệm vụ học sinh</label>
                <textarea id="in-act-content" rows="2" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">c) Sản phẩm của học sinh</label>
                <textarea id="in-act-product" rows="2" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y"></textarea>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">d) Các bước thực hiện (Tổ chức dạy học)</label>
                <textarea id="in-act-steps" rows="6" placeholder="Bước 1 (Chuyển giao): GV giao nhiệm vụ...\nBước 2 (Thực hiện): HS hoạt động độc lập...\nBước 3 (Báo cáo): Đại diện nhóm báo cáo...\nBước 4 (Kết luận): GV nhận xét, kết luận..." class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-y font-mono text-xs"></textarea>
              </div>
            </div>

          </div>
        </details>

      </div>

      <!-- RIGHT COLUMN: A4 Real-time Preview & Export Panel (6 cols) -->
      <div class="lg:col-span-6 space-y-6">
        
        <!-- Export Action Bar -->
        <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-slate-800/60 p-4 rounded-2xl shadow-sm flex items-center justify-between gap-4">
          <span class="text-xs font-bold text-slate-500 dark:text-slate-400">Xem trước văn bản A4 và xuất giáo án:</span>
          <button id="btn-export-word" class="bg-gradient-to-r from-blue-600 to-indigo-700 hover:from-blue-700 hover:to-indigo-800 text-white font-bold py-2.5 px-5 rounded-xl shadow-md hover:shadow-lg hover:scale-105 active:scale-95 transition-all duration-300 flex items-center gap-2 text-xs sm:text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Tải File Word (.doc)
          </button>
        </div>

        <!-- A4 Page Container (White page, shadows, fixed padding) -->
        <div class="bg-white dark:bg-white text-black p-8 sm:p-12 shadow-xl border border-slate-200/80 rounded-2xl overflow-y-auto max-h-[800px] font-serif leading-relaxed text-justify text-sm relative" style="font-family: 'Times New Roman', Times, serif; line-height: 1.5;">
          
          <!-- Lesson plan preview DOM content -->
          <div id="preview-document-root" class="space-y-6 text-[13pt] text-black">
            
            <!-- School / Department headers -->
            <table class="w-full border-none m-0 p-0 text-[12pt]">
              <tr class="border-none">
                <td class="w-1/2 text-center border-none p-0">
                  <div id="p-school" class="font-normal uppercase">TRƯỜNG THPT CHUYÊN HÀ NỘI - AMSTERDAM</div>
                  <div id="p-dept" class="font-bold">Tổ Toán - Tin học</div>
                  <div class="w-24 h-px bg-black mx-auto mt-1"></div>
                </td>
                <td class="w-1/2 text-center border-none p-0">
                  <div class="font-bold">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</div>
                  <div class="font-bold">Độc lập - Tự do - Hạnh phúc</div>
                  <div class="w-36 h-px bg-black mx-auto mt-1"></div>
                </td>
              </tr>
            </table>

            <!-- Title -->
            <div class="text-center space-y-1 pt-6">
              <div class="font-normal">KẾ HOẠCH BÀI DẠY (GIÁO ÁN 5512)</div>
              <div class="font-bold text-lg uppercase" id="p-lesson">HÀM SỐ LƯỢNG GIÁC VÀ ĐỒ THỊ</div>
              <div class="font-normal" id="p-meta">Môn học: Toán học - Lớp: 11A1 - Thời lượng: 2 tiết</div>
              <div class="font-normal italic" id="p-teacher">Họ và tên giáo viên: Nguyễn Văn A</div>
            </div>

            <!-- I. Objectives -->
            <div class="space-y-2">
              <h3 class="font-bold text-[14pt]">I. MỤC TIÊU</h3>
              <div class="pl-4 space-y-2">
                <div>
                  <h4 class="font-bold">1. Kiến thức</h4>
                  <div id="p-obj-knowledge" class="whitespace-pre-line pl-4 font-normal text-slate-900">--</div>
                </div>
                <div>
                  <h4 class="font-bold">2. Năng lực</h4>
                  <div id="p-obj-competence" class="whitespace-pre-line pl-4 font-normal text-slate-900">--</div>
                </div>
                <div>
                  <h4 class="font-bold">3. Phẩm chất</h4>
                  <div id="p-obj-quality" class="whitespace-pre-line pl-4 font-normal text-slate-900">--</div>
                </div>
              </div>
            </div>

            <!-- II. Equipment -->
            <div class="space-y-2">
              <h3 class="font-bold text-[14pt]">II. THIẾT BỊ DẠY HỌC VÀ HỌC LIỆU</h3>
              <div class="pl-4 space-y-2">
                <div>
                  <h4 class="font-semibold inline">1. Thiết bị của giáo viên: </h4>
                  <span id="p-equip-teacher" class="whitespace-pre-line font-normal text-slate-900">--</span>
                </div>
                <div>
