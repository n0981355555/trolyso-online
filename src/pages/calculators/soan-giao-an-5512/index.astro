          product: "Học sinh nêu được cảm nghĩ đầu tiên về vùng đất và con người Tây Bắc qua video.",
          steps: "Bước 1 (Chuyển giao): GV chiếu hình ảnh hoa ban, ruộng bậc thang Tây Bắc và đặt câu hỏi khêu gợi cảm xúc.\nBước 2 (Thực hiện): HS quan sát, cảm nhận cá nhân.\nBước 3 (Báo cáo): 2 học sinh phát biểu cảm xúc chia sẻ trước lớp.\nBước 4 (Kết luận): GV dẫn dắt vào bài mới, giới thiệu tác giả Tô Hoài và tác phẩm Vợ chồng A Phủ."
        },
        {
          goal: "Phân tích số phận bi kịch và sức sống tiềm tàng của nhân vật Mị.",
          content: "Đọc diễn cảm đoạn trích, thảo luận nhóm về sự biến đổi tâm lý của Mị trong đêm tình mùa xuân ở Hồng Ngài.",
          product: "Bảng so sánh trạng thái của Mị trước và trong đêm tình mùa xuân (Vẽ sơ đồ tư duy nhóm).",
          steps: "Bước 1 (Chuyển giao): GV phát phiếu học tập số 1, yêu cầu các nhóm phân tích các chi tiết tiếng sáo, hành động Mị uống rượu và chuẩn bị đi chơi.\nBước 2 (Thực hiện): Nhóm HS thảo luận ghi kết quả lên bảng phụ.\nBước 3 (Báo cáo): Đại diện nhóm 1 trình bày, các nhóm khác nhận xét bổ sung.\nBước 4 (Kết luận): GV chốt lại quá trình hồi sinh sức sống của Mị dưới ngòi bút nhân đạo của Tô Hoài."
        },
        {
          goal: "Củng cố kiến thức nghệ thuật xây dựng nhân vật và ngôn ngữ tác phẩm.",
          content: "Viết đoạn văn ngắn (5-7 câu) cảm nhận về hình ảnh tiếng sáo trong đêm mùa xuân.",
          product: "Đoạn văn cảm thụ văn học hoàn chỉnh viết vào vở.",
          steps: "Bước 1 (Chuyển giao): GV giao viết đoạn văn nhanh tại lớp.\nBước 2 (Thực hiện): HS viết cá nhân.\nBước 3 (Báo cáo): Đọc 3 bài viết trước lớp.\nBước 4 (Kết luận): GV nhận xét, cho điểm khuyến khích và uốn nắn cách dùng từ, viết câu văn học."
        },
        {
          goal: "Vận dụng bài học giá trị nhân đạo vào nhận thức thực tế cuộc sống.",
          content: "Sưu tầm các câu chuyện, bài báo nói về các hoạt động hỗ trợ đồng bào dân tộc thiểu số nghèo vùng cao Tây Bắc ngày nay.",
          product: "Danh sách 2-3 chương trình từ thiện xã hội có thông tin tóm tắt ngắn.",
          steps: "Bước 1 (Chuyển giao): GV giao nhiệm vụ tìm kiếm thông tin ngoài giờ lên lớp.\nBước 2 (Thực hiện): HS tự tìm kiếm qua mạng internet.\nBước 3 (Báo cáo): Gửi bài viết ngắn lên trang Padlet của lớp.\nBước 4 (Kết luận): GV kiểm tra, nhận xét tổng kết tinh thần tương thân tương ái của học sinh."
        }
      ]
    },
    english: {
      school: "TRƯỜNG THPT CHUYÊN HÀ NỘI - AMSTERDAM",
      dept: "Foreign Language Department",
      teacher: "MA. Nguyen Thi C",
      subject: "English - Grade 11 (Global Success)",
      lesson: "UNIT 1: GENERATION GAP - GETTING STARTED",
      duration: "1 period (45 minutes)",
      knowledge: "- Students can understand vocabulary related to family rules and generation gaps (nucleur family, extended family, conflict, tradition).\n- Identify the usage of modal verbs (must, have to, should).\n- Practice listening and reading comprehension skills about family discussions.",
      competence: "- Communication and Collaboration: Work in pairs to talk about their own family rules.\n- Critical Thinking: Analyze causes of conflicts between generations in a family.",
      quality: "- Respect: Show respect for different perspectives of family members.\n- Responsibility: Understand their duties and responsibilities in the family.",
      equipTeacher: "- Laptop, projector, slides containing unit pictures.\n- Worksheet 1 for vocabulary matching.",
      equipStudent: "- English Textbook Grade 11, notebook.\n- Mobile phones (for Kahoot quiz if allowed).",
      activities: [
        {
          goal: "Warm up students' interest and lead in the new topic of Generation Gap.",
          content: "Look at pictures of three generations living under one roof, guess the conflicts they may face.",
          product: "Students' verbal answers listing common family arguments (hair style, study hours).",
          steps: "Step 1 (Assign): Teacher shows images of family arguments and asks students to discuss the causes in pairs.\nStep 2 (Perform): Students discuss in English.\nStep 3 (Report): Call 2 students to share their ideas.\nStep 4 (Conclusion): Teacher introduces Unit 1 topic: Generation Gap."
        },
        {
          goal: "Learn vocabulary and modal verbs usage through a conversation context.",
          content: "Listen and read the dialogue between Sam and his grandmother. Complete worksheet matching task.",
          product: "Correct matching results on the worksheet (1.extended family - c, 2.table manners - a...).",
          steps: "Step 1 (Assign): Teacher plays the audio track and distributes worksheet 1.\nStep 2 (Perform): Students listen, read along, and match definitions.\nStep 3 (Report): Students call out answers, teacher checks and displays key.\nStep 4 (Conclusion): Teacher explains core terms and grammar usage of must vs should."
        },
        {
          goal: "Practice using modal verbs to talk about family obligations.",
          content: "Complete sentences using should, must, have to based on the dialogue context.",
          product: "Completed exercise 3 in the textbook written in students' notebooks.",
          steps: "Step 1 (Assign): Teacher requests students to work individually on exercise 3.\nStep 2 (Perform): Students write answers.\nStep 3 (Report): Call 3 students to write answers on board.\nStep 4 (Conclusion): Teacher corrects and concludes the grammar rules."
        },
        {
          goal: "Apply vocabulary and modal verbs to describe students' own family rules.",
          content: "Write a short paragraph (50-60 words) describing 3 main rules in your family.",
          product: "A paragraph containing at least 2 modal verbs (must/should) in student's notebook.",
          steps: "Step 1 (Assign): Teacher assigns the writing task as homework.\nStep 2 (Perform): Students write at home.\nStep 3 (Report): Submit via email/Google Classroom before next lesson.\nStep 4 (Conclusion): Teacher gives feedback on selected writings in the next unit."
        }
      ]
    }
  };

  // State Management
  let activeActIndex = 1; // 1 to 4
  const actsData = [
    { goal: "", content: "", product: "", steps: "" }, // HĐ 1
    { goal: "", content: "", product: "", steps: "" }, // HĐ 2
    { goal: "", content: "", product: "", steps: "" }, // HĐ 3
    { goal: "", content: "", product: "", steps: "" }  // HĐ 4
  ];

  // DOM Input Elements
  const inSchool = document.getElementById("in-school") as HTMLInputElement;
  const inDept = document.getElementById("in-dept") as HTMLInputElement;
  const inTeacher = document.getElementById("in-teacher") as HTMLInputElement;
  const inSubject = document.getElementById("in-subject") as HTMLInputElement;
  const inLesson = document.getElementById("in-lesson") as HTMLInputElement;
  const inDuration = document.getElementById("in-duration") as HTMLInputElement;

  const inKnowledge = document.getElementById("in-obj-knowledge") as HTMLTextAreaElement;
  const inCompetence = document.getElementById("in-obj-competence") as HTMLTextAreaElement;
  const inQuality = document.getElementById("in-obj-quality") as HTMLTextAreaElement;

  const inEquipTeacher = document.getElementById("in-equip-teacher") as HTMLTextAreaElement;
  const inEquipStudent = document.getElementById("in-equip-student") as HTMLTextAreaElement;

  const inActGoal = document.getElementById("in-act-goal") as HTMLTextAreaElement;
  const inActContent = document.getElementById("in-act-content") as HTMLTextAreaElement;
  const inActProduct = document.getElementById("in-act-product") as HTMLTextAreaElement;
  const inActSteps = document.getElementById("in-act-steps") as HTMLTextAreaElement;

  // DOM Preview Elements
  const pSchool = document.getElementById("p-school");
  const pDept = document.getElementById("p-dept");
  const pLesson = document.getElementById("p-lesson");
  const pMeta = document.getElementById("p-meta");
  const pTeacher = document.getElementById("p-teacher");

  const pKnowledge = document.getElementById("p-obj-knowledge");
  const pCompetence = document.getElementById("p-obj-competence");
  const pQuality = document.getElementById("p-obj-quality");

  const pEquipTeacher = document.getElementById("p-equip-teacher");
  const pEquipStudent = document.getElementById("p-equip-student");

  // Selection/Buttons
  const selectSample = document.getElementById("select-sample") as HTMLSelectElement;
  const btnExport = document.getElementById("btn-export-word");
  const actFormTitle = document.getElementById("act-form-title");

  // Activity Form Tabs
  const formTabs = [
    document.getElementById("form-act-tab-1"),
    document.getElementById("form-act-tab-2"),
    document.getElementById("form-act-tab-3"),
    document.getElementById("form-act-tab-4")
  ];

  // Initialize event listeners to sync form data with Preview
  const inputSyncList = [
    { el: inSchool, p: pSchool, def: "TRƯỜNG THPT CHUYÊN HÀ NỘI - AMSTERDAM" },
    { el: inDept, p: pDept, def: "Tổ Toán - Tin học" },
    { el: inLesson, p: pLesson, def: "HÀM SỐ LƯỢNG GIÁC VÀ ĐỒ THỊ" },
    { el: inTeacher, p: pTeacher, def: "Họ và tên giáo viên: Nguyễn Văn A", prefix: "Họ và tên giáo viên: " },
    { el: inKnowledge, p: pKnowledge },
    { el: inCompetence, p: pCompetence },
    { el: inQuality, p: pQuality },
    { el: inEquipTeacher, p: pEquipTeacher },
    { el: inEquipStudent, p: pEquipStudent }
  ];

  inputSyncList.forEach(item => {
    item.el?.addEventListener("input", () => {
      updateSinglePreview(item);
    });
  });

  // Dual fields trigger for Subject & Duration metadata
  function syncMeta() {
    if (pMeta) {
      const sub = inSubject?.value || "Toán học - Lớp 11A1";
      const dur = inDuration?.value || "2 tiết";
      pMeta.textContent = `Môn học: ${sub} - Thời lượng: ${dur}`;
    }
  }
  inSubject?.addEventListener("input", syncMeta);
  inDuration?.addEventListener("input", syncMeta);

  function updateSinglePreview(item: any) {
    if (item.p) {
      let val = item.el.value.trim();
      if (!val && item.def) {
        val = item.def;
      }
      if (item.prefix && val !== item.def) {
        val = item.prefix + val;
      }
      item.p.textContent = val || "--";
    }
  }

  // Activity tabs click listener
  formTabs.forEach((tab, index) => {
    tab?.addEventListener("click", () => {
      // Save current activity form values to state
      saveCurrentActState();

      // Switch active tab styling
      activeActIndex = index + 1;
      formTabs.forEach((t, i) => {
        t?.classList.remove("bg-white", "dark:bg-brand-darkCard", "text-brand-blue", "dark:text-brand-mint", "shadow-sm");
        t?.classList.add("text-slate-500");
      });
      tab.classList.remove("text-slate-500");
      tab.classList.add("bg-white", "dark:bg-brand-darkCard", "text-brand-blue", "dark:text-brand-mint", "shadow-sm");

      // Update form fields title
      if (actFormTitle) {
        const titles = [
          "Hoạt động 1: Xác định vấn đề/Nhiệm vụ học tập/Mở đầu/Khởi động",
          "Hoạt động 2: Hình thành kiến thức mới/giải quyết vấn đề",
          "Hoạt động 3: Luyện tập",
          "Hoạt động 4: Vận dụng"
        ];
        actFormTitle.textContent = titles[index];
      }

      // Load new activity values from state to form inputs
      const data = actsData[index];
      if (inActGoal) inActGoal.value = data.goal;
      if (inActContent) inActContent.value = data.content;
      if (inActProduct) inActProduct.value = data.product;
      if (inActSteps) inActSteps.value = data.steps;
    });
  });

  // Save inputs to actsData state
  function saveCurrentActState() {
    const idx = activeActIndex - 1;
    actsData[idx].goal = inActGoal?.value || "";
    actsData[idx].content = inActContent?.value || "";
    actsData[idx].product = inActProduct?.value || "";
    actsData[idx].steps = inActSteps?.value || "";

    // Sync straight to Preview Panel DOM
    const pGoal = document.getElementById(`p-act${activeActIndex}-goal`);
    const pContent = document.getElementById(`p-act${activeActIndex}-content`);
    const pProduct = document.getElementById(`p-act${activeActIndex}-product`);
    const pSteps = document.getElementById(`p-act${activeActIndex}-steps`);

    if (pGoal) pGoal.textContent = actsData[idx].goal || "--";
    if (pContent) pContent.textContent = actsData[idx].content || "--";
    if (pProduct) pProduct.textContent = actsData[idx].product || "--";
    if (pSteps) pSteps.textContent = actsData[idx].steps || "--";
  }

  // Add listeners to sync current activity inputs instantly to state & preview
  [inActGoal, inActContent, inActProduct, inActSteps].forEach(input => {
    input?.addEventListener("input", () => {
      saveCurrentActState();
    });
  });

  // Load sample template action
  selectSample?.addEventListener("change", () => {
    const key = selectSample.value;
    if (!key) return;

    const data = samples[key as keyof typeof samples];
    if (!data) return;

    // Fill form elements
    if (inSchool) inSchool.value = data.school;
    if (inDept) inDept.value = data.dept;
    if (inTeacher) inTeacher.value = data.teacher;
    if (inSubject) inSubject.value = data.subject;
    if (inLesson) inLesson.value = data.lesson;
    if (inDuration) inDuration.value = data.duration;

    if (inKnowledge) inKnowledge.value = data.knowledge;
    if (inCompetence) inCompetence.value = data.competence;
    if (inQuality) inQuality.value = data.quality;

    if (inEquipTeacher) inEquipTeacher.value = data.equipTeacher;
    if (inEquipStudent) inEquipStudent.value = data.equipStudent;

    // Fill all activity data state
    data.activities.forEach((act, idx) => {
      actsData[idx].goal = act.goal;
      actsData[idx].content = act.content;
      actsData[idx].product = act.product;
      actsData[idx].steps = act.steps;

      // Update previews for all 4 activities
      const pGoal = document.getElementById(`p-act${idx + 1}-goal`);
      const pContent = document.getElementById(`p-act${idx + 1}-content`);
      const pProduct = document.getElementById(`p-act${idx + 1}-product`);
      const pSteps = document.getElementById(`p-act${idx + 1}-steps`);

      if (pGoal) pGoal.textContent = act.goal;
      if (pContent) pContent.textContent = act.content;
      if (pProduct) pProduct.textContent = act.product;
      if (pSteps) pSteps.textContent = act.steps;
    });

    // Reset active tab values to HĐ 1 values
    const actData = actsData[activeActIndex - 1];
    if (inActGoal) inActGoal.value = actData.goal;
    if (inActContent) inActContent.value = actData.content;
    if (inActProduct) inActProduct.value = actData.product;
    if (inActSteps) inActSteps.value = actData.steps;

    // Trigger full manual preview sync
    inputSyncList.forEach(item => updateSinglePreview(item));
    syncMeta();
  });

  // Export to Microsoft Word (.doc) logic
  btnExport?.addEventListener("click", () => {
    const school = inSchool?.value.trim() || "TRƯỜNG THPT CHUYÊN HÀ NỘI - AMSTERDAM";
    const dept = inDept?.value.trim() || "Tổ Toán - Tin học";
    const teacher = inTeacher?.value.trim() || "Nguyễn Văn A";
    const subject = inSubject?.value.trim() || "Toán học - Lớp 11A1";
    const lesson = inLesson?.value.trim() || "HÀM SỐ LƯỢNG GIÁC VÀ ĐỒ THỊ";
    const duration = inDuration?.value.trim() || "2 tiết";

    const knowledge = (inKnowledge?.value.trim() || "--").replace(/\n/g, "<br/>");
    const competence = (inCompetence?.value.trim() || "--").replace(/\n/g, "<br/>");
    const quality = (inQuality?.value.trim() || "--").replace(/\n/g, "<br/>");

    const equipT = (inEquipTeacher?.value.trim() || "--").replace(/\n/g, "<br/>");
    const equipS = (inEquipStudent?.value.trim() || "--").replace(/\n/g, "<br/>");

    // Gather all 4 activities HTML
    const activitiesTitles = [
      "Hoạt động 1: Xác định vấn đề/nhiệm vụ học tập/Mở đầu/Khởi động",
      "Hoạt động 2: Hình thành kiến thức mới/giải quyết vấn đề",
      "Hoạt động 3: Luyện tập",
      "Hoạt động 4: Vận dụng"
    ];

    let activitiesHtml = "";
    actsData.forEach((act, idx) => {
      const g = (act.goal || "--").replace(/\n/g, "<br/>");
      const c = (act.content || "--").replace(/\n/g, "<br/>");
      const p = (act.product || "--").replace(/\n/g, "<br/>");
      const s = (act.steps || "--").replace(/\n/g, "<br/>");

      activitiesHtml += `
        <div style="margin-top: 15pt; margin-bottom: 10pt;">
          <h4 style="font-weight: bold; font-size: 13pt; margin: 0 0 5pt 0;">${activitiesTitles[idx]}</h4>
          <div style="margin-left: 20pt; line-height: 1.5;">
            <p style="margin: 3pt 0;"><strong style="font-weight: bold;">a) Mục tiêu:</strong> ${g}</p>
            <p style="margin: 3pt 0;"><strong style="font-weight: bold;">b) Nội dung:</strong> ${c}</p>
            <p style="margin: 3pt 0;"><strong style="font-weight: bold;">c) Sản phẩm:</strong> ${p}</p>
            <p style="margin: 3pt 0;"><strong style="font-weight: bold;">d) Tổ chức thực hiện:</strong></p>
            <div style="margin-left: 20pt; font-family: 'Courier New', Courier, monospace; font-size: 11pt; background-color: #f9f9f9; padding: 5pt; border: 1px solid #ddd;">
              ${s}
            </div>
          </div>
        </div>
      `;
    });

    const htmlContent = `
      <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
      <head>
        <title>Kế hoạch bài dạy 5512</title>
        <!--[if gte mso 9]>
        <xml>
          <w:WordDocument>
            <w:View>Print</w:View>
            <w:Zoom>100</w:Zoom>
            <w:DoNotOptimizeForBrowser/>
          </w:WordDocument>
        </xml>
        <![endif]-->
        <style>
          @page {
            size: A4;
            margin: 2cm 2cm 2cm 2cm;
          }
          body {
            font-family: "Times New Roman", Times, serif;
            font-size: 13pt;
            line-height: 1.45;
            color: #000000;
          }
          table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12pt;
          }
          td {
            padding: 6pt;
            vertical-align: top;
          }
          h3 {
            font-size: 14pt;
            font-weight: bold;
            margin-top: 18pt;
            margin-bottom: 6pt;
          }
          h4 {
            font-size: 13pt;
            font-weight: bold;
            margin-top: 12pt;
            margin-bottom: 4pt;
          }
        </style>
      </head>
      <body>
        <!-- Header Info -->
        <table style="width: 100%; border: none;">
          <tr style="border: none;">
            <td style="width: 50%; text-align: center; border: none; padding: 0;">
              <div style="text-transform: uppercase;">${school}</div>
              <div style="font-weight: bold;">${dept}</div>
              <div style="margin-top: 2pt;">-----------------</div>
            </td>
            <td style="width: 50%; text-align: center; border: none; padding: 0;">
              <div style="font-weight: bold;">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</div>
              <div style="font-weight: bold;">Độc lập - Tự do - Hạnh phúc</div>
              <div style="margin-top: 2pt;">-----------------------</div>
            </td>
          </tr>
        </table>

        <!-- Title -->
        <div style="text-align: center; margin-top: 25pt; margin-bottom: 25pt;">
          <div style="font-size: 13pt; font-weight: normal;">KẾ HOẠCH BÀI DẠY (GIÁO ÁN CHUẨN 5512)</div>
          <div style="font-size: 16pt; font-weight: bold; text-transform: uppercase; margin-top: 4pt;">${lesson}</div>
          <div style="font-size: 13pt; margin-top: 4pt;">Môn học: ${subject} - Thời lượng: ${duration}</div>
          <div style="font-size: 13pt; font-style: italic; margin-top: 4pt;">Họ và tên giáo viên: ${teacher}</div>
        </div>

        <!-- I. Objectives -->
        <h3>I. MỤC TIÊU</h3>
        <div style="margin-left: 20pt;">
          <h4 style="margin: 6pt 0 3pt 0;">1. Kiến thức</h4>
          <div style="margin-left: 20pt;">${knowledge}</div>
          
          <h4 style="margin: 8pt 0 3pt 0;">2. Năng lực</h4>
          <div style="margin-left: 20pt;">${competence}</div>
          
          <h4 style="margin: 8pt 0 3pt 0;">3. Phẩm chất</h4>
          <div style="margin-left: 20pt;">${quality}</div>
        </div>

        <!-- II. Equipment -->
        <h3>II. THIẾT BỊ DẠY HỌC VÀ HỌC LIỆU</h3>
        <div style="margin-left: 20pt; line-height: 1.5;">
          <p style="margin: 4pt 0;"><strong style="font-weight: bold;">1. Thiết bị của giáo viên:</strong> ${equipT}</p>
          <p style="margin: 4pt 0;"><strong style="font-weight: bold;">2. Thiết bị/học liệu của học sinh:</strong> ${equipS}</p>
        </div>

        <!-- III. Teaching Procedure -->
        <h3>III. TIẾN TRÌNH DẠY HỌC</h3>
        <div style="margin-left: 10pt;">
          ${activitiesHtml}
        </div>
      </body>
      </html>
    `;

    // Download file
    const blob = new Blob([htmlContent], { type: "application/msword;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    // Clean file title for filename
    const cleanTitle = lesson.toLowerCase().replace(/[^a-z0-9\s]/g, "").replace(/\s+/g, "-");
    link.download = `giao-an-5512-${cleanTitle || "lesson-plan"}.doc`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
  });

  // Load default math sample on page load
  window.addEventListener("DOMContentLoaded", () => {
    if (selectSample) {
      selectSample.value = "math";
      const event = new Event("change");
      selectSample.dispatchEvent(event);
    }
  });
</script>
