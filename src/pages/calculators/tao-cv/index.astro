---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Tạo Mẫu CV Xin Việc PDF Đơn Giản - Thiết Kế Online Miễn Phí" 
  description="Công cụ viết và tạo CV xin việc online miễn phí. Xuất file PDF mẫu CV đơn giản, chuyên nghiệp và chuẩn thiết kế thu hút nhà tuyển dụng."
>
  <main class="max-w-7xl mx-auto px-4 py-8 sm:py-12">
    <!-- Breadcrumbs -->
    <nav class="flex mb-6 text-sm text-slate-500 dark:text-slate-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">
            Trang chủ
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/#calculators" class="hover:text-brand-blue dark:hover:text-brand-mint">Calculators</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Tạo CV Xin Việc</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Header Section -->
    <div class="text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white tracking-tight mb-3">
        Tạo Mẫu CV Xin Việc PDF Đơn Giản
      </h1>
      <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Tự viết CV xin việc chuyên nghiệp online chỉ trong 5 phút. Điền thông tin vào form, kiểm tra bản xem trước và tải file PDF chất lượng cao.
      </p>
    </div>

    <!-- Main Tool Container (Flexbox: Fixed inputs width on desktop, flexible preview with scroll fallback) -->
    <div class="flex flex-col lg:flex-row gap-8 items-start mb-12 w-full justify-center">
      
      <!-- Left: Form inputs (Fixed 400px width on desktop to prevent crushing) -->
      <div class="w-full lg:w-[400px] lg:flex-shrink-0 bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200 dark:border-slate-800 p-6 shadow-xl space-y-6 lg:max-h-[92vh] lg:overflow-y-auto">
        <h2 class="text-base font-heading font-bold text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 pb-3">
          ✍️ Nhập Thông Tin CV
        </h2>

        <!-- Personal Info -->
        <div class="space-y-3">
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Thông Tin Cá Nhân</h3>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="cvName" class="block text-[11px] text-slate-450 dark:text-slate-500 mb-1">Họ và Tên</label>
              <input type="text" id="cvName" value="Nguyễn Văn A" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue" />
            </div>
            <div>
              <label for="cvTitle" class="block text-[11px] text-slate-450 dark:text-slate-500 mb-1">Vị trí ứng tuyển</label>
              <input type="text" id="cvTitle" value="Nhân viên Hành chính" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="cvEmail" class="block text-[11px] text-slate-450 dark:text-slate-500 mb-1">Email</label>
              <input type="email" id="cvEmail" value="nguyenvana@gmail.com" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-brand-blue" />
            </div>
            <div>
              <label for="cvPhone" class="block text-[11px] text-slate-450 dark:text-slate-500 mb-1">Số điện thoại</label>
              <input type="text" id="cvPhone" value="0987.654.321" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-brand-blue" />
            </div>
          </div>
          <div>
            <label for="cvAddress" class="block text-[11px] text-slate-450 dark:text-slate-500 mb-1">Địa chỉ</label>
            <input type="text" id="cvAddress" value="Quận Cầu Giấy, Hà Nội" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-brand-blue" />
          </div>
          <div>
            <label for="cvSummary" class="block text-[11px] text-slate-450 dark:text-slate-500 mb-1">Giới thiệu ngắn bản thân</label>
            <textarea id="cvSummary" rows="3" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-brand-blue">Tốt nghiệp chuyên ngành Quản trị Văn phòng, có 2 năm kinh nghiệm trong các tác vụ hành chính, sắp xếp lịch trình và quản lý hồ sơ tài liệu doanh nghiệp. Mong muốn đóng góp năng lực quản trị hiệu quả.</textarea>
          </div>
        </div>

        <!-- Experience Items -->
        <div class="space-y-4 pt-4 border-t border-slate-100 dark:border-slate-800">
          <div class="flex justify-between items-center">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Kinh Nghiệm Làm Việc</h3>
            <button id="btnAddExp" class="text-xs font-bold text-brand-blue dark:text-brand-mint hover:underline">+ Thêm mới</button>
          </div>
          <div id="expInputsList" class="space-y-4">
            <!-- Dynamic elements populated via JS -->
          </div>
        </div>

        <!-- Education Items -->
        <div class="space-y-4 pt-4 border-t border-slate-100 dark:border-slate-800">
          <div class="flex justify-between items-center">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Học Vấn</h3>
            <button id="btnAddEdu" class="text-xs font-bold text-brand-blue dark:text-brand-mint hover:underline">+ Thêm mới</button>
          </div>
          <div id="eduInputsList" class="space-y-4">
            <!-- Dynamic elements populated via JS -->
          </div>
        </div>

        <!-- Skills Tag string -->
        <div class="pt-4 border-t border-slate-100 dark:border-slate-800 space-y-2">
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Kỹ Năng</h3>
          <label for="cvSkills" class="block text-[11px] text-slate-450 dark:text-slate-500 mb-1">Các kỹ năng (cách nhau bởi dấu phẩy)</label>
          <input type="text" id="cvSkills" value="Tin học văn phòng MS Office, Soạn thảo văn bản, Kỹ năng giao tiếp, Sắp xếp quản lý hồ sơ" class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-brand-blue" />
        </div>

        <!-- Update Preview Action Button -->
        <div class="pt-4 border-t border-slate-100 dark:border-slate-800">
          <button id="btnUpdatePreview" class="w-full py-3.5 bg-brand-blue hover:bg-brand-blue/90 text-white font-extrabold rounded-xl text-xs sm:text-sm shadow-md transition flex items-center justify-center gap-2">
            👉 ĐIỀN THÔNG TIN & XEM TRƯỚC
          </button>
        </div>
      </div>

      <!-- Right: A4 CV Preview (Flexible width, centers paper, handles overflow scrollbar) -->
      <div class="flex-grow w-full flex flex-col items-center overflow-hidden">
        <div class="flex flex-col sm:flex-row sm:justify-between items-center w-full max-w-[210mm] mb-4 gap-3 px-2">
          <h3 class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
            Bản xem trước A4 (Preview)
          </h3>
          <button id="btnExportPDF" class="px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-white font-extrabold rounded-xl text-xs shadow-md transition flex items-center gap-1.5 disabled:opacity-50">
            📥 TẢI FILE CV VỀ MÁY (PDF)
          </button>
        </div>
        
        <!-- Scroll Wrapper (triggers horizontal scrollbar ONLY when screen is narrower than 210mm) -->
        <div class="w-full overflow-x-auto pb-4 flex justify-start lg:justify-center">
          <!-- CV Document Paper Container -->
          <div id="cvPaper" class="w-[210mm] min-h-[297mm] bg-white text-slate-800 shadow-2xl p-10 border border-slate-100 rounded-sm overflow-hidden text-left relative flex flex-col justify-between leading-normal text-xs font-sans flex-shrink-0">
            
            <!-- Outer flex content -->
            <div>
              <!-- Header Section (Candidate name, title, contact details) -->
              <div class="border-b-2 border-slate-800 pb-5 mb-6 flex justify-between items-end">
                <div>
                  <h1 id="pvName" class="text-3xl font-bold tracking-tight text-slate-900 mb-1">Nguyễn Văn A</h1>
                  <span id="pvTitle" class="text-base font-semibold text-slate-600 uppercase tracking-wider block">Nhân viên Hành chính</span>
                </div>
                <div class="text-right text-[11px] text-slate-500 space-y-0.5">
                  <div id="pvPhone">📞 0987.654.321</div>
                  <div id="pvEmail">✉ nguyenvana@gmail.com</div>
                  <div id="pvAddress">📍 Quận Cầu Giấy, Hà Nội</div>
                </div>
              </div>

              <!-- Main grid inside CV paper -->
              <div class="grid grid-cols-3 gap-8">
                <!-- Left Sidebar: Summary and Skills (1 col) -->
                <div class="col-span-1 border-r border-slate-200 pr-6 space-y-6">
                  <!-- Summary -->
                  <div>
                    <h3 class="font-bold text-slate-900 uppercase tracking-wider border-b border-slate-350 pb-1 mb-2.5">Giới Thiệu</h3>
                    <p id="pvSummary" class="text-slate-600 leading-relaxed text-[11px]">Tốt nghiệp chuyên ngành Quản trị Văn phòng, có 2 năm kinh nghiệm trong các tác vụ hành chính, sắp xếp lịch trình và quản lý hồ sơ tài liệu doanh nghiệp. Mong muốn đóng góp năng lực quản trị hiệu quả.</p>
                  </div>

                  <!-- Skills -->
                  <div>
                    <h3 class="font-bold text-slate-900 uppercase tracking-wider border-b border-slate-350 pb-1 mb-2.5">Kỹ Năng</h3>
                    <ul id="pvSkills" class="space-y-1.5 list-disc pl-4 text-slate-600 text-[11px]">
                      <!-- Rendered tags -->
                    </ul>
                  </div>
                </div>

                <!-- Right: Experience and Education (2 cols) -->
                <div class="col-span-2 space-y-6">
                  <!-- Experience -->
                  <div>
                    <h3 class="font-bold text-slate-900 uppercase tracking-wider border-b border-slate-350 pb-1 mb-3">Kinh Nghiệm Làm Việc</h3>
                    <div id="pvExpList" class="space-y-4">
                      <!-- Populated dynamically -->
                    </div>
                  </div>

                  <!-- Education -->
                  <div>
                    <h3 class="font-bold text-slate-900 uppercase tracking-wider border-b border-slate-350 pb-1 mb-3">Học Vấn</h3>
                    <div id="pvEduList" class="space-y-4">
                      <!-- Populated dynamically -->
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Footer brand sign-off -->
            <div class="border-t border-slate-100 pt-3 text-[10px] text-slate-400 text-center flex justify-between items-center">
              <span>CV được thiết kế miễn phí qua trolyso.online</span>
              <span>Trang 1 / 1</span>
            </div>

          </div>
        </div>
      </div>
      
    </div>

    <!-- Handbook Guide Section -->
    <section class="max-w-4xl mx-auto bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200 dark:border-slate-800 p-8 shadow-sm">
      <h2 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-6">
        Cẩm Nang Thiết Kế CV Xin Việc Chuyên Nghiệp
      </h2>
      
      <div class="prose dark:prose-invert max-w-none text-slate-600 dark:text-slate-300 leading-relaxed space-y-4 text-sm">
        <p>
          CV (Curriculum Vitae) là tấm vé thông hành đầu tiên giúp bạn tiếp cận nhà tuyển dụng. Thiết kế một mẫu CV đơn giản, chỉn chu và đầy đủ thông tin cốt lõi là chiến lược tốt nhất giúp hồ sơ của bạn nổi bật hơn 90% ứng viên khác.
        </p>

        <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-6">1. Nguyên tắc thiết kế CV đơn giản (Minimalist CV)</h3>
        <p>
          Thay vì sử dụng các màu sắc sặc sỡ và nhiều hình trang trí rườm rà, các tập đoàn đa quốc gia và HR chuyên nghiệp luôn ưa chuộng các mẫu CV có thiết kế đơn giản, phân chia hình học gọn gàng và sử dụng tối đa 2 tông màu chính.
        </p>
        <blockquote class="border-l-4 border-slate-800 bg-slate-50 dark:bg-slate-900/60 p-4 my-4 rounded-r-xl text-slate-700 dark:text-slate-350">
          Mẫu CV A4 của chúng tôi tuân thủ quy chuẩn bố cục tinh gọn toàn cầu. Sử dụng hệ font serif/sans-serif kết hợp sắc nét, phân vùng thông tin cân đối để người phỏng vấn nắm bắt năng lực của bạn chỉ trong 6 giây đầu tiên.
        </blockquote>

        <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-6">2. Cách mô tả kinh nghiệm làm việc thu hút</h3>
        <ul class="list-disc pl-5 space-y-1">
          <li>Sắp xếp kinh nghiệm theo thứ tự thời gian đảo ngược (công việc gần nhất đặt trên đầu).</li>
          <li>Sử dụng các động từ hành động mạnh (như: Quản lý, Xây dựng, Cải tiến, Tối ưu hóa).</li>
          <li>Đo lường thành tích bằng các con số cụ thể (Ví dụ: "Tăng 25% doanh số trong 6 tháng" hoặc "Giảm thiểu 15% chi phí vận hành văn phòng").</li>
        </ul>
      </div>
    </section>

    <!-- Related Tools & Articles -->
    <section class="max-w-4xl mx-auto mt-8 bg-slate-50 dark:bg-slate-900/40 rounded-2xl border border-slate-200 dark:border-slate-800 p-6 sm:p-8 transition-colors">
      <h3 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-4">
        Các công cụ & cẩm nang liên quan:
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
        <a href="/calculators/tao-van-ban/" class="flex items-center gap-3 p-4 bg-white dark:bg-brand-darkCard rounded-xl border border-slate-200 dark:border-slate-800 hover:shadow-md hover:border-brand-blue dark:hover:border-brand-mint transition">
          <span class="text-2xl">📝</span>
          <div>
            <span class="block font-bold text-slate-800 dark:text-slate-200">Tạo Văn Bản Hành Chính</span>
            <span class="text-xs text-slate-450 dark:text-slate-500">Soạn thảo văn bản theo Nghị định 30</span>
          </div>
        </a>
        <a href="/blog/huong-dan-tao-mau-cv-xin-viec-pdf-don-gian/" class="flex items-center gap-3 p-4 bg-white dark:bg-brand-darkCard rounded-xl border border-slate-200 dark:border-slate-800 hover:shadow-md hover:border-brand-blue dark:hover:border-brand-mint transition">
          <span class="text-2xl">📖</span>
          <div>
            <span class="block font-bold text-slate-800 dark:text-slate-200">Cẩm nang tạo mẫu CV đẹp</span>
            <span class="text-xs text-slate-450 dark:text-slate-500">Mẹo viết CV thu hút nhà tuyển dụng online</span>
          </div>
        </a>
      </div>
    </section>
  </main>

  <!-- Load html2pdf for pixel-perfect PDF rendering of cvPaper -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

  <script>
    // State lists
    let expList = [
      { id: 1, company: 'Công ty Cổ phần X', title: 'Nhân viên Hành chính Tổng hợp', date: '01/2024 - Hiện tại', desc: 'Quản lý văn thư lưu trữ, soạn thảo các thông báo hành chính nội bộ chính xác. Tổ chức sắp xếp hồ sơ và điều hành đội ngũ văn phòng suôn sẻ.' }
    ];

    let eduList = [
      { id: 1, school: 'Đại học Khoa học Xã hội và Nhân văn', degree: 'Cử nhân Quản trị Văn phòng', date: '2020 - 2024', desc: 'Tốt nghiệp loại Giỏi. Nghiên cứu sâu về quy trình tối ưu hóa hành chính công và tin học văn phòng nâng cao.' }
    ];

    // DOM inputs
    const cvName = document.getElementById('cvName');
    const cvTitle = document.getElementById('cvTitle');
    const cvEmail = document.getElementById('cvEmail');
    const cvPhone = document.getElementById('cvPhone');
    const cvAddress = document.getElementById('cvAddress');
    const cvSummary = document.getElementById('cvSummary');
    const cvSkills = document.getElementById('cvSkills');

    // DOM displays
    const pvName = document.getElementById('pvName');
    const pvTitle = document.getElementById('pvTitle');
    const pvEmail = document.getElementById('pvEmail');
    const pvPhone = document.getElementById('pvPhone');
    const pvAddress = document.getElementById('pvAddress');
    const pvSummary = document.getElementById('pvSummary');
    const pvSkills = document.getElementById('pvSkills');

    const expInputsList = document.getElementById('expInputsList');
    const pvExpList = document.getElementById('pvExpList');
    const btnAddExp = document.getElementById('btnAddExp');

    const eduInputsList = document.getElementById('eduInputsList');
    const pvEduList = document.getElementById('pvEduList');
    const btnAddEdu = document.getElementById('btnAddEdu');

    const btnUpdatePreview = document.getElementById('btnUpdatePreview');
    const btnExportPDF = document.getElementById('btnExportPDF');
    const cvPaper = document.getElementById('cvPaper');

    // Updates displays by copying inputs
    function updateBasicFields() {
      pvName.textContent = cvName.value || 'Tên Của Bạn';
      pvTitle.textContent = cvTitle.value || 'Vị trí ứng tuyển';
      pvEmail.textContent = cvEmail.value ? `✉ ${cvEmail.value}` : '✉ email@gmail.com';
      pvPhone.textContent = cvPhone.value ? `📞 ${cvPhone.value}` : '📞 0900.000.000';
      pvAddress.textContent = cvAddress.value ? `📍 ${cvAddress.value}` : '📍 Địa chỉ liên lạc';
      pvSummary.textContent = cvSummary.value || 'Tóm tắt giới thiệu bản thân...';

      // Skills
      pvSkills.innerHTML = '';
      const tags = cvSkills.value.split(',').map(s => s.trim()).filter(s => s.length > 0);
      tags.forEach(tag => {
        const li = document.createElement('li');
        li.textContent = tag;
        pvSkills.appendChild(li);
      });
    }

    // Populate Experience Forms inputs
    function renderExperiences() {
      expInputsList.innerHTML = '';
      expList.forEach((exp, index) => {
        const div = document.createElement('div');
        div.className = "p-4 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 relative space-y-2";
        div.innerHTML = `
          <button class="absolute top-2 right-2 text-red-500 text-xs font-bold hover:underline" onclick="this.dispatchEvent(new CustomEvent('remove-exp', {bubbles: true, detail: ${exp.id}}))">✕ Xóa</button>
          <div>
            <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Tên công ty / Cơ quan</label>
            <input type="text" value="${exp.company}" class="inp-company w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-bold" />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Chức danh</label>
              <input type="text" value="${exp.title}" class="inp-title w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-semibold" />
            </div>
            <div>
              <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Thời gian</label>
              <input type="text" value="${exp.date}" class="inp-date w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-semibold" />
            </div>
          </div>
          <div>
            <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Mô tả công việc</label>
            <textarea rows="2" class="inp-desc w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-semibold">${exp.desc}</textarea>
          </div>
        `;

        // Update states on input
        div.querySelector('.inp-company').addEventListener('input', (e) => { expList[index].company = e.target.value; });
        div.querySelector('.inp-title').addEventListener('input', (e) => { expList[index].title = e.target.value; });
        div.querySelector('.inp-date').addEventListener('input', (e) => { expList[index].date = e.target.value; });
        div.querySelector('.inp-desc').addEventListener('input', (e) => { expList[index].desc = e.target.value; });

        expInputsList.appendChild(div);
      });
    }

    function renderExperiencesPreview() {
      pvExpList.innerHTML = '';
      expList.forEach(exp => {
        const item = document.createElement('div');
        item.className = "space-y-1";
        item.innerHTML = `
          <div class="flex justify-between items-baseline font-semibold text-[11px] text-slate-900">
            <span class="font-bold">${exp.company}</span>
            <span class="text-slate-500 font-normal font-mono">${exp.date}</span>
          </div>
          <div class="text-[10.5px] italic text-slate-700 font-semibold mb-1">${exp.title}</div>
          <p class="text-slate-600 leading-relaxed text-[11px] whitespace-pre-line">${exp.desc}</p>
        `;
        pvExpList.appendChild(item);
      });
    }

    // Populate Education Forms inputs
    function renderEducations() {
      eduInputsList.innerHTML = '';
      eduList.forEach((edu, index) => {
        const div = document.createElement('div');
        div.className = "p-4 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 relative space-y-2";
        div.innerHTML = `
          <button class="absolute top-2 right-2 text-red-500 text-xs font-bold hover:underline" onclick="this.dispatchEvent(new CustomEvent('remove-edu', {bubbles: true, detail: ${edu.id}}))">✕ Xóa</button>
          <div>
            <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Tên trường học / Cơ sở đào tạo</label>
            <input type="text" value="${edu.school}" class="inp-school w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-bold" />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Bằng cấp / Ngành học</label>
              <input type="text" value="${edu.degree}" class="inp-degree w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-semibold" />
            </div>
            <div>
              <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Thời gian học</label>
              <input type="text" value="${edu.date}" class="inp-date w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-semibold" />
            </div>
          </div>
          <div>
            <label class="block text-[10px] text-slate-450 dark:text-slate-500 mb-0.5">Thành tích / Mô tả</label>
            <textarea rows="2" class="inp-desc w-full px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-850 bg-white dark:bg-brand-darkCard text-xs font-semibold">${edu.desc}</textarea>
          </div>
        `;

        // Update states on input
        div.querySelector('.inp-school').addEventListener('input', (e) => { eduList[index].school = e.target.value; });
        div.querySelector('.inp-degree').addEventListener('input', (e) => { eduList[index].degree = e.target.value; });
        div.querySelector('.inp-date').addEventListener('input', (e) => { eduList[index].date = e.target.value; });
        div.querySelector('.inp-desc').addEventListener('input', (e) => { eduList[index].desc = e.target.value; });

        eduInputsList.appendChild(div);
      });
    }

    function renderEducationsPreview() {
      pvEduList.innerHTML = '';
      eduList.forEach(edu => {
        const item = document.createElement('div');
        item.className = "space-y-1";
        item.innerHTML = `
          <div class="flex justify-between items-baseline font-semibold text-[11px] text-slate-900">
            <span class="font-bold">${edu.school}</span>
            <span class="text-slate-500 font-normal font-mono">${edu.date}</span>
          </div>
          <div class="text-[10.5px] italic text-slate-700 font-semibold mb-1">${edu.degree}</div>
          <p class="text-slate-600 leading-relaxed text-[11px] whitespace-pre-line">${edu.desc}</p>
        `;
        pvEduList.appendChild(item);
      });
    }

    // Add triggers
    btnAddExp.addEventListener('click', () => {
      const newId = expList.length > 0 ? Math.max(...expList.map(e => e.id)) + 1 : 1;
      expList.push({
        id: newId,
        company: 'Tên Công ty Mới',
        title: 'Chức danh công việc',
        date: '01/2024 - 06/2024',
        desc: 'Mô tả tóm tắt kinh nghiệm...'
      });
      renderExperiences();
    });

    btnAddEdu.addEventListener('click', () => {
      const newId = eduList.length > 0 ? Math.max(...eduList.map(e => e.id)) + 1 : 1;
      eduList.push({
        id: newId,
        school: 'Tên Trường học Mới',
        degree: 'Chuyên ngành học',
        date: '2020 - 2024',
        desc: 'Mô tả học tập, điểm số hoặc giải thưởng...'
      });
      renderEducations();
    });

    // Delete delegates
    document.addEventListener('remove-exp', (e) => {
      expList = expList.filter(exp => exp.id !== e.detail);
      renderExperiences();
    });

    document.addEventListener('remove-edu', (e) => {
      eduList = eduList.filter(edu => edu.id !== e.detail);
      renderEducations();
    });

    // Consolidated Preview Refresher
    function updateAllPreview() {
      updateBasicFields();
      renderExperiencesPreview();
      renderEducationsPreview();

      // Visual indicator on button
      if (btnUpdatePreview) {
        const originalHTML = btnUpdatePreview.innerHTML;
        btnUpdatePreview.innerHTML = '✓ ĐÃ CẬP NHẬT BẢN XEM TRƯỚC';
        btnUpdatePreview.classList.replace('bg-brand-blue', 'bg-emerald-500');
        setTimeout(() => {
          btnUpdatePreview.innerHTML = originalHTML;
          btnUpdatePreview.classList.replace('bg-emerald-500', 'bg-brand-blue');
        }, 1500);
      }
    }

    btnUpdatePreview.addEventListener('click', updateAllPreview);

    // Export PDF
    btnExportPDF.addEventListener('click', () => {
      btnExportPDF.disabled = true;
      btnExportPDF.textContent = 'ĐANG TẢI...';

      const options = {
        margin: 0,
        filename: `${cvName.value.replace(/\s+/g, '-').toLowerCase()}-cv.pdf`,
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2.5, useCORS: true },
        jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' }
      };

      html2pdf()
        .from(cvPaper)
        .set(options)
        .save()
        .then(() => {
          btnExportPDF.disabled = false;
          btnExportPDF.textContent = '📥 TẢI FILE CV VỀ MÁY (PDF)';
        })
        .catch(err => {
          console.error(err);
          alert('Lỗi xuất file PDF.');
          btnExportPDF.disabled = false;
          btnExportPDF.textContent = '📥 TẢI FILE CV VỀ MÁY (PDF)';
        });
    });

    // Init values
    updateAllPreview();
    renderExperiences();
    renderEducations();
  </script>
</Layout>
