  ];

  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('industrySearch');
    const resultsBody = document.getElementById('resultsBody');
    const resultsCount = document.getElementById('resultsCount');
    const emptyState = document.getElementById('emptyState');
    const btnClearSearch = document.getElementById('btnClearSearch');

    function removeVietnameseTones(str) {
      let result = str.toLowerCase();
      result = result.replace(/à|á|ạ|ả|ã|â|ầ|ấ|ậ|ẩ|ẫ|ă|ằ|ắ|ặ|ẳ|ẵ/g, "a");
      result = result.replace(/è|é|ẹ|ẻ|ẽ|ê|ề|ế|ệ|ể|ễ/g, "e");
      result = result.replace(/ì|í|ị|ỉ|ĩ/g, "i");
      result = result.replace(/ò|ó|ọ|ỏ|õ|ô|ồ|ố|ộ|ổ|ỗ|ơ|ờ|ớ|ợ|ở|ỡ/g, "o");
      result = result.replace(/ù|ú|ụ|ủ|ũ|ư|ừ|ứ|ự|ử|ữ/g, "u");
      result = result.replace(/ỳ|ý|ỵ|ỷ|ỹ/g, "y");
      result = result.replace(/đ/g, "d");
      return result;
    }

    function renderResults(filtered) {
      resultsBody.innerHTML = '';
      
      if (filtered.length === 0) {
        emptyState.classList.remove('hidden');
        resultsCount.textContent = '0';
        return;
      }
      
      emptyState.classList.add('hidden');
      resultsCount.textContent = filtered.length.toString();

      // Check current language
      const isEn = localStorage.getItem('lang') === 'en';
      const copyText = isEn ? 'Copy' : 'Sao chép';
      const copiedText = isEn ? 'Copied' : 'Đã chép';

      filtered.forEach(item => {
        const row = document.createElement('tr');
        row.className = 'hover:bg-slate-50 dark:hover:bg-slate-900/30 transition duration-150';
        row.innerHTML = `
          <td class="p-4 font-extrabold text-brand-blue dark:text-brand-mint text-base">${item.code}</td>
          <td class="p-4 font-bold text-slate-800 dark:text-slate-100">${item.name}</td>
          <td class="p-4 text-slate-500 dark:text-slate-400 text-xs">${item.desc}</td>
          <td class="p-4 text-center">
            <button 
              class="copy-btn px-2.5 py-1.5 bg-slate-100 hover:bg-brand-blue hover:text-white dark:bg-slate-800 dark:hover:bg-brand-mint dark:hover:text-slate-900 text-slate-700 dark:text-slate-300 rounded-lg text-xs font-bold transition-all flex items-center gap-1 mx-auto"
              data-code="${item.code}"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" /></svg>
              <span>${copyText}</span>
            </button>
          </td>
        `;
        resultsBody.appendChild(row);
      });

      // Hook copy action
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const code = btn.getAttribute('data-code');
          navigator.clipboard.writeText(code).then(() => {
            const span = btn.querySelector('span');
            span.textContent = copiedText;
            btn.classList.add('bg-emerald-500', 'text-white', 'dark:bg-emerald-500');
            setTimeout(() => {
              span.textContent = copyText;
              btn.classList.remove('bg-emerald-500', 'text-white', 'dark:bg-emerald-500');
            }, 1500);
          });
        });
      });
    }

    // Initial render
    renderResults(vsicData);

    // Search input event listener
    searchInput.addEventListener('input', () => {
      const val = removeVietnameseTones(searchInput.value.trim());
      
      if (val === '') {
        renderResults(vsicData);
        btnClearSearch.classList.add('hidden');
        return;
      }
      
      btnClearSearch.classList.remove('hidden');
      
      const filtered = vsicData.filter(item => {
        return removeVietnameseTones(item.code).includes(val) || 
               removeVietnameseTones(item.name).includes(val) || 
               removeVietnameseTones(item.desc).includes(val);
      });
      
      renderResults(filtered);
    });

    // Clear search
    btnClearSearch.addEventListener('click', () => {
      searchInput.value = '';
      btnClearSearch.classList.add('hidden');
      renderResults(vsicData);
      searchInput.focus();
    });
  });
</script>
