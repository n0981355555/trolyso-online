<script>
  function calculateOvertime() {
    // 1. Inputs
    const basicSalary = parseFloat((document.getElementById("basicSalary") as HTMLInputElement).value) || 0;
    const standardDays = parseFloat((document.getElementById("standardDays") as HTMLSelectElement).value) || 26;
    const holidayPayType = (document.getElementById("holidayPayType") as HTMLSelectElement).value;

    const hoursND = parseFloat((document.getElementById("hoursNormalDay") as HTMLInputElement).value) || 0;
    const hoursNN = parseFloat((document.getElementById("hoursNormalNight") as HTMLInputElement).value) || 0;
    
    const hoursWD = parseFloat((document.getElementById("hoursWeekendDay") as HTMLInputElement).value) || 0;
    const hoursWN = parseFloat((document.getElementById("hoursWeekendNight") as HTMLInputElement).value) || 0;
    
    const hoursHD = parseFloat((document.getElementById("hoursHolidayDay") as HTMLInputElement).value) || 0;
    const hoursHN = parseFloat((document.getElementById("hoursHolidayNight") as HTMLInputElement).value) || 0;

    // 2. Base hourly rate calculation
    const hourlyRate = basicSalary / (standardDays * 8);
    document.getElementById("resHourlyRate")!.textContent = formatCurrency(hourlyRate) + " VND/giờ";

    // 3. Coefficients based on Law
    const coefND = 1.5;
    const coefNN = 2.1; // 1.5 + 0.3 + 1.5 * 0.2
    const coefWD = 2.0;
    const coefWN = 2.7; // 2.0 + 0.3 + 2.0 * 0.2
    
    // Holiday Coefficient
    let coefHD = 3.0;
    let coefHN = 3.9; // 3.0 + 0.3 + 3.0 * 0.2
    
    if (holidayPayType === "monthly") {
      // If monthly worker, holiday is paid 100% standard salary (this is regular pay, so the overtime pay rate itself is 3.0 but the total received including regular pay is 4.0).
      // Note: Article 98 says overtime pay itself is at least 300%. The UI should show the overtime pay rate (300%) or total including regular pay.
      // Let's stick to the overtime pay rates: 300% (daytime) and 390% (nighttime) to calculate the overtime premium, and clearly display that this is in addition to the monthly salary.
      coefHD = 3.0;
      coefHN = 3.9;
      
      document.getElementById("tdCoefHD")!.textContent = "300% (+100% lương tháng)";
      document.getElementById("tdCoefHN")!.textContent = "390% (+100% lương tháng)";
    } else {
      coefHD = 3.0;
      coefHN = 3.9;
      document.getElementById("tdCoefHD")!.textContent = "300%";
      document.getElementById("tdCoefHN")!.textContent = "390%";
    }

    // 4. Calculations
    const amountND = hoursND * hourlyRate * coefND;
    const amountNN = hoursNN * hourlyRate * coefNN;
    const amountWD = hoursWD * hourlyRate * coefWD;
    const amountWN = hoursWN * hourlyRate * coefWN;
    const amountHD = hoursHD * hourlyRate * coefHD;
    const amountHN = hoursHN * hourlyRate * coefHN;

    const totalOvertime = amountND + amountNN + amountWD + amountWN + amountHD + amountHN;
    const totalIncome = basicSalary + totalOvertime;

    // 5. Update UI values
    updateRow("tdHoursND", "tdAmountND", hoursND, amountND);
    updateRow("tdHoursNN", "tdAmountNN", hoursNN, amountNN);
    updateRow("tdHoursWD", "tdAmountWD", hoursWD, amountWD);
    updateRow("tdHoursWN", "tdAmountWN", hoursWN, amountWN);
    updateRow("tdHoursHD", "tdAmountHD", hoursHD, amountHD);
    updateRow("tdHoursHN", "tdAmountHN", hoursHN, amountHN);

    document.getElementById("resTotalOvertime")!.textContent = formatCurrency(totalOvertime) + " VND";
    document.getElementById("resTotalIncome")!.textContent = formatCurrency(totalIncome) + " VND";
  }

  function updateRow(hoursId: string, amountId: string, hours: number, amount: number) {
    document.getElementById(hoursId)!.textContent = hours + " giờ";
    document.getElementById(amountId)!.textContent = formatCurrency(amount) + " VND";
  }

  function formatCurrency(num: number) {
    return Math.round(num).toLocaleString('vi-VN');
  }

  // Bind Events
  const inputs = ["basicSalary", "standardDays", "holidayPayType", 
                  "hoursNormalDay", "hoursNormalNight", 
                  "hoursWeekendDay", "hoursWeekendNight", 
                  "hoursHolidayDay", "hoursHolidayNight"];
  inputs.forEach(id => {
    const el = document.getElementById(id);
    el?.addEventListener("change", calculateOvertime);
    el?.addEventListener("input", calculateOvertime);
  });

  // Initial calculation
  calculateOvertime();
</script>
