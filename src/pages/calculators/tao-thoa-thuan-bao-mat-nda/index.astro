<script>
  function updatePreview() {
    // 1. Get input values
    const partyAName = (document.getElementById("partyAName") as HTMLInputElement).value;
    const partyARep = (document.getElementById("partyARep") as HTMLInputElement).value;
    const partyARole = (document.getElementById("partyARole") as HTMLInputElement).value;
    const partyANat = (document.getElementById("partyANat") as HTMLInputElement).value;
    const partyAAddr = (document.getElementById("partyAAddr") as HTMLInputElement).value;

    const partyBName = (document.getElementById("partyBName") as HTMLInputElement).value;
    const partyBRep = (document.getElementById("partyBRep") as HTMLInputElement).value;
    const partyBRole = (document.getElementById("partyBRole") as HTMLInputElement).value;
    const partyBNat = (document.getElementById("partyBNat") as HTMLInputElement).value;
    const partyBAddr = (document.getElementById("partyBAddr") as HTMLInputElement).value;

    const purposeVi = (document.getElementById("purposeVi") as HTMLTextAreaElement).value;
    const purposeEn = (document.getElementById("purposeEn") as HTMLTextAreaElement).value;

    const termYears = (document.getElementById("termYears") as HTMLSelectElement).value;
    const fineAmount = parseFloat((document.getElementById("fineAmount") as HTMLInputElement).value) || 0;
    const signLocation = (document.getElementById("signLocation") as HTMLInputElement).value;
    const signDateVal = (document.getElementById("signDate") as HTMLInputElement).value;

    // Format sign date
    let signDateVi = "......";
    let signDateEn = "......";
    if (signDateVal) {
      const d = new Date(signDateVal);
      signDateVi = `ngày ${d.getDate()} tháng ${d.getMonth() + 1} năm ${d.getFullYear()}`;
      // Format English Date: Month Day, Year
      const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
      signDateEn = `${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
    }

    // Format term string
    let termVi = "";
    let termEn = "";
    if (termYears === "forever") {
      termVi = "vô thời hạn (không thời hạn)";
      termEn = "indefinite (without time limit)";
    } else {
      termVi = `${termYears} năm`;
      termEn = `${termYears} years`;
    }

    const fineStrVi = formatCurrency(fineAmount);
    const fineStrEn = formatCurrency(fineAmount);

    // 2. Set Preview text
    updateTextNodes("pv-party-a-name", partyAName);
    updateTextNodes("pv-party-a-rep", partyARep);
    updateTextNodes("pv-party-a-role", partyARole);
    updateTextNodes("pv-party-a-nat", partyANat);
    updateTextNodes("pv-party-a-addr", partyAAddr);

    updateTextNodes("pv-party-b-name", partyBName);
    updateTextNodes("pv-party-b-rep", partyBRep);
    updateTextNodes("pv-party-b-role", partyBRole);
    updateTextNodes("pv-party-b-nat", partyBNat);
    updateTextNodes("pv-party-b-addr", partyBAddr);

    updateTextNodes("pv-purpose-vi", purposeVi);
    updateTextNodes("pv-purpose-en", purposeEn);

    updateTextNodes("pv-term-vi", termVi);
    updateTextNodes("pv-term-en", termEn);

    updateTextNodes("pv-fine-vi", fineStrVi);
    updateTextNodes("pv-fine-en", fineStrEn);

    updateTextNodes("pv-sign-location-vi", signLocation);
    updateTextNodes("pv-sign-location-en", signLocation);

    updateTextNodes("pv-sign-date-vi", signDateVi);
    updateTextNodes("pv-sign-date-en", signDateEn);

    updateTextNodes("pv-party-a-rep-sig", partyARep);
    updateTextNodes("pv-party-b-rep-sig", partyBRep);
  }

  function updateTextNodes(className: string, val: string) {
    document.querySelectorAll("." + className).forEach(el => {
      el.textContent = val || "...";
    });
  }

  function formatCurrency(num: number) {
    return Math.round(num).toLocaleString('vi-VN');
  }

  // Initial date to today
  const signDateInput = document.getElementById("signDate") as HTMLInputElement;
  if (signDateInput && !signDateInput.value) {
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    signDateInput.value = `${yyyy}-${mm}-${dd}`;
  }

  // Bind events
  const inputs = ['partyAName', 'partyARep', 'partyARole', 'partyANat', 'partyAAddr', 
                  'partyBName', 'partyBRep', 'partyBRole', 'partyBNat', 'partyBAddr', 
                  'purposeVi', 'purposeEn', 'termYears', 'fineAmount', 'signLocation', 'signDate'];
  inputs.forEach(id => {
    const el = document.getElementById(id);
    el?.addEventListener('change', updatePreview);
    el?.addEventListener('input', updatePreview);
  });

  // Action Buttons
  const btnCopyNDA = document.getElementById("btnCopyNDA");
  btnCopyNDA?.addEventListener("click", () => {
    const printArea = document.getElementById("printArea");
    if (!printArea) return;
    
    // Copy as plain text
    const text = printArea.innerText;
    navigator.clipboard.writeText(text).then(() => {
      const isEn = localStorage.getItem("lang") === "en";
      const oldText = btnCopyNDA.innerHTML;
      btnCopyNDA.innerHTML = isEn ? "✅ Copied!" : "✅ Đã sao chép!";
      setTimeout(() => {
        btnCopyNDA.innerHTML = oldText;
      }, 2000);
    });
  });

  const btnPrintNDA = document.getElementById("btnPrintNDA");
  btnPrintNDA?.addEventListener("click", () => {
    window.print();
  });

  // Initial update
  updatePreview();
</script>
