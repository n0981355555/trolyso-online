---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Trình Tạo Thỏa Thuận Bảo Mật NDA Song Ngữ Việt - Anh Chuẩn Pháp Lý"
  description="Công cụ tự động tạo biên bản thỏa thuận bảo mật thông tin (NDA) song ngữ Anh - Việt chuyên nghiệp. Live preview, sao chép và xuất file PDF/in nhanh chóng."
>
  <!-- JSON-LD WebApplication Schema -->
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Công cụ tạo thỏa thuận bảo mật thông tin NDA song ngữ",
      "description": "Ứng dụng trực tuyến giúp doanh nghiệp tạo nhanh thỏa thuận bảo mật thông tin (NDA) song ngữ Việt - Anh, hỗ trợ xem trước thời gian thực, sao chép và in ấn.",
      "operatingSystem": "All",
      "applicationCategory": "BusinessApplication",
      "browserRequirements": "Requires HTML5, CSS3, JavaScript support",
      "url": "https://trolyso.online/calculators/tao-thoa-thuan-bao-mat-nda/"
    }
  </script>

  <!-- JSON-LD FAQPage Schema -->
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Thỏa thuận bảo mật thông tin NDA song ngữ là gì?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "NDA (Non-Disclosure Agreement) là thỏa thuận pháp lý giữa hai hoặc nhiều bên nhằm cam kết không tiết lộ các thông tin mật, bí mật kinh doanh hoặc công nghệ được chia sẻ trong quá trình hợp tác. Bản song ngữ Việt - Anh phục vụ cho các giao dịch thương mại có yếu tố nước ngoài hoặc doanh nghiệp FDI."
          }
        },
        {
          "@type": "Question",
          "name": "Thời hạn bảo mật trong NDA thông thường là bao lâu?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Thời hạn bảo mật thông thường dao động từ 2 đến 5 năm kể từ ngày chấm dứt hợp tác, hoặc có thể kéo dài vô thời hạn đối với các bí mật thương mại cốt lõi như mã nguồn phần mềm, công thức sản xuất."
          }
        },
        {
          "@type": "Question",
          "name": "Mức phạt vi phạm NDA bao nhiêu là hợp lý?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Mức phạt vi phạm thỏa thuận NDA do hai bên thỏa thuận và ghi rõ trong hợp đồng (Ví dụ: 100.000.000đ hoặc dựa theo giá trị thiệt hại thực tế phát sinh). Theo Bộ luật Dân sự Việt Nam, các bên tự do thỏa thuận mức phạt vi phạm trừ một số trường hợp cụ thể có luật chuyên ngành điều chỉnh."
          }
        }
      ]
    }
  </script>

  <style is:inline>
    @media print {
      body * {
        visibility: hidden;
      }
      #printArea, #printArea * {
        visibility: visible;
      }
      #printArea {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        color: #000;
        background: #fff;
      }
      .no-print {
        display: none !important;
      }
    }
  </style>

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(37,99,235,0.04),transparent_50%)] pointer-events-none z-0"></div>

  <main class="max-w-7xl mx-auto px-4 py-8 w-full z-10 relative">
    
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-6 no-print" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint font-medium transition">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/calculators/" class="hover:text-brand-blue dark:hover:text-brand-mint font-medium transition">Công cụ</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Tạo NDA song ngữ</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="text-center mb-8 no-print">
      <h1 class="text-2xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-3">
        Trình Tạo NDA Song Ngữ Việt - Anh
      </h1>
      <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400 max-w-3xl mx-auto">
        Tạo nhanh Thỏa thuận bảo mật thông tin (Non-Disclosure Agreement) song ngữ Anh - Việt chuẩn pháp lý. Điền form, xem trước trực quan và in/sao chép tức thì.
      </p>
    </div>

    <!-- main workspace -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- LEFT FORM INPUTS (5 cols) -->
      <div class="lg:col-span-5 space-y-6 no-print">
        
        <!-- Party A (Disclosing) -->
        <div class="bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200/60 dark:border-slate-800/60 p-5 shadow-sm">
          <h3 class="font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2 text-sm sm:text-base">
            🏢 Bên A: Bên tiết lộ thông tin (Disclosing Party)
          </h3>
          <div class="space-y-3">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Tên công ty / Cá nhân</label>
              <input type="text" id="partyAName" value="Công ty TNHH Giải pháp Số Assistant" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition font-semibold" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Người đại diện</label>
              <input type="text" id="partyARep" value="Nguyễn Văn A" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Chức vụ</label>
                <input type="text" id="partyARole" value="Giám đốc" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Quốc tịch</label>
                <input type="text" id="partyANat" value="Việt Nam" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Địa chỉ</label>
              <input type="text" id="partyAAddr" value="Số 1 Cầu Giấy, Dịch Vọng, Cầu Giấy, Hà Nội" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
          </div>
        </div>

        <!-- Party B (Receiving) -->
        <div class="bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200/60 dark:border-slate-800/60 p-5 shadow-sm">
          <h3 class="font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2 text-sm sm:text-base">
            🤝 Bên B: Bên nhận thông tin (Receiving Party)
          </h3>
          <div class="space-y-3">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Tên công ty / Cá nhân</label>
              <input type="text" id="partyBName" value="Công ty Cổ phần Công nghệ TechVibe" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition font-semibold" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Người đại diện</label>
              <input type="text" id="partyBRep" value="Trần Thị B" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Chức vụ</label>
                <input type="text" id="partyBRole" value="Giám đốc Công nghệ" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Quốc tịch</label>
                <input type="text" id="partyBNat" value="Việt Nam" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Địa chỉ</label>
              <input type="text" id="partyBAddr" value="Số 100 Điện Biên Phủ, Phường Đa Kao, Quận 1, TP. Hồ Chí Minh" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-sm outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
            </div>
          </div>
        </div>

        <!-- Agreement Terms -->
        <div class="bg-white dark:bg-brand-darkCard rounded-2xl border border-slate-200/60 dark:border-slate-800/60 p-5 shadow-sm">
          <h3 class="font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2 text-sm sm:text-base">
            ⚙️ Các điều khoản thỏa thuận (Agreement Terms)
          </h3>
          <div class="space-y-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Mục đích chia sẻ thông tin (tiếng Việt)</label>
              <textarea id="purposeVi" rows="2" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-none">Hợp tác nghiên cứu phát triển dự án phần mềm và tích hợp hệ thống Trợ Lý Số.</textarea>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">Mục đích chia sẻ thông tin (tiếng Anh)</label>
              <textarea id="purposeEn" rows="2" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition resize-none">Cooperation in research, development of software project, and integration of Digital Assistant system.</textarea>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Thời hạn bảo mật</label>
                <select id="termYears" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs outline-none focus:border-brand-blue transition font-semibold">
                  <option value="2">2 năm (2 Years)</option>
                  <option value="3" selected>3 năm (3 Years)</option>
                  <option value="5">5 năm (5 Years)</option>
                  <option value="forever">Vô thời hạn (Forever)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Phạt vi phạm (VND)</label>
                <input type="number" id="fineAmount" value="100000000" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition font-bold" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Địa danh ký kết</label>
                <input type="text" id="signLocation" value="Hà Nội" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Ngày ký kết</label>
                <input type="date" id="signDate" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs outline-none focus:bg-white dark:focus:bg-brand-darkCard focus:border-brand-blue transition" />
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- RIGHT LIVE PREVIEW & EXPORTS (7 cols) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        
        <!-- Toolbar actions -->
        <div class="flex flex-wrap items-center justify-between gap-3 bg-slate-100 dark:bg-slate-900 p-3 rounded-2xl border border-slate-200/50 dark:border-slate-800/50 no-print">
          <span class="text-xs font-bold text-slate-500 dark:text-slate-400">📄 Bản xem trước song ngữ (A4 Layout)</span>
          <div class="flex gap-2">
            <button id="btnCopyNDA" class="px-4 py-2 bg-slate-200 dark:bg-slate-800 text-slate-800 dark:text-slate-200 hover:bg-slate-300 dark:hover:bg-slate-700 font-bold text-xs rounded-xl flex items-center gap-1.5 transition">
              📋 Sao chép
            </button>
            <button id="btnPrintNDA" class="px-4 py-2 bg-brand-blue dark:bg-brand-mint text-white dark:text-slate-950 font-bold text-xs rounded-xl flex items-center gap-1.5 transition">
              🖨️ In / Xuất PDF
            </button>
          </div>
        </div>

        <!-- A4 Page Preview Area -->
        <div id="printArea" class="bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-900 rounded-2xl shadow-lg p-6 sm:p-10 font-serif text-slate-900 dark:text-slate-100 text-xs leading-relaxed max-h-[700px] overflow-y-auto print:max-h-none print:overflow-visible transition-colors">
          
          <!-- Document Header -->
          <div class="grid grid-cols-2 gap-6 text-center border-b border-slate-200 dark:border-slate-800 pb-6 mb-6">
            <div>
              <h2 class="font-bold text-sm uppercase">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h2>
              <p class="font-bold text-[10px]">Độc lập - Tự do - Hạnh phúc</p>
              <p class="text-[9px] mt-1">---***---</p>
            </div>
            <div>
              <h2 class="font-bold text-sm uppercase">SOCIALIST REPUBLIC OF VIETNAM</h2>
              <p class="font-bold text-[10px]">Independence - Freedom - Happiness</p>
              <p class="text-[9px] mt-1">---***---</p>
            </div>
          </div>

          <!-- Document Title -->
          <div class="grid grid-cols-2 gap-6 text-center mb-8">
            <div>
              <h1 class="font-bold text-base uppercase">THỎA THUẬN BẢO MẬT THÔNG TIN</h1>
              <p class="text-[10px] italic mt-1">(Dành cho hợp tác kinh doanh/phát triển sản phẩm)</p>
            </div>
            <div>
              <h1 class="font-bold text-base uppercase">NON-DISCLOSURE AGREEMENT</h1>
              <p class="text-[10px] italic mt-1">(For business cooperation/product development)</p>
            </div>
          </div>

          <!-- Introduction preamble -->
          <div class="grid grid-cols-2 gap-6 mb-6 text-justify">
            <div>
              <p>Thỏa thuận bảo mật thông tin này (sau đây gọi là "Thỏa thuận") được lập và ký kết vào ngày <span class="pv-sign-date-vi">...</span> tại <span class="pv-sign-location-vi">...</span> bởi các bên dưới đây:</p>
            </div>
            <div>
              <p>This Non-Disclosure Agreement (hereinafter referred to as the "Agreement") is entered into on <span class="pv-sign-date-en">...</span> at <span class="pv-sign-location-en">...</span> by and between:</p>
            </div>
          </div>

          <!-- PARTIES DETAILS -->
          <div class="grid grid-cols-2 gap-6 mb-6">
            <!-- Party A (Vi/En) -->
            <div class="space-y-1">
              <p class="font-bold uppercase">BÊN A (BÊN TIẾT LỘ):</p>
              <p><strong>Tên:</strong> <span class="pv-party-a-name">...</span></p>
              <p><strong>Người đại diện:</strong> <span class="pv-party-a-rep">...</span></p>
              <p><strong>Chức vụ:</strong> <span class="pv-party-a-role">...</span></p>
              <p><strong>Quốc tịch:</strong> <span class="pv-party-a-nat">...</span></p>
              <p><strong>Địa chỉ:</strong> <span class="pv-party-a-addr">...</span></p>
            </div>
            <div class="space-y-1">
              <p class="font-bold uppercase">PARTY A (DISCLOSING PARTY):</p>
              <p><strong>Name:</strong> <span class="pv-party-a-name">...</span></p>
              <p><strong>Representative:</strong> <span class="pv-party-a-rep">...</span></p>
              <p><strong>Title:</strong> <span class="pv-party-a-role">...</span></p>
              <p><strong>Nationality:</strong> <span class="pv-party-a-nat">...</span></p>
              <p><strong>Address:</strong> <span class="pv-party-a-addr">...</span></p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6 mb-6">
            <!-- Party B (Vi/En) -->
            <div class="space-y-1">
              <p class="font-bold uppercase">BÊN B (BÊN NHẬN):</p>
              <p><strong>Tên:</strong> <span class="pv-party-b-name">...</span></p>
              <p><strong>Người đại diện:</strong> <span class="pv-party-b-rep">...</span></p>
              <p><strong>Chức vụ:</strong> <span class="pv-party-b-role">...</span></p>
              <p><strong>Quốc tịch:</strong> <span class="pv-party-b-nat">...</span></p>
              <p><strong>Địa chỉ:</strong> <span class="pv-party-b-addr">...</span></p>
            </div>
            <div class="space-y-1">
              <p class="font-bold uppercase">PARTY B (RECEIVING PARTY):</p>
              <p><strong>Name:</strong> <span class="pv-party-b-name">...</span></p>
              <p><strong>Representative:</strong> <span class="pv-party-b-rep">...</span></p>
              <p><strong>Title:</strong> <span class="pv-party-b-role">...</span></p>
              <p><strong>Nationality:</strong> <span class="pv-party-b-nat">...</span></p>
              <p><strong>Address:</strong> <span class="pv-party-b-addr">...</span></p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6 mb-6 text-justify">
            <div>
              <p class="italic">Xét rằng, các Bên mong muốn chia sẻ các thông tin bảo mật để phục vụ mục đích: <span class="pv-purpose-vi">...</span> (sau đây gọi là "Mục đích"). Các bên đồng ý ký kết Thỏa thuận này với các điều khoản dưới đây:</p>
            </div>
            <div>
              <p class="italic">Whereas, the Parties wish to share confidential information for the purpose of: <span class="pv-purpose-en">...</span> (hereinafter referred to as the "Purpose"). The parties agree to enter into this Agreement under the following terms:</p>
            </div>
          </div>

          <!-- SECTION 1: CONFIDENTIAL INFORMATION -->
          <div class="grid grid-cols-2 gap-6 mb-6 text-justify">
            <div>
              <p class="font-bold">ĐIỀU 1: THÔNG TIN BẢO MẬT</p>
              <p>
                "Thông tin bảo mật" nghĩa là tất cả thông tin, dữ liệu, bí mật kinh doanh, thiết kế, mã nguồn phần mềm, thông tin kỹ thuật, tài chính hoặc thương mại do Bên tiết lộ cung cấp cho Bên nhận thông tin dưới bất kỳ hình thức nào (bằng văn bản, lời nói hoặc điện tử).
              </p>
            </div>
            <div>
              <p class="font-bold">ARTICLE 1: CONFIDENTIAL INFORMATION</p>
              <p>
                "Confidential Information" means all information, data, trade secrets, designs, software source code, technical, financial, or commercial information provided by Disclosing Party to Receiving Party in any form (written, oral, or electronic).
              </p>
            </div>
          </div>

          <!-- SECTION 2: OBLIGATIONS -->
