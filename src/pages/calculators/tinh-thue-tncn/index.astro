---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Công Cụ Tính Thuế Thu Nhập Cá Nhân Chuẩn 2026 - Trợ Lý Số"
  description="Công cụ tính thuế thu nhập cá nhân (TNCN) online chuẩn pháp luật Việt Nam. Hỗ trợ tính thuế lũy tiến từng phần và phân tích chi tiết số thuế phải nộp ở từng bậc."
>
  <!-- Background Decor -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(37,99,235,0.04),transparent_50%)] pointer-events-none z-0"></div>

  <main class="max-w-6xl mx-auto px-4 py-12 w-full z-10 relative">
    
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/#calculators" class="hover:text-brand-blue dark:hover:text-brand-mint">Calculators</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Tính thuế TNCN</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-4">
        Công Cụ Tính Thuế Thu Nhập Cá Nhân 2026
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Tính toán số tiền thuế TNCN phải nộp hàng tháng và hiển thị bảng phân tích số tiền thuế chi tiết ở từng bậc lũy tiến.
      </p>
    </div>

    <!-- Tool Grid -->
    <div class="bg-white dark:bg-brand-darkCard rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 overflow-hidden grid grid-cols-1 md:grid-cols-12 mb-12 transition-colors">
        
      <!-- Left inputs (7 cols) -->
      <div class="p-6 sm:p-10 md:col-span-7">
        <h2 class="text-xl font-heading font-bold text-slate-900 dark:text-white mb-8 flex items-center gap-3">
          📝 Nhập thông tin thu nhập & Khấu trừ
        </h2>

        <div class="space-y-5">
          <!-- Tổng thu nhập tháng -->
          <div>
            <label for="incomeInput" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Tổng thu nhập chịu thuế tháng (VND)</label>
            <input type="number" id="incomeInput" value="30000000" step="1000000" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-bold text-lg" />
          </div>

          <!-- Lựa chọn tính bảo hiểm -->
          <div>
            <label for="insuranceType" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Đóng bảo hiểm bắt buộc</label>
            <select id="insuranceType" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-medium">
              <option value="auto">Tự động tính bảo hiểm bắt buộc (10.5%)</option>
              <option value="custom">Tự nhập số tiền đóng bảo hiểm</option>
              <option value="none">Không đóng bảo hiểm bắt buộc</option>
            </select>
          </div>

          <!-- Nhập bảo hiểm tùy chỉnh -->
          <div id="customInsuranceWrapper" class="hidden">
            <label for="customInsurance" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Số tiền đóng bảo hiểm thực tế (VND)</label>
            <input type="number" id="customInsurance" value="0" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-bold" />
          </div>

          <!-- Số người phụ thuộc -->
          <div>
            <label for="dependents" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Số người phụ thuộc (Giảm trừ gia cảnh)</label>
            <div class="flex items-center gap-3">
              <button id="btnMinus" aria-label="Giảm số người phụ thuộc" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">-</button>
              <input type="number" id="dependents" value="0" min="0" class="w-20 text-center py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-bold text-lg" />
              <button id="btnPlus" aria-label="Tăng số người phụ thuộc" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">+</button>
            </div>
          </div>

          <!-- Từ thiện, nhân đạo -->
          <div>
            <label for="charity" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Đóng góp từ thiện, nhân đạo (VND)</label>
            <input type="number" id="charity" value="0" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-bold" />
          </div>

          <button id="btnCalculate" class="w-full bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold py-4 px-6 rounded-xl transition duration-200 shadow-lg">
            ⚡ Tính Thuế TNCN
          </button>
        </div>
      </div>

      <!-- Right outputs (5 cols) -->
      <div class="p-6 sm:p-10 bg-slate-50/50 dark:bg-slate-900/50 md:col-span-5 flex flex-col justify-between border-t md:border-t-0 md:border-l border-slate-200 dark:border-slate-800">
        <div>
          <h3 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-6">Kết quả tính thuế</h3>

          <div class="space-y-4 text-sm">
            <div class="flex justify-between items-center py-2 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Thu nhập chịu thuế:</span>
              <span class="font-bold text-slate-900 dark:text-white" id="resIncome">0đ</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Giảm trừ bảo hiểm:</span>
              <span class="font-semibold text-red-500" id="resInsurance">0đ</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Giảm trừ gia cảnh (Bản thân):</span>
              <span class="font-semibold text-slate-700 dark:text-slate-300">-11,000,000đ</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Giảm trừ gia cảnh (Phụ thuộc):</span>
              <span class="font-semibold text-slate-700 dark:text-slate-300" id="resDependents">0đ</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Khấu trừ từ thiện:</span>
              <span class="font-semibold text-slate-700 dark:text-slate-300" id="resCharity">0đ</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Thu nhập tính thuế:</span>
              <span class="font-bold text-brand-blue dark:text-brand-mint" id="resTaxable">0đ</span>
            </div>
            <div class="flex justify-between items-center pt-6 pb-2">
              <span class="text-base font-bold text-slate-800 dark:text-slate-200">THUẾ TNCN PHẢI NỘP:</span>
              <span class="text-2xl font-extrabold text-red-500" id="resTax">0đ</span>
            </div>
          </div>
        </div>

        <div class="text-xs text-slate-400 mt-8 pt-4 border-t border-slate-200 dark:border-slate-800">
          * Đã trừ bảo hiểm bắt buộc và các khoản giảm trừ gia cảnh quy định mới nhất.
        </div>
      </div>

    </div>

    <!-- Bậc Thuế Chi Tiết (UX Feature: Bảng phân tích chi tiết) -->
    <div class="bg-white dark:bg-brand-darkCard rounded-2xl p-6 sm:p-10 shadow-xl border border-slate-200 dark:border-slate-800 transition-colors">
      <h3 class="text-xl font-heading font-bold text-slate-900 dark:text-white mb-6">📊 Bảng Phân Tích Lũy Tiến Từng Bậc</h3>
      
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-800 text-slate-400">
              <th class="py-3 px-4">Bậc</th>
              <th class="py-3 px-4">Thu nhập tính thuế / tháng</th>
              <th class="py-3 px-4">Thuế suất</th>
              <th class="py-3 px-4 text-right">Số thuế phải nộp từng bậc</th>
            </tr>
          </thead>
          <tbody id="taxBracketsBody" class="divide-y divide-slate-100 dark:divide-slate-800 font-medium text-slate-700 dark:text-slate-300">
            <!-- Sẽ được điền bằng Javascript -->
          </tbody>
         </table>
      </div>
    </div>

    <!-- SEO Content Section (E-E-A-T & Googlebot indexing helper) -->
    <div class="mt-12 bg-white dark:bg-brand-darkCard rounded-2xl p-6 sm:p-10 shadow-xl border border-slate-200 dark:border-slate-800 prose prose-slate dark:prose-invert max-w-none transition-colors animate-fade-in">
      <h2 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-6">
        Hướng Dẫn Cách Tính Thuế Thu Nhập Cá Nhân 2026 Tự Động & Chuẩn Xác
      </h2>
      <p>
        Thuế thu nhập cá nhân (TNCN) là nghĩa vụ tài chính bắt buộc của người lao động có thu nhập chịu thuế vượt quá mức giảm trừ gia cảnh theo quy định pháp luật hiện hành. Để giúp bạn dễ dàng tự tính toán số thuế phải nộp hằng tháng, công cụ của <strong>Trợ Lý Số</strong> đã được cập nhật chính xác các thông số theo Luật Thuế thu nhập cá nhân mới nhất năm 2026.
      </p>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-6 mb-3">1. Công thức tính thuế TNCN cơ bản</h3>
      <p>Số tiền thuế TNCN phải nộp hằng tháng được xác định theo công thức pháp luật quy định như sau:</p>
      <div class="bg-slate-50 dark:bg-slate-900/60 p-4 rounded-xl border border-slate-200 dark:border-slate-800 font-semibold mb-4 text-sm text-slate-800 dark:text-slate-200">
        1. Thu nhập tính thuế = Thu nhập chịu thuế - Các khoản giảm trừ
        <br/>
        2. Thuế TNCN phải nộp = Thu nhập tính thuế × Thuế suất tương ứng theo bậc lũy tiến
      </div>
      <p>Trong đó, các khoản giảm trừ bao gồm:</p>
      <ul>
        <li><strong>Giảm trừ gia cảnh bản thân:</strong> 11.000.000 đồng/tháng (132.000.000 đồng/năm).</li>
        <li><strong>Giảm trừ gia cảnh người phụ thuộc:</strong> 4.400.000 đồng/tháng cho mỗi người phụ thuộc.</li>
        <li><strong>Các khoản đóng bảo hiểm bắt buộc:</strong> BHXH (8%), BHYT (1.5%), BHTN (1%). Tổng cộng là 10.5% mức lương đóng bảo hiểm (tối đa bằng 20 lần mức lương cơ sở).</li>
        <li>Các khoản đóng góp từ thiện, nhân đạo, khuyến học được nhà nước công nhận.</li>
      </ul>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-6 mb-3">2. Biểu thuế suất lũy tiến từng phần (7 Bậc)</h3>
      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm text-left border border-slate-200 dark:border-slate-800">
          <thead class="bg-slate-100 dark:bg-slate-900 text-slate-700 dark:text-slate-300">
            <tr>
              <th class="p-3 border">Bậc thuế</th>
              <th class="p-3 border">Thu nhập tính thuế/tháng</th>
              <th class="p-3 border">Thuế suất</th>
              <th class="p-3 border">Công thức tính nhanh</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-3 border font-semibold">Bậc 1</td>
              <td class="p-3 border">Đến 5 triệu VND</td>
              <td class="p-3 border font-bold">5%</td>
              <td class="p-3 border">TNTT × 5%</td>
            </tr>
            <tr class="bg-slate-50/50 dark:bg-slate-950/20">
              <td class="p-3 border font-semibold">Bậc 2</td>
              <td class="p-3 border">Trên 5 triệu đến 10 triệu VND</td>
              <td class="p-3 border font-bold">10%</td>
              <td class="p-3 border">(TNTT × 10%) - 250.000 VND</td>
            </tr>
            <tr>
              <td class="p-3 border font-semibold">Bậc 3</td>
              <td class="p-3 border">Trên 10 triệu đến 18 triệu VND</td>
              <td class="p-3 border font-bold">15%</td>
              <td class="p-3 border">(TNTT × 15%) - 750.000 VND</td>
            </tr>
            <tr class="bg-slate-50/50 dark:bg-slate-950/20">
              <td class="p-3 border font-semibold">Bậc 4</td>
              <td class="p-3 border">Trên 18 triệu đến 32 triệu VND</td>
              <td class="p-3 border font-bold">20%</td>
              <td class="p-3 border">(TNTT × 20%) - 1.650.000 VND</td>
            </tr>
            <tr>
              <td class="p-3 border font-semibold">Bậc 5</td>
              <td class="p-3 border">Trên 32 triệu đến 52 triệu VND</td>
              <td class="p-3 border font-bold">25%</td>
              <td class="p-3 border">(TNTT × 25%) - 3.250.000 VND</td>
            </tr>
            <tr class="bg-slate-50/50 dark:bg-slate-950/20">
              <td class="p-3 border font-semibold">Bậc 6</td>
              <td class="p-3 border">Trên 52 triệu đến 80 triệu VND</td>
              <td class="p-3 border font-bold">30%</td>
              <td class="p-3 border">(TNTT × 30%) - 5.850.000 VND</td>
            </tr>
            <tr>
              <td class="p-3 border font-semibold">Bậc 7</td>
              <td class="p-3 border">Trên 80 triệu VND</td>
              <td class="p-3 border font-bold text-red-600 dark:text-red-400">35%</td>
              <td class="p-3 border">(TNTT × 35%) - 9.850.000 VND</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-6 mb-3">3. Ví dụ tính thuế TNCN thực tế</h3>
      <p>
        Bà Cúc có tổng thu nhập hằng tháng là 30.000.000 đồng, đóng bảo hiểm bắt buộc ở mức 10.5% lương (3.150.000 đồng) và nuôi 1 người phụ thuộc. 
        <br/>- Các khoản giảm trừ của bà Cúc: Bảo hiểm (3.150.000) + Bản thân (11.000.000) + 1 người phụ thuộc (4.400.000) = 18.550.000 đồng.
        <br/>- Thu nhập tính thuế = 30.000.000 - 18.550.000 = 11.450.000 đồng (Thuộc bậc 3).
        <br/>- Áp dụng công thức tính nhanh bậc 3: (11.450.000 × 15%) - 750.000 = 967.500 đồng.
      </p>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-8 mb-3">❓ Câu hỏi thường gặp (FAQ)</h3>
      <div class="space-y-4">
        <div class="border-b border-slate-200 dark:border-slate-800 pb-3">
          <p class="font-bold text-slate-900 dark:text-white text-sm mb-1">Mức giảm trừ gia cảnh bản thân năm 2026 là bao nhiêu?</p>
          <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">Hiện tại mức giảm trừ gia cảnh cho bản thân người nộp thuế áp dụng là 11.000.000 đồng/tháng (132.000.000 đồng/năm) theo đúng Nghị quyết 954/2020/UBTVQH14.</p>
        </div>
        <div class="border-b border-slate-200 dark:border-slate-800 pb-3">
          <p class="font-bold text-slate-900 dark:text-white text-sm mb-1">Những ai được tính là người phụ thuộc giảm trừ gia cảnh?</p>
          <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">Người phụ thuộc bao gồm con dưới 18 tuổi hoặc con trên 18 tuổi bị khuyết tật/không có khả năng lao động; cha mẹ đẻ/cha mẹ vợ/chồng ngoài độ tuổi lao động hoặc trong độ tuổi lao động nhưng bị khuyết tật, không có thu nhập hoặc thu nhập bình quân tháng dưới 1.000.000 đồng.</p>
        </div>
        <div class="pb-3">
          <p class="font-bold text-slate-900 dark:text-white text-sm mb-1">Thời gian nộp hồ sơ quyết toán thuế TNCN hằng năm là khi nào?</p>
          <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">Đối với cá nhân tự quyết toán trực tiếp với cơ quan thuế, hạn chót nộp hồ sơ quyết toán là ngày cuối cùng của tháng thứ 4 kể từ ngày kết thúc năm dương lịch (thường là ngày 30/04 hằng năm).</p>
        </div>
      </div>

      <!-- Bi-directional Linking to Blog Post -->
      <div class="mt-8 p-4 rounded-xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 not-prose">
        <div class="flex items-center gap-3">
          <span class="text-2xl">💡</span>
          <div>
            <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-0.5">Bạn muốn tìm hiểu kỹ hơn?</h4>
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-0">Đọc cẩm nang hướng dẫn chi tiết về các bậc thuế, giảm trừ gia cảnh và quyết toán.</p>
          </div>
        </div>
        <a href="/blog/huong-dan-tinh-thue-tncn/" class="px-4 py-2 bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold rounded-lg text-xs transition whitespace-nowrap shadow-sm">
          Xem bài viết →
        </a>
      </div>
    </div>

    <!-- Structured Data Schemas (JSON-LD) for SEO -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebApplication",
            "@id": "https://trolyso.online/calculators/tinh-thue-tncn/#webapp",
            "name": "Công Cụ Tính Thuế Thu Nhập Cá Nhân Online Tự Động",
            "url": "https://trolyso.online/calculators/tinh-thue-tncn/",
            "applicationCategory": "FinanceApplication",
            "operatingSystem": "All",
            "browserRequirements": "Requires JavaScript. Requires HTML5.",
            "offers": {
              "@type": "Offer",
              "price": "0",
              "priceCurrency": "VND"
            }
          },
          {
            "@type": "FAQPage",
            "@id": "https://trolyso.online/calculators/tinh-thue-tncn/#faq",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Mức giảm trừ gia cảnh bản thân năm 2026 là bao nhiêu?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Hiện tại mức giảm trừ gia cảnh cho bản thân người nộp thuế áp dụng là 11.000.000 đồng/tháng (132.000.000 đồng/năm) theo đúng Nghị quyết 954/2020/UBTVQH14."
                }
              },
              {
                "@type": "Question",
                "name": "Những ai được tính là người phụ thuộc giảm trừ gia cảnh?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Người phụ thuộc bao gồm con dưới 18 tuổi hoặc con trên 18 tuổi bị khuyết tật/không có khả năng lao động; cha mẹ đẻ/cha mẹ vợ/chồng ngoài độ tuổi lao động hoặc trong độ tuổi lao động nhưng bị khuyết tật, không có thu nhập hoặc thu nhập bình quân tháng dưới 1.000.000 đồng."
                }
              },
              {
                "@type": "Question",
                "name": "Thời gian nộp hồ sơ quyết toán thuế TNCN hằng năm là khi nào?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Đối với cá nhân tự quyết toán trực tiếp với cơ quan thuế, hạn chót nộp hồ sơ quyết toán là ngày cuối cùng của tháng thứ 4 kể từ ngày kết thúc năm dương lịch (thường là ngày 30/04 hằng năm)."
                }
              }
            ]
          }
        ]
      }
    </script>

  </main>
</Layout>

<script>
  function formatMoney(amount: number) {
    const isEn = localStorage.getItem('lang') === 'en';
    if (isEn) {
      return new Intl.NumberFormat('en-US', { style: 'decimal' }).format(amount) + ' VND';
    }
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
  }

  const incomeInput = document.getElementById('incomeInput') as HTMLInputElement;
  const insuranceType = document.getElementById('insuranceType') as HTMLSelectElement;
  const customInsuranceWrapper = document.getElementById('customInsuranceWrapper');
  const customInsurance = document.getElementById('customInsurance') as HTMLInputElement;
  const dependentsInput = document.getElementById('dependents') as HTMLInputElement;
  const charityInput = document.getElementById('charity') as HTMLInputElement;

  const btnMinus = document.getElementById('btnMinus');
  const btnPlus = document.getElementById('btnPlus');
  const btnCalculate = document.getElementById('btnCalculate');

  const resIncome = document.getElementById('resIncome');
  const resInsurance = document.getElementById('resInsurance');
  const resDependents = document.getElementById('resDependents');
  const resCharity = document.getElementById('resCharity');
  const resTaxable = document.getElementById('resTaxable');
  const resTax = document.getElementById('resTax');
  const taxBracketsBody = document.getElementById('taxBracketsBody');

  // Đổi trạng thái hiển thị nhập bảo hiểm thủ công
  insuranceType.addEventListener('change', () => {
    if (insuranceType.value === 'custom') {
      customInsuranceWrapper?.classList.remove('hidden');
    } else {
      customInsuranceWrapper?.classList.add('hidden');
    }
    calculateTax();
  });

  function calculateTax() {
    const income = parseFloat(incomeInput.value) || 0;
    const type = insuranceType.value;
    const dependents = parseInt(dependentsInput.value) || 0;
    const charity = parseFloat(charityInput.value) || 0;

    // 1. Tính bảo hiểm bắt buộc
    let insurance = 0;
    if (type === 'auto') {
      insurance = income * 0.105;
    } else if (type === 'custom') {
      insurance = parseFloat(customInsurance.value) || 0;
    }

    // 2. Các khoản giảm trừ gia cảnh
    const selfDeduction = 11000000;
    const dependentDeduction = dependents * 4400000;

    // 3. Tính thu nhập tính thuế
    const totalDeductions = insurance + selfDeduction + dependentDeduction + charity;
    const taxableIncome = Math.max(0, income - totalDeductions);

    // 4. Biểu thuế lũy tiến từng phần
    const brackets = [
      { limit: 5000000, rate: 0.05, maxTax: 250000 },
      { limit: 10000000, rate: 0.10, maxTax: 500000 },
      { limit: 18000000, rate: 0.15, maxTax: 1200000 },
      { limit: 32000000, rate: 0.20, maxTax: 2800000 },
      { limit: 52000000, rate: 0.25, maxTax: 5000000 },
      { limit: 80000000, rate: 0.30, maxTax: 8400000 },
      { limit: Infinity, rate: 0.35, maxTax: Infinity }
    ];

    let tax = 0;
    let tempIncome = taxableIncome;
    let previousLimit = 0;
    const bracketPayments: number[] = [];

    for (let i = 0; i < brackets.length; i++) {
      const b = brackets[i];
      const bracketRange = b.limit - previousLimit;
      
      if (tempIncome > 0) {
        if (tempIncome >= bracketRange) {
          const bracketTax = bracketRange * b.rate;
          tax += bracketTax;
          bracketPayments.push(bracketTax);
          tempIncome -= bracketRange;
        } else {
          const bracketTax = tempIncome * b.rate;
          tax += bracketTax;
          bracketPayments.push(bracketTax);
          tempIncome = 0;
        }
      } else {
        bracketPayments.push(0);
      }
      previousLimit = b.limit;
    }

    // 5. Hiển thị kết quả đầu ra
    if (resIncome) resIncome.innerText = formatMoney(income);
    if (resInsurance) resInsurance.innerText = "-" + formatMoney(insurance);
    if (resDependents) resDependents.innerText = "-" + formatMoney(dependentDeduction);
    if (resCharity) resCharity.innerText = "-" + formatMoney(charity);
    if (resTaxable) resTaxable.innerText = formatMoney(taxableIncome);
    if (resTax) resTax.innerText = formatMoney(tax);

    // 6. Vẽ bảng phân tích lũy tiến từng bậc
    const isEn = localStorage.getItem('lang') === 'en';
    if (taxBracketsBody) {
      taxBracketsBody.innerHTML = "";
      const ranges = isEn ? [
        "Up to 5 million",
        "Over 5 million to 10 million",
        "Over 10 million to 18 million",
        "Over 18 million to 32 million",
        "Over 32 million to 52 million",
        "Over 52 million to 80 million",
        "Over 80 million"
      ] : [
        "Đến 5 triệu",
        "Trên 5 triệu đến 10 triệu",
        "Trên 10 triệu đến 18 triệu",
        "Trên 18 triệu đến 32 triệu",
        "Trên 32 triệu đến 52 triệu",
        "Trên 52 triệu đến 80 triệu",
        "Trên 80 triệu"
      ];

      for (let i = 0; i < brackets.length; i++) {
        const tr = document.createElement('tr');
        tr.className = "border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors";
        
        const pay = bracketPayments[i] || 0;
        const isCurrent = pay > 0;
        
        tr.innerHTML = `
          <td class="py-4.5 px-4 text-slate-500">${i + 1}</td>
          <td class="py-4.5 px-4 font-semibold text-slate-800 dark:text-slate-200">${ranges[i]}</td>
          <td class="py-4.5 px-4"><span class="px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-xs font-bold">${brackets[i].rate * 100}%</span></td>
          <td class="py-4.5 px-4 text-right font-bold ${isCurrent ? 'text-red-500' : 'text-slate-400'}">${pay > 0 ? formatMoney(pay) : (isEn ? '0 VND' : '0đ')}</td>
        `;
        taxBracketsBody.appendChild(tr);
      }
    }
  }

  // Bind Events
  btnMinus?.addEventListener('click', () => {
    let val = parseInt(dependentsInput.value) || 0;
    val = Math.max(0, val - 1);
    dependentsInput.value = val.toString();
    calculateTax();
  });

  btnPlus?.addEventListener('click', () => {
    let val = parseInt(dependentsInput.value) || 0;
    dependentsInput.value = (val + 1).toString();
    calculateTax();
  });

  btnCalculate?.addEventListener('click', calculateTax);
  incomeInput.addEventListener('input', calculateTax);
  customInsurance.addEventListener('input', calculateTax);
  charityInput.addEventListener('input', calculateTax);

  // Initial Calculation
  calculateTax();
</script>
