---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Cách Tính Bảo Hiểm Xã Hội 1 Lần Online Tự Động Chuẩn 2026 - Trợ Lý Số"
  description="Công cụ tính bảo hiểm xã hội 1 lần trực tuyến miễn phí, chính xác chuẩn pháp luật Việt Nam mới nhất hiện nay."
>
  <!-- Background Decor -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(16,185,129,0.04),transparent_50%)] pointer-events-none z-0"></div>

  <main class="max-w-6xl mx-auto px-4 py-12 w-full z-10 relative">
    
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-brand-blue dark:hover:text-brand-mint">Trang chủ</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <a href="/#calculators" class="hover:text-brand-blue dark:hover:text-brand-mint">Calculators</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2 text-slate-400">/</span>
            <span class="text-slate-400 dark:text-slate-500">Tính BHXH 1 Lần</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-slate-900 dark:text-white mb-4">
        Công Cụ Tính Bảo Hiểm Xã Hội 1 Lần
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Ước tính nhanh số tiền nhận về khi thanh toán BHXH một lần theo Luật Bảo hiểm xã hội Việt Nam.
      </p>
    </div>

    <!-- Tool Grid -->
    <div class="bg-white dark:bg-brand-darkCard rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 overflow-hidden grid grid-cols-1 md:grid-cols-12 mb-12 transition-colors">
        
      <!-- Left inputs (7 cols) -->
      <div class="p-6 sm:p-10 md:col-span-7">
        <h2 class="text-xl font-heading font-bold text-slate-900 dark:text-white mb-8 flex items-center gap-3">
          🛡️ Nhập thông tin đóng BHXH
        </h2>

        <div class="space-y-6">
          <!-- Bình quân tiền lương đóng BHXH -->
          <div>
            <label for="avgSalary" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Bình quân tiền lương tháng đóng BHXH (VND)</label>
            <input type="number" id="avgSalary" value="8000000" step="500000" class="w-full px-4 py-4 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue dark:focus:ring-brand-mint font-bold text-lg" />
          </div>

          <!-- Thời gian đóng trước 2014 -->
          <div>
            <label for="yearsBefore" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Số năm đóng BHXH trước năm 2014</label>
            <div class="flex items-center gap-3">
              <button id="btnMinusBefore" aria-label="Giảm số năm đóng bảo hiểm trước 2014" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">-</button>
              <input type="number" id="yearsBefore" value="2" step="0.5" min="0" class="w-24 text-center py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-bold text-lg" />
              <span class="text-sm text-slate-400">năm</span>
              <button id="btnPlusBefore" aria-label="Tăng số năm đóng bảo hiểm trước 2014" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">+</button>
            </div>
          </div>

          <!-- Thời gian đóng từ 2014 -->
          <div>
            <label for="yearsAfter" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Số năm đóng BHXH từ năm 2014 trở đi</label>
            <div class="flex items-center gap-3">
              <button id="btnMinusAfter" aria-label="Giảm số năm đóng bảo hiểm sau 2014" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">-</button>
              <input type="number" id="yearsAfter" value="3.5" step="0.5" min="0" class="w-24 text-center py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-blue font-bold text-lg" />
              <span class="text-sm text-slate-400">năm</span>
              <button id="btnPlusAfter" aria-label="Tăng số năm đóng bảo hiểm sau 2014" class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 font-bold flex items-center justify-center transition">+</button>
            </div>
          </div>

          <button id="btnCalculate" class="w-full bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold py-4 px-6 rounded-xl transition duration-200 shadow-lg">
            <svg class="w-4 h-4 inline-block align-middle mr-1.5 -mt-0.5 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>Tính Số Tiền Nhận Về
          </button>
        </div>
      </div>

      <!-- Right outputs (5 cols) -->
      <div class="p-6 sm:p-10 bg-slate-50/50 dark:bg-slate-900/50 md:col-span-5 flex flex-col justify-between border-t md:border-t-0 md:border-l border-slate-200 dark:border-slate-800">
        <div>
          <h3 class="text-lg font-heading font-bold text-slate-900 dark:text-white mb-6">Kết quả ước tính</h3>

          <div class="space-y-4 text-sm">
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Hệ số nhận trước 2014 (x1.5):</span>
              <span class="font-semibold text-slate-900 dark:text-white" id="coeffBefore">0 năm</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Hệ số nhận sau 2014 (x2.0):</span>
              <span class="font-semibold text-slate-900 dark:text-white" id="coeffAfter">0 năm</span>
            </div>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-200 dark:border-slate-800">
              <span class="text-slate-500">Tổng hệ số hưởng:</span>
              <span class="font-bold text-brand-blue dark:text-brand-mint" id="totalCoeff">0 tháng lương</span>
            </div>
            <div class="flex justify-between items-center pt-6 pb-2">
              <span class="text-base font-bold text-slate-800 dark:text-slate-200">TỔNG TIỀN BHXH 1 LẦN:</span>
              <span class="text-2xl font-extrabold text-emerald-600 dark:text-brand-mint" id="totalBHXH">0đ</span>
            </div>
          </div>
        </div>

      </div>

    </div>

    <!-- SEO Content Section (E-E-A-T & Googlebot indexing helper) -->
    <div class="mt-12 bg-white dark:bg-brand-darkCard rounded-2xl p-6 sm:p-10 shadow-xl border border-slate-200 dark:border-slate-800 prose prose-slate dark:prose-invert max-w-none transition-colors animate-fade-in">
      <h2 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-6">
        Hướng Dẫn Cách Tính Bảo Hiểm Xã Hội 1 Lần 2026 Chuẩn Nhất
      </h2>
      <p>
        Bảo hiểm xã hội một lần (BHXH 1 lần) là chế độ an sinh xã hội cho phép người lao động rút toàn bộ số tiền đã đóng vào quỹ hưu trí và tử tuất sau khi ngừng đóng bảo hiểm và đáp ứng đầy đủ điều kiện quy định. Công cụ tính của <strong>Trợ Lý Số</strong> giúp bạn nhanh chóng ước tính số tiền nhận được dựa trên quy định Luật BHXH hiện hành.
      </p>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-6 mb-3">1. Công thức tính tiền BHXH 1 lần</h3>
      <p>Số tiền hưởng bảo hiểm xã hội 1 lần được xác định dựa trên mức bình quân tiền lương tháng đóng bảo hiểm và tổng thời gian đóng bảo hiểm:</p>
      <div class="bg-slate-50 dark:bg-slate-900/60 p-4 rounded-xl border border-slate-200 dark:border-slate-800 font-semibold mb-4 text-sm text-slate-800 dark:text-slate-200">
        Mức hưởng = Mức lương bình quân đóng BHXH × Tổng hệ số hưởng (Số tháng hưởng)
      </div>
      <p>Trong đó, <strong>Tổng hệ số hưởng</strong> được tính như sau:</p>
      <ul>
        <li><strong>1,5 tháng</strong> lương bình quân cho mỗi năm đóng BHXH trước năm 2014.</li>
        <li><strong>2,0 tháng</strong> lương bình quân cho mỗi năm đóng BHXH từ năm 2014 trở đi.</li>
      </ul>
      <p><em>* Quy tắc làm tròn số tháng:</em> Từ 1 đến 6 tháng đóng BHXH lẻ được tính là 0,5 năm; từ 7 đến 12 tháng được làm tròn thành 1,0 năm.</p>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-6 mb-3">2. Ví dụ tính BHXH 1 lần thực tế</h3>
      <p>
        Ông Nam đóng BHXH được 5 năm 4 tháng, trong đó có 2 năm đóng trước năm 2014 và 3 năm 4 tháng đóng sau năm 2014. Mức lương bình quân đóng BHXH là 8.000.000 đồng.
        <br/>- Hệ số đóng trước 2014: 2 năm × 1.5 = 3.0 tháng.
        <br/>- Hệ số đóng sau 2014: 3.5 năm (vì 4 tháng lẻ được làm tròn thành 0.5 năm) × 2.0 = 7.0 tháng.
        <br/>- Tổng hệ số hưởng = 3.0 + 7.0 = 10.0 tháng lương.
      </p>
      <div class="bg-blue-50 dark:bg-blue-950/30 p-3 rounded-lg border-l-4 border-brand-blue font-semibold text-sm my-2 text-slate-800 dark:text-slate-200 text-center">
        Tổng số tiền BHXH 1 lần ông Nam nhận được = 8.000.000 × 10 = 80.000.000 đồng
      </div>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-8 mb-3">❓ Câu hỏi thường gặp (FAQ)</h3>
      <div class="space-y-4">
        <div class="border-b border-slate-200 dark:border-slate-800 pb-3">
          <p class="font-bold text-slate-900 dark:text-white text-sm mb-1">Sau khi nghỉ việc bao lâu thì được rút BHXH 1 lần?</p>
          <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">Người lao động được rút BHXH 1 lần sau khi nghỉ việc 12 tháng (1 năm) và không tiếp tục đóng bảo hiểm xã hội bắt buộc hay tự nguyện (ngoại trừ một số trường hợp đặc biệt như mắc bệnh hiểm nghèo hoặc định cư nước ngoài được rút ngay).</p>
        </div>
        <div class="border-b border-slate-200 dark:border-slate-800 pb-3">
          <p class="font-bold text-slate-900 dark:text-white text-sm mb-1">Cách làm tròn tháng lẻ đóng bảo hiểm xã hội 1 lần như thế nào?</p>
          <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">Theo Thông tư 59/2015/TT-BLĐTBXH, thời gian đóng BHXH có tháng lẻ từ 1 đến 6 tháng được tính là nửa năm (0.5 năm); từ 7 đến 11 tháng được tính là một năm (1.0 năm).</p>
        </div>
        <div class="pb-3">
          <p class="font-bold text-slate-900 dark:text-white text-sm mb-1">Hồ sơ hưởng bảo hiểm xã hội 1 lần gồm những giấy tờ gì?</p>
          <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">Hồ sơ bao gồm: Sổ bảo hiểm xã hội (bản chính), Đơn đề nghị hưởng bảo hiểm xã hội 1 lần (Mẫu số 14-HSB), CCCD để đối chiếu thông tin khi nộp tại cơ quan BHXH quận/huyện.</p>
        </div>
      </div>

      <!-- Bi-directional Linking to Blog Post -->
      <div class="mt-8 p-4 rounded-xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 not-prose">
        <div class="flex items-center gap-3">
          <span class="text-2xl">💡</span>
          <div>
            <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-0.5">Bạn muốn tìm hiểu kỹ hơn?</h4>
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-0">Đọc cẩm nang hướng dẫn chi tiết cách rút và thủ tục nhận nhanh.</p>
          </div>
        </div>
        <a href="/blog/cach-tinh-bhxh-1-lan/" class="px-4 py-2 bg-brand-blue hover:bg-blue-700 dark:bg-brand-mint dark:hover:bg-emerald-600 text-white font-bold rounded-lg text-xs transition whitespace-nowrap shadow-sm">
          Xem bài viết →
        </a>
      </div>
    </div>

    <!-- Structured Data Schemas (JSON-LD) for SEO -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebApplication",
            "@id": "https://trolyso.online/calculators/tinh-bhxh-1-lan/#webapp",
            "name": "Công Cụ Tính Bảo Hiểm Xã Hội 1 Lần Tự Động Online",
            "url": "https://trolyso.online/calculators/tinh-bhxh-1-lan/",
            "applicationCategory": "FinanceApplication",
            "operatingSystem": "All",
            "browserRequirements": "Requires JavaScript. Requires HTML5.",
            "offers": {
              "@type": "Offer",
              "price": "0",
              "priceCurrency": "VND"
            }
          },
          {
            "@type": "FAQPage",
            "@id": "https://trolyso.online/calculators/tinh-bhxh-1-lan/#faq",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Sau khi nghỉ việc bao lâu thì được rút BHXH 1 lần?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Người lao động được rút BHXH 1 lần sau khi nghỉ việc 12 tháng (1 năm) và không tiếp tục đóng bảo hiểm xã hội bắt buộc hay tự nguyện (ngoại trừ một số trường hợp đặc biệt như mắc bệnh hiểm nghèo hoặc định cư nước ngoài được rút ngay)."
                }
              },
              {
                "@type": "Question",
                "name": "Cách làm tròn tháng lẻ đóng bảo hiểm xã hội 1 lần như thế nào?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Theo Thông tư 59/2015/TT-BLĐTBXH, thời gian đóng BHXH có tháng lẻ từ 1 đến 6 tháng được tính là nửa năm (0.5 năm); từ 7 đến 11 tháng được tính là một năm (1.0 năm)."
                }
              },
              {
                "@type": "Question",
                "name": "Hồ sơ hưởng bảo hiểm xã hội 1 lần gồm những giấy tờ gì?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Hồ sơ bao gồm: Sổ bảo hiểm xã hội (bản chính), Đơn đề nghị hưởng bảo hiểm xã hội 1 lần (Mẫu số 14-HSB), CCCD để đối chiếu thông tin khi nộp tại cơ quan BHXH quận/huyện."
                }
              }
            ]
          }
        ]
      }
    </script>

  </main>
</Layout>

<script>
  function formatMoney(amount: number) {
    const isEn = localStorage.getItem('lang') === 'en';
    if (isEn) {
      return new Intl.NumberFormat('en-US', { style: 'decimal' }).format(amount) + ' VND';
    }
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
  }

  const avgSalaryInput = document.getElementById('avgSalary') as HTMLInputElement;
  const yearsBeforeInput = document.getElementById('yearsBefore') as HTMLInputElement;
  const yearsAfterInput = document.getElementById('yearsAfter') as HTMLInputElement;

  const btnMinusBefore = document.getElementById('btnMinusBefore');
  const btnPlusBefore = document.getElementById('btnPlusBefore');
  const btnMinusAfter = document.getElementById('btnMinusAfter');
  const btnPlusAfter = document.getElementById('btnPlusAfter');
  const btnCalculate = document.getElementById('btnCalculate');

  const coeffBeforeEl = document.getElementById('coeffBefore');
  const coeffAfterEl = document.getElementById('coeffAfter');
  const totalCoeffEl = document.getElementById('totalCoeff');
  const totalBHXHEl = document.getElementById('totalBHXH');

  function calculateBHXH() {
    const avgSalary = parseFloat(avgSalaryInput.value) || 0;
    const yearsBefore = parseFloat(yearsBeforeInput.value) || 0;
    const yearsAfter = parseFloat(yearsAfterInput.value) || 0;

    const coeffBefore = yearsBefore * 1.5;
    const coeffAfter = yearsAfter * 2.0;
    const totalCoeff = coeffBefore + coeffAfter;
    const totalMoney = totalCoeff * avgSalary;

    const isEn = localStorage.getItem('lang') === 'en';
    const yearWord = isEn ? 'years' : 'năm';
    const monthWord = isEn ? 'months of salary' : 'tháng lương';

    if (coeffBeforeEl) coeffBeforeEl.innerText = `${yearsBefore} ${yearWord} x 1.5 = ${coeffBefore.toFixed(1)}`;
    if (coeffAfterEl) coeffAfterEl.innerText = `${yearsAfter} ${yearWord} x 2.0 = ${coeffAfter.toFixed(1)}`;
    if (totalCoeffEl) totalCoeffEl.innerText = `${totalCoeff.toFixed(1)} ${monthWord}`;
    if (totalBHXHEl) totalBHXHEl.innerText = formatMoney(totalMoney);
  }

  // Bind events
  btnMinusBefore?.addEventListener('click', () => {
    let val = parseFloat(yearsBeforeInput.value) || 0;
    val = Math.max(0, val - 0.5);
    yearsBeforeInput.value = val.toString();
    calculateBHXH();
  });

  btnPlusBefore?.addEventListener('click', () => {
    let val = parseFloat(yearsBeforeInput.value) || 0;
    yearsBeforeInput.value = (val + 0.5).toString();
    calculateBHXH();
  });

  btnMinusAfter?.addEventListener('click', () => {
    let val = parseFloat(yearsAfterInput.value) || 0;
    val = Math.max(0, val - 0.5);
    yearsAfterInput.value = val.toString();
    calculateBHXH();
  });

  btnPlusAfter?.addEventListener('click', () => {
    let val = parseFloat(yearsAfterInput.value) || 0;
    yearsAfterInput.value = (val + 0.5).toString();
    calculateBHXH();
  });

  btnCalculate?.addEventListener('click', calculateBHXH);
  avgSalaryInput?.addEventListener('input', calculateBHXH);
  yearsBeforeInput?.addEventListener('input', calculateBHXH);
  yearsAfterInput?.addEventListener('input', calculateBHXH);

  // Initial Calculation
  calculateBHXH();
</script>
