---
export interface Props {
  slug: string;
  type?: 'post' | 'tool' | 'calculator';
  initialCount?: number;
  showLiveDot?: boolean;
  className?: string;
}

const { slug, type = 'post', initialCount, showLiveDot = true, className = '' } = Astro.props;

// Deterministic fallback count calculation so SSG HTML has immediate nice numbers
function getHash(str: string) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = (hash << 5) - hash + str.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}

const hash = getHash(slug);
const defaultBase = (type === 'tool' || type === 'calculator') 
  ? 2500 + (hash % 8500) 
  : 800 + (hash % 3500);

const displayCount = initialCount || defaultBase;
const formattedCount = displayCount >= 1000 ? `${(displayCount / 1000).toFixed(1)}k+` : `${displayCount}`;
---

<span 
  class={`stats-badge inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200/80 dark:border-slate-700/80 transition-all duration-300 hover:scale-105 ${className}`}
  data-slug={slug}
  data-type={type}
  data-base-count={displayCount}
>
  {showLiveDot && (
    <span class="relative flex h-2 w-2">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
    </span>
  )}

  {type === 'tool' || type === 'calculator' ? (
    <svg class="w-3.5 h-3.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
    </svg>
  ) : (
    <svg class="w-3.5 h-3.5 text-blue-500 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
    </svg>
  )}

  <span class="stats-counter font-semibold text-slate-800 dark:text-slate-100">
    {formattedCount}
  </span>
  
  <span class="text-slate-500 dark:text-slate-400 font-normal">
    {type === 'tool' || type === 'calculator' ? 'lượt tính' : 'lượt xem'}
  </span>
</span>
